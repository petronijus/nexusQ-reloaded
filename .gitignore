output/
build/

# nexusqd compiled binaries (built by make / the aport, never committed)
userspace/nexusqd/nexusqd
userspace/nexusqd/nexusled

# IDE / debug scratch
.cursor/
fb_err.txt
fb_out.txt

# Private overlay (non-redistributable firmware)
/private/

# Stock Nexus Q companion imagery extracted from the decompiled APK
# (Google copyright — see scripts/extract-stock-assets.sh)
companion/app/assets/stock/**
!companion/app/assets/stock/drawable/
!companion/app/assets/stock/raw/
!companion/app/assets/stock/drawable/.keep
!companion/app/assets/stock/raw/.keep
firmware/bcm4330.hcd
firmware/bcmdhd.cal
# Redistributable (upstream linux-firmware) -- cached locally, else fetched at build time
firmware/brcmfmac4330-sdio.bin

# Build/session scratch logs
build-*.log
gadget-install.log

# Device root password (read at runtime by flash/SSH helpers; never committed)
.nexus_pw

# Reverse-engineering scratch (extracted Google factory image — non-redistributable, large)
reverse-eng/
scripts/ulpiread

# Working scratch: debug tools, carved stock ramdisks/system mounts, extracted
# Google blobs (e.g. the stock BCM4330 patchram we diffed ours against). Same
# non-redistributable class as reverse-eng/ — never committable.
scratchpad/

# Python bytecode
__pycache__/
*.pyc
