<?xml version="1.0" encoding="utf-8"?>
<!--
    HCE registration for the Nexus Q "tap-to-send" link. Declares the custom AID
    F0010203040506 under the "other" category (not a standard payment AID). The
    device need not be unlocked or screen-on, so the Q can push a text even while
    the phone is idle in a pocket.
-->
<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/hce_service_description"
    android:requireDeviceUnlock="false"
    android:requireDeviceScreenOn="false"
    android:shouldDefaultToObserveMode="false">
    <aid-group
        android:category="other"
        android:description="@string/hce_aid_group_description">
        <aid-filter android:name="F0010203040506"/>
    </aid-group>
</host-apdu-service>
