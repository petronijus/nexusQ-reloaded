// SPDX-License-Identifier: GPL-2.0-only
/*
 * Device Tree Source for Google Nexus Q (steelhead)
 *
 * Copyright (C) 2024-2025 Nexus Q Reloaded Project
 *
 * Based on omap4-panda-common.dtsi and original board-steelhead.c
 * from the CyanogenMod android_kernel_google_steelhead repository.
 *
 * Hardware:
 *   SoC:       TI OMAP4460 (dual Cortex-A9 @ 1.2 GHz)
 *   RAM:       1 GB LPDDR2 (Elpida ECB240ABACN)
 *   Storage:   16 GB eMMC (Samsung KLMAG4FEJA-A002)
 *   WiFi/BT:   Broadcom BCM4330 (SDIO + UART2)
 *   Audio:     TAS5713 25W amp (I2C4 + McBSP2) + HDMI; no codec (the
 *              TWL6040 is unused/unpopulated on steelhead per the stock kernel)
 *   NFC:       NXP PN544 (I2C3)
 *   Ethernet:  SMSC LAN9500A (USB EHCI)
 *   HDMI:      OMAP4 DSS via TPD12S015A (micro-HDMI)
 *   LEDs:      AVR MCU (I2C2) -> LP5523 drivers (32 RGB LEDs)
 *   PMIC:      TWL6030 + TPS62361
 */

/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include "omap4460.dtsi"
#include "elpida_ecb240abacn.dtsi"
/* omap4-mcpdm.dtsi deliberately NOT included: it enables the McPDM
 * target-module (0x40132000) with a TWL6040 as its pdmclk provider, but
 * steelhead has no TWL6040 at all (see the sound-card note below), so the
 * ti-sysc ext-opt-clock quirk deferred the module forever ("deferred probe
 * pending: (reason unknown)" every boot). Without the include McPDM stays at
 * its upstream disabled default — correct, since McPDM needs the codec. */

/ {
	model = "Google Nexus Q";
	compatible = "google,steelhead", "ti,omap4460", "ti,omap4";

	memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 0x40000000>; /* 1 GB */
	};

	chosen {
		stdout-path = &uart3;
	};

	aliases {
		ethernet = &ethernet;
	};

	/*
	 * HS USB Host PHY on PORT 1 for Ethernet (SMSC USB3320, ULPI).
	 * Modelled as a bare nop-xceiv: the USB3320 is driven directly through
	 * the OMAP EHCI ULPI viewport, and its 38.4 MHz reference clock
	 * (auxclk3), power enable (gpio_1 NENABLE) and reset (gpio_62 NRESET)
	 * are sequenced imperatively by the steelhead ehci-omap bring-up in the
	 * vendor board order (clk -> enable -> reset), NOT by nop-xceiv /
	 * regulator probe order -- which released reset before the refclk was
	 * stable, so the LAN9500A never enumerated (PORTSC CCS stayed 0). The
	 * power rail (was a regulator-fixed "hsusb1_vbus" on gpio_1) and the
	 * PHY clock/reset are therefore owned by &usbhsehci, see below.
	 */
	hsusb1_phy: hsusb1-phy {
		compatible = "usb-nop-xceiv";
		#phy-cells = <0>;
	};

	/* BCM4330 WiFi power sequencing: 32k LPO + WLAN_EN (gpio_43),
	 * mirrors steelhead_wifi_power() in board-steelhead-wifi.c:
	 * clk32k on -> 300 ms settle -> WLAN_EN high -> 200 ms.
	 *
	 * The 32k source is the TWL6030 CLK32KG output (<&twl 0>, CFG_TRANS
	 * 0x8C). Stock's consumer string "clk32kaudio" is MISLEADING: its
	 * board data wires that name to the CLK32KG regulator (id 48,
	 * steelhead_twldata+0x8c), the real CLK32KAUDIO slot is NULL. Our
	 * earlier <&twl 1> (CLK32KAUDIO, 0x8F) gated the WRONG pin, so the
	 * chip's LPO never ran — prime suspect for the flaky WiFi/BT
	 * (stock-parity audit 2026-07-02, steelhead_wifi_power @ 0xc0077884).
	 * clk-settle-delay-ms is our pwrseq-simple extension (patch 0028). */
	bcm4330_pwrseq: bcm4330-pwrseq {
		compatible = "mmc-pwrseq-simple";
		pinctrl-names = "default";
		pinctrl-0 = <&wlan_en_pins>;
		reset-gpios = <&gpio2 11 GPIO_ACTIVE_LOW>; /* gpio_43 WLAN_EN */
		clk-settle-delay-ms = <300>;
		post-power-on-delay-ms = <200>;
		clocks = <&twl 0>; /* TWL6030 CLK32KG */
		clock-names = "ext_clock";
	};

	/* BCM4330 VBAT 3.3V - static rail, WLAN_EN is handled by pwrseq.
	 * 3.3V matters for SDIO OCR negotiation (card advertises 3.2-3.4V). */
	bcm4330_vmmc: bcm4330-vmmc {
		compatible = "regulator-fixed";
		regulator-name = "vbcm4330";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};

	/* TAS5713 speaker power rail (PVDD_A..D). Hardwired on the board;
	 * voltage NOT asserted here (unmeasured — TAS5713 spec 8-26 V) since
	 * the tas571x driver only enable()s its supplies. */
	amp_pvdd: amp-pvdd {
		compatible = "regulator-fixed";
		regulator-name = "amp_pvdd";
		regulator-always-on;
		regulator-boot-on;
	};

	/* Board 3.3 V rail for the TAS5713 amp AVDD/DVDD (analog + digital). */
	vdd_3v3: vdd-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vdd_3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};

	/*
	 * VDD_MPU cpu-supply for cpufreq. The TPS62361 lives on the write-only PRM
	 * VC SR-i2c (no Linux i2c regulator), so this VC-bridge regulator
	 * (steelhead-vc-mpu-regulator.c) translates regulator_set_voltage() into a
	 * scale on the mpu voltage domain via the OMAP voltage layer (VP force-update),
	 * and engages Forward Body Bias via vbb-supply (abb_mpu) at OPP-Nitro. Range
	 * covers OPP50..OPP-Nitro (1025..1380 mV, 350/700/920/1200 MHz).
	 */
	vc_mpu_supply: regulator-vc-mpu {
		compatible = "steelhead,vc-mpu-supply";
		regulator-name = "vdd_mpu";
		regulator-min-microvolt = <1025000>;
		regulator-max-microvolt = <1380000>;
		regulator-boot-on;
		regulator-always-on;
		vbb-supply = <&abb_mpu>;
	};

	/* HDMI level converter: TPD12S015A */
	tpd12s015: encoder0 {
		compatible = "ti,tpd12s015";

		gpios = <&gpio2 28 GPIO_ACTIVE_HIGH>,	/* gpio_60 CT_CP_HPD */
			<&gpio2 9 GPIO_ACTIVE_HIGH>,	/* gpio_41 LS_OE */
			<&gpio2 31 GPIO_ACTIVE_HIGH>;	/* gpio_63 HPD */

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				tpd12s015_in: endpoint {
					remote-endpoint = <&hdmi_out>;
				};
			};

			port@1 {
				reg = <1>;
				tpd12s015_out: endpoint {
					remote-endpoint = <&hdmi_connector_in>;
				};
			};
		};
	};

	hdmi0: connector0 {
		compatible = "hdmi-connector";
		label = "hdmi";
		type = "d"; /* micro-HDMI */

		port {
			hdmi_connector_in: endpoint {
				remote-endpoint = <&tpd12s015_out>;
			};
		};
	};

	/* S/PDIF digital audio output (TOSLINK) */
	spdif_dit: spdif-dit {
		compatible = "linux,spdif-dit";
		#sound-dai-cells = <0>;
	};

	/*
	 * NO TWL6040 codec / ABE sound card on steelhead. The earlier
	 * "dead chip on this unit" verdict (2026-06-10, no I2C ACK on 0x4b)
	 * was wrong in kind: the stock 3.0.8 kernel contains ZERO twl6040 /
	 * AUDPWRON code (whole-image string+symbol sweep), the twldata codec
	 * pdata slot is NULL (steelhead_twldata+0x24), and stock's i2c1 board
	 * info registers only the twl6030@0x48 — the chip is simply not used
	 * (and almost certainly not populated) on this board, so the missing
	 * ACK is the stock-correct behaviour. Audit 2026-07-03, evidence in
	 * docs/2026-07-02-stock-parity-voltage-wifi-idle.md. Audio is the
	 * TAS5713 below + HDMI; there is no headset/aux path by design.
	 */

	/* Speaker amp: McBSP2 I2S -> TAS5713 (25 W class-D) */
	sound_tas5713: sound-tas5713 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "NexusQ-Speaker";
		simple-audio-card,format = "i2s";
		simple-audio-card,mclk-fs = <256>;
		simple-audio-card,bitclock-master = <&tas5713_cpu>;
		simple-audio-card,frame-master = <&tas5713_cpu>;

		tas5713_cpu: simple-audio-card,cpu {
			sound-dai = <&mcbsp2>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas5713>;
		};
	};

	/*
	 * Optical S/PDIF out: OMAP4 McASP in DIT (IEC958) mode -> spdif-dit codec.
	 * In DIT mode the McASP generates its own IEC958 framing, so no i2s
	 * format / bit-/frame-master negotiation is needed (unlike the TAS5713
	 * link above); the link just binds the McASP DIT DAI to the DIT codec.
	 * Mirrors stock's omap-mcasp-dai <-> dit-hifi card ("Steelhead SPDIF Card").
	 */
	sound_spdif: sound-spdif {
		compatible = "simple-audio-card";
		simple-audio-card,name = "NexusQ-SPDIF";
		/*
		 * The McASP in DIT mode generates the IEC958 framing itself, but
		 * simple-audio-card still calls snd_soc_dai_set_fmt() on the cpu DAI.
		 * davinci_mcasp_set_dai_fmt() returns -EINVAL (-22, seen at v1.6.13
		 * probe) when the SND_SOC_DAIFMT_FORMAT field is 0 (its default: case).
		 * Give it a valid format ("i2s") and make the McASP the bit+frame
		 * master — DIT drives its own TX clock from the ABE McASP fck, there is
		 * no external codec clock (spdif-dit is a dummy sink).
		 */
		simple-audio-card,format = "i2s";
		simple-audio-card,bitclock-master = <&spdif_cpu>;
		simple-audio-card,frame-master = <&spdif_cpu>;

		spdif_cpu: simple-audio-card,cpu {
			sound-dai = <&mcasp0>;
		};

		simple-audio-card,codec {
			sound-dai = <&spdif_dit>;
		};
	};
};

&omap4_pmx_core {
	pinctrl-names = "default";
	pinctrl-0 = <
		&dss_hdmi_pins
		&tpd12s015_pins
		&hsusbb1_pins
		&ethernet_gpios
	>;

	i2c1_pins: i2c1-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x122, PIN_INPUT | MUX_MODE0)	/* i2c1_scl */
			OMAP4_IOPAD(0x124, PIN_INPUT | MUX_MODE0)	/* i2c1_sda */
		>;
	};

	i2c2_pins: i2c2-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x126, PIN_INPUT | MUX_MODE0)	/* i2c2_scl */
			OMAP4_IOPAD(0x128, PIN_INPUT | MUX_MODE0)	/* i2c2_sda */
		>;
	};

	i2c3_pins: i2c3-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x12a, PIN_INPUT | MUX_MODE0)	/* i2c3_scl */
			OMAP4_IOPAD(0x12c, PIN_INPUT | MUX_MODE0)	/* i2c3_sda */
		>;
	};

	i2c4_pins: i2c4-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x12e, PIN_INPUT | MUX_MODE0)	/* i2c4_scl */
			OMAP4_IOPAD(0x130, PIN_INPUT | MUX_MODE0)	/* i2c4_sda */
		>;
	};

	dss_hdmi_pins: dss-hdmi-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x09a, PIN_INPUT | MUX_MODE0)	/* hdmi_cec */
			/*
			 * DDC (EDID I2C) pads: do NOT force the SoC internal
			 * pull-up. These are open-drain DDC lines; the TPD12S015
			 * companion provides the external pull-ups. Forcing the
			 * weak (~50k) internal PULLUP fights the external pulls
			 * and corrupts SCL/SDA edges -> "HDMICORE timeout reading
			 * edid" (TMDS is a separate pad group, so video still
			 * works). Stock leaves these pads un-muxed (no SW pull).
			 */
			OMAP4_IOPAD(0x09c, PIN_INPUT | MUX_MODE0)	/* hdmi_scl (DDC) */
			OMAP4_IOPAD(0x09e, PIN_INPUT | MUX_MODE0)	/* hdmi_sda (DDC) */
		>;
	};

	tpd12s015_pins: tpd12s015-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x062, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a17.gpio_41 LS_OE */
			OMAP4_IOPAD(0x088, PIN_OUTPUT | MUX_MODE3)		/* gpmc_nbe1.gpio_60 CT_CP_HPD */
			OMAP4_IOPAD(0x098, PIN_INPUT_PULLDOWN | MUX_MODE3)	/* hdmi_hpd.gpio_63 HPD */
		>;
	};

	hsusbb1_pins: hsusbb1-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x0c2, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_clk */
			OMAP4_IOPAD(0x0c4, PIN_OUTPUT | MUX_MODE4)		/* usbb1_ulpiphy_stp */
			OMAP4_IOPAD(0x0c6, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dir */
			OMAP4_IOPAD(0x0c8, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_nxt */
			OMAP4_IOPAD(0x0ca, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat0 */
			OMAP4_IOPAD(0x0cc, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat1 */
			OMAP4_IOPAD(0x0ce, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat2 */
			OMAP4_IOPAD(0x0d0, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat3 */
			OMAP4_IOPAD(0x0d2, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat4 */
			OMAP4_IOPAD(0x0d4, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat5 */
			OMAP4_IOPAD(0x0d6, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat6 */
			OMAP4_IOPAD(0x0d8, PIN_INPUT_PULLDOWN | MUX_MODE4)	/* usbb1_ulpiphy_dat7 */
		>;
	};

	ethernet_gpios: ethernet-gpios {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x08c, PIN_OUTPUT | MUX_MODE3)		/* gpmc_wait0.gpio_62 NRESET */
			/*
			 * THE cold-init fix (2026-07-06): gpio_1 NENABLE, the
			 * LAN9500A power-enable, is pad kpd_col2 @ 0x186 in the
			 * CORE padconf -- NOT the wkup domain as a prior comment
			 * wrongly assumed, which is why it was omitted. Without
			 * this mux gpiolib drove the gpio_1 DATAOUT latch (read
			 * "asserted") but the pad stayed in safe_mode and NENABLE
			 * never reached the chip, so the LAN9500A was never
			 * powered on and never drove D+ (PORTSC CCS=0 forever) on
			 * a cold boot. Stock muxes BOTH pads (omap_mux_init_gpio
			 * 1 and 62 @ VA 0xc00178d0/dc, values 0x0e03). Proven
			 * live: writing this pad (0x4A100184 upper16=0x0e03) +
			 * re-running the bring-up made eth0 attach at 100Mbps
			 * from the cold-failed state. Same pinmux-miss class of
			 * bug as the NFC pads. */
			OMAP4_IOPAD(0x186, PIN_OUTPUT | MUX_MODE3)		/* kpd_col2.gpio_1 NENABLE (LAN9500A power enable) */
			/*
			 * gpio_159 (usbb2_ulpitll_dir 0x164) intentionally NOT
			 * muxed: stock leaves that pad in safe_mode (mux dump
			 * 0x011f) and only pulses gpio_159 in a hub_control resume
			 * recovery path that is a no-op on this board — it is not
			 * wired to the LAN9500A. Driving it was a non-stock guess;
			 * removed 2026-07-06 for parity (the real fix is the 0x186
			 * NENABLE pad above).
			 */
		>;
	};

	wlan_en_pins: wlan-en-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x066, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a19.gpio_43 WLAN_EN */
		>;
	};

	wlan_sdio_pins: wlan-sdio-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x07a, PIN_INPUT | MUX_MODE3)		/* gpmc_ncs3.gpio_53 WLAN_IRQ */
			OMAP4_IOPAD(0x148, PIN_INPUT_PULLUP | MUX_MODE0)	/* sdmmc5_clk */
			OMAP4_IOPAD(0x14a, PIN_INPUT_PULLUP | MUX_MODE0)	/* sdmmc5_cmd */
			OMAP4_IOPAD(0x14c, PIN_INPUT_PULLUP | MUX_MODE0)	/* sdmmc5_dat0 */
			OMAP4_IOPAD(0x14e, PIN_INPUT_PULLUP | MUX_MODE0)	/* sdmmc5_dat1 */
			OMAP4_IOPAD(0x150, PIN_INPUT_PULLUP | MUX_MODE0)	/* sdmmc5_dat2 */
			OMAP4_IOPAD(0x152, PIN_INPUT_PULLUP | MUX_MODE0)	/* sdmmc5_dat3 */
		>;
	};

	bt_pins: bt-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x06c, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a22.gpio_46 BT_EN */
			OMAP4_IOPAD(0x078, PIN_OUTPUT | MUX_MODE3)		/* gpmc_ncs2.gpio_52 BT_RESET */
			OMAP4_IOPAD(0x06a, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a21.gpio_45 BT_WAKE */
			OMAP4_IOPAD(0x06e, PIN_INPUT_PULLDOWN | MUX_MODE3)	/* gpmc_a23.gpio_47 HOST_WAKE */
		>;
	};

	uart2_pins: uart2-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x118, PIN_INPUT_PULLUP | MUX_MODE0)	/* uart2_cts */
			OMAP4_IOPAD(0x11a, PIN_OUTPUT | MUX_MODE0)		/* uart2_rts */
			OMAP4_IOPAD(0x11c, PIN_INPUT_PULLUP | MUX_MODE0)	/* uart2_rx */
			OMAP4_IOPAD(0x11e, PIN_OUTPUT | MUX_MODE0)		/* uart2_tx */
		>;
	};

	/* NFC pads. THE 2026-07-03 ROOT CAUSE of the "chip never ACKs" saga:
	 * these were 0x1b4/0x1b6/0x1b8 — the dpm_emu3/4/5 debug pads — so the
	 * REAL NFC pads (usbb2_ulpitll_dat1/2/3) stayed in their bootloader
	 * state and VEN/FW/IRQ never reached the chip; the PN544 looked dead
	 * from mainline while being perfectly alive (stock RAM boot: ACK at
	 * 0x28 with VEN high, core-reset frame accepted). Correct offsets +
	 * values read live from the WORKING stock kernel's omap_mux debugfs
	 * (reverse-eng/stock-omap-mux-full.txt): 0x16a/0x16c = 0x0003,
	 * 0x16e = 0x011b. */
	nfc_pins: nfc-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x16a, PIN_OUTPUT | MUX_MODE3)		/* usbb2_ulpitll_dat1.gpio_162 FW */
			OMAP4_IOPAD(0x16c, PIN_OUTPUT | MUX_MODE3)		/* usbb2_ulpitll_dat2.gpio_163 EN */
			OMAP4_IOPAD(0x16e, PIN_INPUT_PULLUP | MUX_MODE3)	/* usbb2_ulpitll_dat3.gpio_164 IRQ */
		>;
	};

	tas5713_pins: tas5713-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x060, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a16.gpio_40 IFACE_EN */
			OMAP4_IOPAD(0x064, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a18.gpio_42 RESET */
			OMAP4_IOPAD(0x068, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a20.gpio_44 PDN */
			OMAP4_IOPAD(0x19a, PIN_OUTPUT | MUX_MODE0)		/* fref_clk1_out -> TAS5713 MCLK */
		>;
	};

	/*
	 * McBSP2 I2S pads for the TAS5713 amplifier.
	 * Stock (board-steelhead.c + reverse-eng/stock-omap-mux-full.txt) routes
	 * McBSP2 on the abe_mcbsp2_* ball cluster in MUX_MODE0:
	 *   clkx=0x0f6, dx=0x0fa, fsx=0x0fc   (dr=0x0f8 is unused by the TX-only
	 *   TAS5713 link and is repurposed as the S/PDIF AXR out, see below).
	 * The previous DTS muxed 0x110/0x114/0x116 — but those are the abe_dmic_*
	 * pads, NOT McBSP2. Confirmed 2026-07-07 against the stock mux dump AND a
	 * live pinctrl read: with the old (wrong) mux, 0x0f6/0x0fa/0x0fc sat in
	 * safe_mode, so the McBSP2 I2S clock/data/frame never reached the amp
	 * (aplay returned rc=0 but nothing was actually driven to the speaker).
	 */
	mcbsp2_pins: mcbsp2-pins {
		pinctrl-single,pins = <
			/* McBSP2 is bit/frame master -> clkx/dx/fsx OUTPUT (stock) */
			OMAP4_IOPAD(0x0f6, PIN_OUTPUT | MUX_MODE0)		/* abe_mcbsp2_clkx */
			OMAP4_IOPAD(0x0fa, PIN_OUTPUT | MUX_MODE0)		/* abe_mcbsp2_dx */
			OMAP4_IOPAD(0x0fc, PIN_OUTPUT | MUX_MODE0)		/* abe_mcbsp2_fsx */
		>;
	};

	/*
	 * S/PDIF (optical TOSLINK) output: OMAP4 McASP serializer AXR0 on the
	 * abe_mcbsp2_dr ball in MUX_MODE2 (abe_mcasp_axr). Stock board-steelhead.c
	 * does exactly omap_mux_init_signal("abe_mcbsp2_dr.abe_mcasp_axr", 0) ->
	 * padconf 0x0f8 = 0x0002. This ball is McBSP2's data-RECEIVE line, unused
	 * by the TX-only TAS5713 link, so the speaker and optical paths never clash.
	 */
	mcasp_spdif_pins: mcasp-spdif-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x0f8, PIN_OUTPUT | MUX_MODE2)		/* abe_mcbsp2_dr.abe_mcasp_axr */
		>;
	};

	avr_pins: avr-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x070, PIN_OUTPUT | MUX_MODE3)		/* gpmc_a24.gpio_48 RESET */
			OMAP4_IOPAD(0x072, PIN_INPUT_PULLUP | MUX_MODE3)	/* gpmc_a25.gpio_49 INT */
		>;
	};
};

&omap4_pmx_wkup {
	pinctrl-names = "default";
	pinctrl-0 = <&ethernet_wkup_pins &tps62361_vsel_pins>;

	msecure_pins: msecure-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x050, PIN_OUTPUT | MUX_MODE3)		/* fref_clk0_out.gpio_wk6 */
		>;
	};

	ethernet_wkup_pins: ethernet-wkup-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x042, PIN_OUTPUT | MUX_MODE3)		/* gpio_wk1 NENABLE */
			OMAP4_IOPAD(0x058, PIN_OUTPUT | MUX_MODE0)		/* fref_clk3_out -> PHY 38.4 MHz */
		>;
	};

	/*
	 * TPS62361 VDD_MPU regulator VSEL0 select line. gpio_wk7 is driven high
	 * (see the &gpio1 hog below) so the chip outputs its SET1 register -- the
	 * register the OMAP Voltage Controller writes VDD_MPU voltages to. Pad,
	 * mux mode and drive level were decoded from the stock kernel (gpio 7,
	 * fref_clk4_req mode 3, gpio_direction_output high).
	 */
	tps62361_vsel_pins: tps62361-vsel-pins {
		pinctrl-single,pins = <
			OMAP4_IOPAD(0x05a, PIN_OUTPUT | MUX_MODE3)		/* fref_clk4_req.gpio_wk7 TPS62361 VSEL0 */
		>;
	};
};

&gpio1 {
	/*
	 * Hold TPS62361 VSEL0 (gpio_wk7) high from boot so VDD_MPU is taken from
	 * the TPS SET1 register. The TPS is dormant (VCORE1 drives VDD_MPU) until
	 * the Stage-1b retasking (omap4460_vdd_mpu_retask) enables it, so driving
	 * this line early is harmless.
	 */
	tps62361_vsel0_hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "tps62361-vsel0";
	};
};

/* I2C1: TWL6030 PMIC + TWL6040 Audio Codec */
&i2c1 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c1_pins>;
	clock-frequency = <400000>;

	twl: twl@48 {
		reg = <0x48>;
		interrupts = <GIC_SPI 7 IRQ_TYPE_LEVEL_HIGH>;
		#clock-cells = <1>;
		system-power-controller;
	};

	/* No twl6040@4b node: the codec does not exist on steelhead (see the
	 * sound-card note above; the removed node's ti,audpwron-gpio gpio_127
	 * had no stock evidence either — stock uses hdq_sio for nothing). */
};

#include "twl6030.dtsi"
#include "twl6030_omap4.dtsi"

/* I2C2: AVR front panel controller + TMP101 temperature sensor */
&i2c2 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c2_pins>;
	clock-frequency = <400000>;

	avr@20 {
		compatible = "google,steelhead-avr";
		reg = <0x20>;
		pinctrl-names = "default";
		pinctrl-0 = <&avr_pins>;
		interrupt-parent = <&gpio2>;
		interrupts = <17 IRQ_TYPE_EDGE_FALLING>; /* gpio_49 */
		reset-gpios = <&gpio2 16 GPIO_ACTIVE_LOW>; /* gpio_48 */
	};

	tmp101@48 {
		compatible = "ti,tmp101";
		reg = <0x48>;
		vs-supply = <&v1v8>;	/* sensor I/O rail = 1.8 V */
	};
};

/* I2C3: NXP PN544 NFC */
&i2c3 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c3_pins>;
	clock-frequency = <400000>;

	/* RESOLVED 2026-07-03: the chip was never dead — the nfc_pins pinmux
	 * pointed at the dpm_emu debug pads instead of usbb2_ulpitll_dat1/2/3
	 * (see the nfc_pins comment), so VEN/FW/IRQ never reached it. Verified
	 * alive under the stock RAM boot: ACK at 0x28 with VEN high, 6-byte
	 * core-reset frame accepted, silent with VEN low — pins, polarity and
	 * timing all stock-parity MATCH (and patch 0020 keeps the stock VEN
	 * settle). Node re-enabled together with the pad fix. */
	pn544@28 {
		compatible = "nxp,pn544-i2c";
		reg = <0x28>;
		pinctrl-names = "default";
		pinctrl-0 = <&nfc_pins>;
		interrupt-parent = <&gpio6>;
		interrupts = <4 IRQ_TYPE_LEVEL_HIGH>; /* gpio_164 (stock IRQF_TRIGGER_HIGH) */
		enable-gpios = <&gpio6 3 GPIO_ACTIVE_HIGH>; /* gpio_163 */
		firmware-gpios = <&gpio6 2 GPIO_ACTIVE_HIGH>; /* gpio_162 */
	};
};

/* I2C4: TAS5713 25W Class-D amplifier */
&i2c4 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c4_pins>;
	clock-frequency = <400000>;

	tas5713: tas5713@1b {
		compatible = "ti,tas5713";
		reg = <0x1b>;
		pinctrl-names = "default";
		pinctrl-0 = <&tas5713_pins>;

		reset-gpios = <&gpio2 10 GPIO_ACTIVE_LOW>; /* gpio_42 */
		pdn-gpios = <&gpio2 12 GPIO_ACTIVE_LOW>; /* gpio_44 */

		/* Board 3.3 V analog + digital supplies (the driver only enables
		 * these, never programs a voltage). PVDD_A..D = the speaker power
		 * rail (amp_pvdd below): hardwired-on, exact voltage unmeasured
		 * (TAS5713 spec allows 8-26 V), so the regulator node deliberately
		 * carries no voltage properties — enabling is all the driver does,
		 * and this replaces the four "using dummy regulator" boot warnings
		 * with the real topology. */
		AVDD-supply = <&vdd_3v3>;
		DVDD-supply = <&vdd_3v3>;
		PVDD_A-supply = <&amp_pvdd>;
		PVDD_B-supply = <&amp_pvdd>;
		PVDD_C-supply = <&amp_pvdd>;
		PVDD_D-supply = <&amp_pvdd>;

		/* MCLK 12.288 MHz (256 x 48 kHz) on fref_clk1_out:
		 * dpll_per_m3x2 -> 61.44 MHz, auxclk1 divides by 5
		 * (board-steelhead.c lines 755-810) */
		clocks = <&auxclk1_ck>;
		clock-names = "mclk";
		assigned-clocks = <&dpll_per_m3x2_ck>, <&auxclk1_src_ck>, <&auxclk1_ck>;
		assigned-clock-parents = <0>, <&dpll_per_m3x2_ck>, <0>;
		assigned-clock-rates = <61440000>, <0>, <12288000>;

		#sound-dai-cells = <0>;
	};
};

/* MMC1: eMMC (16 GB Samsung moviNAND), non-removable, 8-bit bus */
&mmc1 {
	vmmc-supply = <&vmmc>;
	bus-width = <8>;
	non-removable;
};

&mmc2 {
	status = "disabled";
};

&mmc3 {
	status = "disabled";
};

&mmc4 {
	status = "disabled";
};

/* MMC5: BCM4330 WiFi (SDIO, brcmfmac driver) */
&mmc5 {
	pinctrl-names = "default";
	pinctrl-0 = <&wlan_sdio_pins>;
	vmmc-supply = <&bcm4330_vmmc>;
	non-removable;
	bus-width = <4>;
	cap-power-off-card;
	mmc-pwrseq = <&bcm4330_pwrseq>;

	#address-cells = <1>;
	#size-cells = <0>;

	brcmf: wifi@1 {
		compatible = "brcm,bcm4330-fmac", "brcm,bcm4329-fmac";
		reg = <1>;
		interrupt-parent = <&gpio2>;
		interrupts = <21 IRQ_TYPE_LEVEL_HIGH>; /* gpio_53 */
		interrupt-names = "host-wake";
		/* Per-device factory WiFi MAC (patch 0043). brcmfmac has no on-device
		 * source for it (nvram is a placeholder; OTP holds a generic Murata
		 * MAC), so pin it here just as the BT node pins local-bd-address. */
		local-mac-address = [f8 8f ca 20 48 e1];
	};
};

&emif1 {
	cs1-used;
	device-handle = <&elpida_ECB240ABACN>;
};

&emif2 {
	cs1-used;
	device-handle = <&elpida_ECB240ABACN>;
};

/* UART2: BCM4330 Bluetooth HCI */
&uart2 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart2_pins>;
	interrupts-extended = <&wakeupgen GIC_SPI 73 IRQ_TYPE_LEVEL_HIGH
			       &omap4_pmx_core OMAP4_UART2_RX>;

	bluetooth {
		compatible = "brcm,bcm4330-bt";
		pinctrl-names = "default";
		pinctrl-0 = <&bt_pins>;
		/* Operating HCI UART baud. WITHOUT this, hci_bcm leaves oper_speed=0
		 * and never syncs the host UART to the rate the BCM4330 firmware runs
		 * at, so host and controller drift apart -> "hci0: Frame reassembly
		 * failed (-84)" (EILSEQ), command tx timeouts, phantom Connected
		 * state, and A2DP audio arriving in corrupt bursts (~1 s sound then
		 * seconds of silence). Stock ran the BT UART at 3 Mbaud (the value
		 * that dominates the stock kernel image); match it so hci_bcm commands
		 * both ends to 3 Mbaud and the link is clean. RTS/CTS are muxed in
		 * uart2_pins. (2026-07-08 crackle/BT-audio investigation.) */
		max-speed = <3000000>;
		shutdown-gpios = <&gpio2 14 GPIO_ACTIVE_HIGH>; /* gpio_46 BT_EN */
		reset-gpios = <&gpio2 20 GPIO_ACTIVE_LOW>; /* gpio_52 BT_RESET */
		device-wakeup-gpios = <&gpio2 13 GPIO_ACTIVE_HIGH>; /* gpio_45 BT_WAKE */
		host-wakeup-gpios = <&gpio2 15 GPIO_ACTIVE_HIGH>; /* gpio_47 HOST_WAKE */
		/* Real per-device BT MAC (stock injected it via the
		 * board_steelhead_bluetooth.btaddr= cmdline). Without it btbcm
		 * leaves the BCM4330B1 .hcd placeholder 43:30:A0:00:00:00, which is
		 * (a) identical on every unit (pairing-record collisions) and (b)
		 * malformed — MSB 0x43 has the multicast/group bit set, an invalid
		 * unicast public address. btbcm issues the vendor Write_BD_ADDR
		 * (0xFC01) from this property. Bytes are DT little-endian of
		 * f8:8f:ca:20:49:e5 (2026-07-06). */
		local-bd-address = [e5 49 20 ca 8f f8];
		/* TWL6030 CLK32KG — same pin as WiFi (stock BT rfkill enables the
		 * identical "clk32kaudio"-named CLK32KG regulator; see the pwrseq
		 * node comment for the naming trap). */
		clocks = <&twl 0>;
		clock-names = "ext_clock";
		vbat-supply = <&bcm4330_vmmc>;	/* BCM4330 VBAT 3.3 V (shared rail) */
		vddio-supply = <&v1v8>;		/* BCM4330 I/O 1.8 V */
	};
};

/* UART3: Debug console (ttyS2 with mainline 8250 driver) */
&uart3 {
	interrupts-extended = <&wakeupgen GIC_SPI 74 IRQ_TYPE_LEVEL_HIGH
			       &omap4_pmx_core OMAP4_UART3_RX>;
};

/* UART4: AVR programming port */
&uart4 {
	interrupts-extended = <&wakeupgen GIC_SPI 70 IRQ_TYPE_LEVEL_HIGH
			       &omap4_pmx_core OMAP4_UART4_RX>;
};

/* USB OTG (Micro-USB service port) */
&usb_otg_hs {
	interface-type = <1>;
	mode = <3>; /* OTG */
	power = <500>;
};

/* USB Host for SMSC LAN9500A Ethernet */
&usbhshost {
	port1-mode = "ehci-phy";
};

&usbhsehci {
	phys = <&hsusb1_phy>;

	/*
	 * Steelhead LAN9500A bring-up resources, sequenced by ehci-omap in the
	 * vendor board order (steelhead_usbhost_init): with the 38.4 MHz PHY
	 * refclk (auxclk3) enabled, drive NENABLE low (power on), settle, then
	 * release NRESET high, before the controller is started. Both gpios are
	 * active-low (raw: NENABLE HIGH=off / LOW=on, NRESET LOW=reset /
	 * HIGH=run); the driver uses logical levels (asserted = enabled / in
	 * reset). Optional in the driver, so a no-op on non-steelhead boards.
	 */
	clocks = <&auxclk3_ck>;
	clock-names = "steelhead-ethernet-phy";
	steelhead-ethernet-enable-gpios = <&gpio1 1 GPIO_ACTIVE_LOW>;	/* gpio_1  NENABLE (pad kpd_col2 0x186, see ethernet_gpios) */
	steelhead-ethernet-reset-gpios = <&gpio2 30 GPIO_ACTIVE_LOW>;	/* gpio_62 NRESET  */
	/* gpio_159 (steelhead-eth-phy-reset) removed 2026-07-06: stock leaves
	 * its pad in safe_mode and it is not wired to the LAN9500A (its only
	 * stock use is a no-op resume-recovery path). Not an ethernet line. */

	#address-cells = <1>;
	#size-cells = <0>;

	ethernet: ethernet@1 {
		compatible = "usb424,9500";
		reg = <1>;
	};
};

/*
 * OMAP4 USBHS muxes ONE external ULPI PHY (port 1) between the EHCI and the
 * OHCI cores. The Nexus Q only uses port 1 for the high-speed LAN9500A on EHCI;
 * the vendor board kernel explicitly held the OHCI suspended (HcControl =
 * OHCI_USB_SUSPEND) at EHCI probe so it never contends for / drives the shared
 * ULPI port. Mainline brings OHCI up as a live HCD on the same PHY (bus 3),
 * which can keep the EHCI from seeing a downstream connect. Disable it.
 */
&usbhsohci {
	status = "disabled";
};

/* McBSP2: I2S output to TAS5713 amplifier.
 * Internal (PRCM) functional clock must come from the ABE DPLL
 * (abe_24m_fclk, 24.576 MHz = 512 x 48 kHz) so the SRG can derive
 * integer bit-clock dividers -- board-steelhead.c did the same. */
&mcbsp2 {
	pinctrl-names = "default";
	pinctrl-0 = <&mcbsp2_pins>;
	/*
	 * McBSP2 functional clock tree (ABE clkctrl @ 0x30):
	 *   bit 26 = func_mcbsp2_gfclk sync mux  -> abe_24m_fclk (24.576 MHz)
	 *   bit 24 = func_mcbsp2_gfclk           -> bit 26 (its sync mux)
	 *
	 * The previous DTS tried to reparent bit 24 directly to abe_24m_fclk,
	 * but abe_24m_fclk is NOT a legal parent of bit 24 (its only parents are
	 * "abe-clkctrl:0030:26", "pad_clks_ck", "slimbus_clk" -- see
	 * drivers/clk/ti/clk-44xx.c omap4_func_mcbsp2_gfclk_parents[]). That
	 * produced the boot error:
	 *   clk: failed to reparent abe-clkctrl:0030:24 to abe_24m_fclk: -22
	 * The internal SRG already runs at 24.576 MHz via the bit-26 default;
	 * we now set the parents explicitly so the intent is unambiguous and the
	 * invalid -EINVAL reparent is gone.
	 *
	 * DPLL_ABE reference (CM_ABE_PLL_REF_CLKSEL): mainline clk-44xx.c
	 * reparents it to sys_32k for deep-idle PM -- states steelhead never
	 * enters (C1-only, see patch 0024). The stock x-loader and bootloader
	 * lock DPLL_ABE from sys_clkin (38.4 MHz, M=64/N=24 = exactly
	 * 98.304 MHz) and the stock kernel leaves it alone. With the mainline
	 * 32k reference the McBSP2 bit/frame clocks (DPLL_ABE, 32.768 kHz
	 * watch crystal) and the TAS5713 MCLK (DPLL_PER, 38.4 MHz system
	 * crystal) free-run against each other and beat at the crystals'
	 * relative ppm offset: the amp slips one sample per ~1 s -- a
	 * metronomic, load-independent playback click. Reparent the ABE DPLL
	 * back to sys_clkin (= stock topology, single reference crystal for
	 * the whole audio path) and relock at 98.304 MHz. assigned-clock
	 * parents are applied before rates, so the relock uses the new
	 * reference.
	 */
	assigned-clocks = <&abe_dpll_refclk_mux_ck>,
			  <&dpll_abe_ck>,
			  <&abe_clkctrl OMAP4_MCBSP2_CLKCTRL 26>,
			  <&abe_clkctrl OMAP4_MCBSP2_CLKCTRL 24>;
	assigned-clock-parents = <&sys_clkin_ck>,
				 <0>,
				 <&abe_24m_fclk>,
				 <&abe_clkctrl OMAP4_MCBSP2_CLKCTRL 26>;
	assigned-clock-rates = <0>, <98304000>, <0>, <0>;
	#sound-dai-cells = <0>;
	status = "okay";
};

/*
 * OMAP4 McASP -> optical S/PDIF (TOSLINK). The mcasp0 node itself
 * (ti,omap4-mcasp-audio: target-module @ 0x40128000 + L3 data port, op-mode=<1>
 * DIT/IEC958, serial-dir=<1> = serializer 0 = TX, dmas <&sdma 8>, ABE McASP
 * fck) already lives in omap4-l4-abe.dtsi, disabled. steelhead just enables it
 * and adds the AXR0 output pinmux. No ABE DSP firmware needed — davinci-mcasp
 * drives the McASP registers directly (stock parity: stock disabled the ABE L3
 * IRQ and did the same). Codec + card: spdif_dit + sound_spdif above.
 */
&mcasp0 {
	pinctrl-names = "default";
	pinctrl-0 = <&mcasp_spdif_pins>;
	#sound-dai-cells = <0>;
	status = "okay";
};

&twl_usb_comparator {
	usb-supply = <&vusb>;
};

/* HDMI output */
&dss {
	status = "okay";
	vdda_video-supply = <&vcxio>;	/* DSS DPLL analog rail = VCXIO 1.8 V (stock) */
};

&hdmi {
	status = "okay";
	vdda-supply = <&vdac>;

	port {
		hdmi_out: endpoint {
			remote-endpoint = <&tpd12s015_in>;
		};
	};
};

/*
 * MPU cpufreq: cpu-supply = the VC-bridge regulator (drives the TPS62361 via the
 * Voltage Controller, VP force-update). OPP table = OPP50/100/Turbo/Nitro
 * (350 / 700 / 920 / 1200 MHz); the cpu-supply scales VDD_MPU 1025..1380 mV with
 * the frequency (stock-measured nominals; voltdm_scale snaps to the opp4xxx
 * table). At OPP-Nitro the cpu-supply also engages Forward Body Bias via abb_mpu
 * (required for stable 1.2 GHz).
 */
&cpu0 {
	cpu-supply = <&vc_mpu_supply>;
	operating-points = <
		/* kHz     uV */
		350000  1025000
		700000  1203000
		920000  1317000
		1200000 1380000
	>;
};

/*
 * Let the abb_mpu (ti,abb-v2) regulator be set across its ti,abb_info range so the
 * VC-bridge cpu-supply can select Forward Body Bias (1375000) at OPP-Nitro and
 * bypass (1025000) below. The node itself comes from omap4460.dtsi; it has no
 * min/max constraints there, which would otherwise block regulator_set_voltage().
 */
&abb_mpu {
	regulator-min-microvolt = <1025000>;
	regulator-max-microvolt = <1389000>;
};

/* TWL6030 regulator overrides for steelhead */
&vmmc {
	regulator-min-microvolt = <3000000>;
	regulator-max-microvolt = <3000000>;
};

&vaux1 {
	regulator-min-microvolt = <3000000>;
	regulator-max-microvolt = <3000000>;
	regulator-always-on;
};

&vcxio {
	regulator-always-on;
};

&vdac {
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

&vana {
	regulator-always-on;
};

&v2v1 {
	regulator-always-on;
};

/*
 * Disable genuinely-unused OMAP4 interconnect target-modules that otherwise
 * print failed-probe noise during boot (see docs/2026-06-19-boot-warnings-followup.md).
 *
 * Hardware RNG (0x48091fe0 / rng_target): lives in the l4_secure clock domain.
 * On this U-Boot-booted GP-style flow the secure clkctrl fck is not exposed, so
 * ti-sysc fails with "clock get error for fck: -2" (-ENOENT). The Nexus Q does
 * not use the on-chip hwrng -> disable it to silence the probe failure.
 */
&rng_target {
	status = "disabled";
};

/*
 * HDQ / 1-wire (0x480b2000): battery/EEPROM 1-wire master. The Nexus Q has no
 * HDQ/1-wire device wired, the module is left unclocked, and ti-sysc reports
 * "OCP softreset timed out" when it tries to reset it. Disable it.
 * (Node has no label upstream, so reference it by full path.)
 */
&{/ocp/interconnect@48000000/segment@0/target-module@b2000} {
	status = "disabled";
};

/*
 * GPTIMER1 (timer1_target, 4a318000) is the always-on system clockevent
 * ("TI gptimer clockevent: always-on 32768 Hz ..."), owned by the timer core.
 * ti-sysc must keep its hands off it, and it MUST NOT be disabled here (that
 * would break timekeeping). Upstream ti-sysc signalled that hands-off with
 * -EBUSY, which the driver core logged as a boot error; patch 0019 turns it
 * into a silent -ENODEV ("rejects match"). The timer keeps its
 * ti,no-reset-on-init / ti,no-idle quirks from omap4.dtsi -- no DTS change.
 */

/*
 * B2: second core. The shared omap4.dtsi declares cpu@0 and cpu@1. cpu@1 is
 * kept (no longer deleted) now that the kernel is built SMP (CONFIG_SMP=y /
 * NR_CPUS=2) for OMAP4460 CPU1 bring-up. Without this node arm_dt_init_cpu_maps
 * caps the kernel to 1 core and CPU1 never gets a logical id. The OMAP4 machine
 * descriptor wires omap4_smp_ops, so no explicit cpu enable-method is needed
 * (HS secure-SMC release path; stock service IDs already match mainline).
 */

/*
 * PMU (dual Cortex-A9 performance monitors). The two per-CPU PMU SPIs (54,55)
 * map to cpu0/cpu1; declaring interrupt-affinity makes that explicit and
 * silences the arm_pmu "no interrupt-affinity property, guessing" boot warning.
 * cpu@1 has no label upstream, so reference it by path.
 */
&pmu {
	interrupt-affinity = <&cpu0>, <&{/cpus/cpu@1}>;
};

/*
 * GPMC (general-purpose memory controller): the Nexus Q has no GPMC memory
 * device (no NAND/NOR; every gpmc_* name in this DTS is a pad muxed to GPIO,
 * which does not need the controller). Left enabled, gpmc_mem_init finds the
 * ROM's stale CS0 mapping at 0x0 and logs "disabling cs 0 mapped at
 * 0x0-0x1000000". Nothing consumes &gpmc, so disable it.
 */
&gpmc {
	status = "disabled";
};
