From 0000000000000000000000000000000000000006 Mon Sep 17 00:00:00 2001
From: Petr Parkan Janda <petr.parkan.janda@oh-so.com>
Date: Sat, 20 Jun 2026 11:55:00 +0200
Subject: [PATCH] usb: ehci-omap: steelhead LAN9500A bring-up (vendor host init)

The Google Nexus Q has a soldered SMSC LAN9500A USB-Ethernet chip on EHCI port 1
behind an external SMSC USB3320 ULPI PHY (modelled as usb-nop-xceiv). It did not
enumerate on mainline. Reverse-engineering the vendor board kernel
(android-omap-steelhead-3.0: drivers/usb/host/ehci-omap.c #ifdef
CONFIG_MACH_STEELHEAD, and board-steelhead-usbhost.c) shows the host-init steps
mainline lacks. Verified on hardware: under the stock kernel the LAN9500A
enumerates (idVendor=0424 idProduct=9e00 -> eth0), so the chip is healthy and the
gap is purely these software steps.

Replicate the vendor host init (the order/placement matters):

 1) Power-on-reset the LAN9500A in board order -- with the 38.4 MHz PHY refclk
    (auxclk3) enabled: NENABLE(gpio_1) low, settle, NRESET(gpio_62) high. Owned
    via the steelhead DT (enable/reset gpios + clock on &usbhsehci); optional, so
    a no-op on other boards. Done in probe before usb_add_hcd(); gpio_62 resets
    BOTH the USB3320 PHY and the LAN9500A (verified: holding it -ETIMEDOUTs ULPI).
 2) Program the external USB3320 ULPI PHY into its working host state from the
    EHCI .reset hook (omap_ehci_reset: ehci_setup() then the ULPI burst), which
    runs from inside usb_add_hcd() AFTER the controller is reset/set up -- exactly
    where the vendor omap_ehci_soft_phy_reset (stock VA 0xC0331BDC) does it. This
    placement is the crux: the INSNREG05 ULPI viewport only accepts writes once
    ehci_setup() has run, so an earlier version that issued the burst BEFORE
    usb_add_hcd() silently dropped them (proven: a .reset-hook readback shows
    IFC=0x18, our written value, sticking). The vendor also does NOT stop at a
    single Function-Control soft reset: after a settle it writes five ULPI regs,
    EACH 20 times, to force them through the marginal external ULPI link:
        FUNC_CTRL_SET(0x05)=0x20 (RESET), FUNC_CTRL(0x04)=0x41, IFC_CTRL(0x07)=0x18,
        OTG_CTRL(0x0a)=0x66 (host Dp/Dm pull-downs), FUNC_CTRL(0x04)=0x45 -- each x20.
    Also set INSNREG01 OUT/IN burst thresholds = 0x80 here (vendor steelhead-only).

NOTE (2026-06-24): the LAN9500A still does not enumerate with all of the above,
even though the ULPI state is now byte-identical to stock (FUNC=0x45/IFC=0x18/
OTG=0x66) and stock enumerates the same chip on this unit today (proven via
stock-adb: port:1 CCS=1). So the remaining gap is NOT the PHY registers but a
host/USBHS-level difference -- still open. This patch keeps the correct,
stock-faithful structure (`.reset`-hook placement + full ULPI programming) as the
base to build on; see docs/2026-06-24-ethernet-stock-proven-its-our-sw.md.

Also log the ULPI identity once and pin the root hub runtime-active (userspace
udev re-enables autosuspend via hwdb, which would halt the controller, gate the
EHCI fclk and drop port power before the slow-to-connect LAN9500A is seen).

Signed-off-by: Petr Parkan Janda <petr.parkan.janda@oh-so.com>
---
--- a/drivers/usb/host/ehci-omap.c
+++ b/drivers/usb/host/ehci-omap.c
@@ -23,18 +23,24 @@
 #include <linux/platform_device.h>
 #include <linux/slab.h>
 #include <linux/usb/ulpi.h>
+#include <linux/ulpi/regs.h>
 #include <linux/pm_runtime.h>
 #include <linux/clk.h>
+#include <linux/gpio/consumer.h>
 #include <linux/usb.h>
 #include <linux/usb/hcd.h>
 #include <linux/of.h>
 #include <linux/dma-mapping.h>
+#include <linux/delay.h>
 
 #include "ehci.h"
 
 #include <linux/platform_data/usb-omap.h>
 
 /* EHCI Register Set */
+#define	EHCI_INSNREG01					(0x94)
+#define	EHCI_INSNREG01_OUT_THRESHOLD_SHIFT		16
+#define	EHCI_INSNREG01_IN_THRESHOLD_SHIFT		0
 #define EHCI_INSNREG04					(0xA0)
 #define EHCI_INSNREG04_DISABLE_UNSUSPEND		(1 << 5)
 #define	EHCI_INSNREG05_ULPI				(0xA4)
@@ -61,6 +67,230 @@
 	__raw_writel(val, base + reg);
 }
 
+static inline u32 ehci_read(void __iomem *base, u32 reg)
+{
+	return __raw_readl(base + reg);
+}
+
+/*
+ * Read one 8-bit ULPI PHY register through the OMAP EHCI INSNREG05 viewport.
+ * 'port' is the 1-based ULPI port select (port 1 == first EHCI port). Returns
+ * the register byte (0..0xff), or -ETIMEDOUT if the viewport never goes idle
+ * (which means the external ULPI PHY is unclocked or held in reset).
+ */
+static int omap_ehci_ulpi_read(void __iomem *regs, int port, u8 ulpi_reg)
+{
+	u32 val;
+	int timeout = 1000;
+
+	val = (1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT) |
+	      (port << EHCI_INSNREG05_ULPI_PORTSEL_SHIFT) |
+	      (3 << EHCI_INSNREG05_ULPI_OPSEL_SHIFT) |	/* 3 = read */
+	      ((u32)ulpi_reg << EHCI_INSNREG05_ULPI_REGADD_SHIFT);
+	ehci_write(regs, EHCI_INSNREG05_ULPI, val);
+
+	while ((ehci_read(regs, EHCI_INSNREG05_ULPI) &
+		(1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT)) && --timeout)
+		udelay(1);
+
+	if (!timeout)
+		return -ETIMEDOUT;
+
+	return ehci_read(regs, EHCI_INSNREG05_ULPI) & 0xff;
+}
+
+/*
+ * Write one 8-bit value to a ULPI PHY register through the OMAP EHCI INSNREG05
+ * viewport (OPSEL = 2 = write). Mirrors omap_ehci_ulpi_write() from the vendor
+ * driver; used to program the external USB3320 into its working host state.
+ */
+static void omap_ehci_ulpi_write(void __iomem *regs, int port, u8 ulpi_reg,
+				 u8 val)
+{
+	unsigned long timeout = jiffies + msecs_to_jiffies(1000);
+	u32 reg;
+
+	reg = (u32)val
+		| ((u32)ulpi_reg << EHCI_INSNREG05_ULPI_REGADD_SHIFT)
+		| (2 << EHCI_INSNREG05_ULPI_OPSEL_SHIFT)	/* 2 = write */
+		| (port << EHCI_INSNREG05_ULPI_PORTSEL_SHIFT)
+		| (1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT);
+
+	ehci_write(regs, EHCI_INSNREG05_ULPI, reg);
+
+	/* Wait for ULPI access completion */
+	while ((ehci_read(regs, EHCI_INSNREG05_ULPI)
+			& (1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT))) {
+		cpu_relax();
+
+		if (time_after(jiffies, timeout)) {
+			pr_err("%s: ulpi write timeout (reg %#x)\n",
+			       __func__, ulpi_reg);
+			break;
+		}
+	}
+}
+
+/*
+ * Bring the external SMSC USB3320 ULPI PHY (port 1 -- the Nexus Q's soldered
+ * LAN9500A USB-ethernet path) into its working host state, mirroring the vendor
+ * omap_ehci_soft_phy_reset (stock VA 0xC0331BDC). The stock routine does NOT
+ * stop at a single Function-Control soft reset: after a settle it programs five
+ * ULPI registers and writes EACH one 20 times, to force the value through the
+ * marginal external ULPI link. Doing only the one-shot RESET (as this driver did
+ * before) relied on the PHY's reset defaults happening to land at FUNC=0x45 /
+ * OTG=0x66 -- which is exactly why enumeration was intermittent: on a bad boot
+ * OTG_CTRL was left without the host-side Dp/Dm pull-downs (0x66) and IFC_CTRL
+ * was not forced (0x18), so the PHY answered register reads (ULPI VID 0x0424 --
+ * alive) but the controller never saw the LAN9500A pull up D+ and the port sat
+ * at SE0 / PORTSC CCS=0. A warm gpio_1 rail power-cycle cannot fix it because
+ * the PHY *registers*, not the rail, are wrong. Replicate the full sequence.
+ */
+static void omap_ehci_soft_phy_reset(void __iomem *regs, int port)
+{
+	int i;
+
+	/*
+	 * Stock does a controller reset then udelay(2000) before the ULPI
+	 * register burst (VA 0xc0331f10) -- let the just-released USB3320 /
+	 * LAN9500A link state machine settle before programming it.
+	 */
+	udelay(2000);
+
+	/* FUNCTION_CTRL_SET = RESET (0x20): soft-reset the transceiver */
+	for (i = 0; i < 20; i++)
+		omap_ehci_ulpi_write(regs, port, ULPI_SET(ULPI_FUNC_CTRL),
+				     ULPI_FUNC_CTRL_RESET);
+	/* FUNC_CTRL = 0x41 */
+	for (i = 0; i < 20; i++)
+		omap_ehci_ulpi_write(regs, port, ULPI_FUNC_CTRL, 0x41);
+	/* IFC_CTRL = 0x18 */
+	for (i = 0; i < 20; i++)
+		omap_ehci_ulpi_write(regs, port, ULPI_IFC_CTRL, 0x18);
+	/* OTG_CTRL = 0x66 (host Dp/Dm pull-downs + IdPullup -- lets the EHCI
+	 * see the downstream LAN9500A assert connect) */
+	for (i = 0; i < 20; i++)
+		omap_ehci_ulpi_write(regs, port, ULPI_OTG_CTRL, 0x66);
+	/* FUNC_CTRL = 0x45 (XcvrSelect HS + OpMode) */
+	for (i = 0; i < 20; i++)
+		omap_ehci_ulpi_write(regs, port, ULPI_FUNC_CTRL, 0x45);
+}
+
+/*
+ * EHCI .reset override. The vendor steelhead kernel programs the external
+ * USB3320 ULPI PHY from inside its EHCI .reset hook (stock VA 0xC0331BDC),
+ * AFTER the standard controller reset -- NOT once before usb_add_hcd(). That
+ * ordering is essential: the INSNREG05 ULPI viewport only accepts writes once
+ * the controller has been set up by ehci_setup(), so issuing the ULPI burst
+ * before usb_add_hcd() (as an earlier version of this driver did) silently
+ * dropped the writes -- the PHY kept its reset defaults and the LAN9500A's
+ * connect was missed on the "bad" boots. Run ehci_setup() first, then set the
+ * steelhead INSNREG01 burst thresholds and the full ULPI PHY programming on the
+ * just-reset, running controller. This hook re-runs on every controller reset,
+ * exactly as stock does.
+ */
+/* OMAP4 USBHS UHH module: base = EHCI base (0x4A064C00) - 0xC00 = 0x4A064000 */
+#define OMAP_UHH_OFFSET_FROM_EHCI	0xC00
+#define OMAP_UHH_SYSCONFIG		0x10
+#define OMAP_UHH_SYSCONFIG_SOFTRESET	(1 << 0)
+#define OMAP_UHH_HOSTCONFIG_REG		0x40
+#define OMAP_UHH_HOSTCONFIG_P1_CONNECT	(1 << 8)
+
+/*
+ * Steelhead gpio_159 (gpio5 bit31): a third reset line stock pulses inside
+ * soft_phy_reset. Captured by ehci_hcd_omap_probe, pulsed by omap_ehci_reset.
+ * Single-instance steelhead-only, so a file static is fine.
+ */
+static struct gpio_desc *steelhead_eth_phy_reset;
+
+static int omap_ehci_reset(struct usb_hcd *hcd)
+{
+	struct omap_hcd *omap = (struct omap_hcd *)hcd_to_ehci(hcd)->priv;
+	void __iomem *regs = hcd->regs;
+	void __iomem *uhh;
+	int ret, i;
+
+	/*
+	 * Stock host-level half of omap_ehci_soft_phy_reset (stock VA 0xc0331cc8):
+	 * pulse the UHH module SOFTRESET to re-arm the USBHS host port state
+	 * machine, saving/restoring UHH_HOSTCONFIG across it (the softreset clears
+	 * it). Our port omitted this entirely and only re-programmed the ULPI PHY;
+	 * stock proved on this unit that with the PHY configured AND this UHH
+	 * re-arm the EHCI latches the port-1 connect (CCS=1). Done BEFORE
+	 * ehci_setup() so the controller is then configured on a freshly re-armed
+	 * USBHS. UHH base = EHCI base - 0xC00 (0x4A064000 on OMAP4).
+	 */
+	uhh = ioremap(hcd->rsrc_start - OMAP_UHH_OFFSET_FROM_EHCI, 0x100);
+	if (uhh) {
+		u32 saved = readl(uhh + OMAP_UHH_HOSTCONFIG_REG);
+		int t = 1000;
+
+		writel(OMAP_UHH_SYSCONFIG_SOFTRESET, uhh + OMAP_UHH_SYSCONFIG);
+		while ((readl(uhh + OMAP_UHH_SYSCONFIG) &
+			OMAP_UHH_SYSCONFIG_SOFTRESET) && --t)
+			udelay(1);
+		/*
+		 * Restore HOSTCONFIG (the softreset clears it). The live value is 0x1c
+		 * (INCR bursts only) -- which MATCHES stock; forcing P1_CONNECT_STATUS
+		 * (bit8) to 0x11c was tested and made no difference, so we leave it at
+		 * the stock 0x1c.
+		 */
+		writel(saved, uhh + OMAP_UHH_HOSTCONFIG_REG);
+		iounmap(uhh);
+		pr_info("steelhead: UHH softreset (HOSTCONFIG=%#x restored, %s)\n",
+			saved, t ? "clear" : "TIMEOUT");
+	}
+
+	/*
+	 * Stock pulses a THIRD reset line here (gpio_159 = gpio5 bit31) in
+	 * soft_phy_reset, after the UHH softreset and before the ULPI burst:
+	 * gpio_direction_output(159,0) -> udelay(2000) -> (159,1) -> udelay(2000)
+	 * (stock VA 0xc0331d3c). It is an active-low reset pulse on the otherwise
+	 * unused usbb2_ulpitll_dir pad (CONTROL_PADCONF 0x164, MUX_MODE3); its board
+	 * net is unproven from vmlinux but it is a hard reset to the LAN9500A or the
+	 * USB3320 that mainline never drove. Replicate the pulse (GPIO_ACTIVE_LOW in
+	 * DT, so assert = logical 1 = physical low, release = logical 0 = high).
+	 */
+	if (steelhead_eth_phy_reset) {
+		gpiod_set_value_cansleep(steelhead_eth_phy_reset, 1);	/* assert (low) */
+		udelay(2000);
+		gpiod_set_value_cansleep(steelhead_eth_phy_reset, 0);	/* release (high) */
+		udelay(2000);
+		pr_info("steelhead: gpio_159 reset pulse (low->2ms->high)\n");
+	}
+
+	ret = ehci_setup(hcd);
+	if (ret)
+		return ret;
+
+	/* INSNREG01 OUT/IN burst thresholds = 0x80 (vendor steelhead-only) */
+	ehci_write(regs, EHCI_INSNREG01,
+		   (0x80 << EHCI_INSNREG01_OUT_THRESHOLD_SHIFT) |
+		   (0x80 << EHCI_INSNREG01_IN_THRESHOLD_SHIFT));
+
+	/* program the external USB3320 ULPI PHY on each PHY-mode port */
+	for (i = 0; i < omap->nports; i++)
+		if (omap->phy[i]) {
+			omap_ehci_soft_phy_reset(regs, i + 1);
+			/*
+			 * DIAG (temporary): confirm this hook actually ran on the
+			 * set-up controller AND that the ULPI writes stuck -- read
+			 * the registers back. Expect FUNC=0x45 IFC=0x18 OTG=0x66 if
+			 * the writes took; an IFC != 0x18 means the viewport still
+			 * dropped them. Remove once root-caused.
+			 */
+			pr_info("steelhead: omap_ehci_reset port%d readback FUNC=%#x IFC=%#x OTG=%#x VID=%#x:%#x\n",
+				i + 1,
+				omap_ehci_ulpi_read(regs, i + 1, ULPI_FUNC_CTRL),
+				omap_ehci_ulpi_read(regs, i + 1, ULPI_IFC_CTRL),
+				omap_ehci_ulpi_read(regs, i + 1, ULPI_OTG_CTRL),
+				omap_ehci_ulpi_read(regs, i + 1, ULPI_VENDOR_ID_HIGH),
+				omap_ehci_ulpi_read(regs, i + 1, ULPI_VENDOR_ID_LOW));
+		}
+
+	return 0;
+}
+
 /* configure so an HC device and id are always provided */
 /* always called with process context; sleeping is OK */
 
@@ -68,6 +298,7 @@
 
 static const struct ehci_driver_overrides ehci_omap_overrides __initconst = {
 	.extra_priv_size = sizeof(struct omap_hcd),
+	.reset = omap_ehci_reset,
 };
 
 /**
@@ -144,6 +375,61 @@
 
 	platform_set_drvdata(pdev, hcd);
 
+	/*
+	 * Nexus Q (steelhead): stage the SMSC LAN9500A USB-Ethernet power-on
+	 * reset in the vendor board order BEFORE the PHY is initialised and the
+	 * controller is started. The chip hangs off port 1 behind the USB3320
+	 * ULPI PHY; the two share the 38.4 MHz reference clock (auxclk3) and the
+	 * reset line (gpio_62 NRESET), with the rail enabled by gpio_1 NENABLE.
+	 * The vendor board file (steelhead_usbhost_init), with the PHY refclk
+	 * already running, does:
+	 *	clk_enable(auxclk3) -> udelay(100) -> NENABLE low (power on)
+	 *	-> udelay(2) -> NRESET high (release reset)
+	 * Mainline otherwise lets nop-xceiv / regulator probe order release
+	 * NRESET before the refclk is stable. The resources are optional and only
+	 * present in the steelhead DT, so this is a no-op on other boards.
+	 *
+	 * The gpios are declared GPIO_ACTIVE_LOW in DT, so a logical 1 is the
+	 * asserted state (NENABLE on / NRESET held) and logical 0 is deasserted.
+	 */
+	{
+		struct gpio_desc *eth_en, *eth_reset;
+		struct clk *eth_phyclk;
+
+		/* NENABLE deasserted (off), NRESET asserted (held in reset) */
+		eth_en = devm_gpiod_get_optional(dev,
+				"steelhead-ethernet-enable", GPIOD_OUT_LOW);
+		eth_reset = devm_gpiod_get_optional(dev,
+				"steelhead-ethernet-reset", GPIOD_OUT_HIGH);
+		if (IS_ERR(eth_en))
+			eth_en = NULL;
+		if (IS_ERR(eth_reset))
+			eth_reset = NULL;
+
+		/* gpio_159: 3rd reset line pulsed later in omap_ehci_reset (stock).
+		 * Keep the con_id short -- "<id>-gpios" must fit gpiolib's 32-char
+		 * property-name buffer (the longer "...-phy-reset" got truncated). */
+		steelhead_eth_phy_reset = devm_gpiod_get_optional(dev,
+				"steelhead-eth-phy-reset", GPIOD_OUT_LOW);
+		if (IS_ERR(steelhead_eth_phy_reset))
+			steelhead_eth_phy_reset = NULL;
+
+		if (eth_en && eth_reset) {
+			eth_phyclk = devm_clk_get_optional(dev,
+					"steelhead-ethernet-phy");
+			if (!IS_ERR_OR_NULL(eth_phyclk)) {
+				clk_set_rate(eth_phyclk, 38400000);
+				clk_prepare_enable(eth_phyclk);
+			}
+			udelay(100);				/* refclk settle */
+			gpiod_set_value_cansleep(eth_en, 1);	/* power/enable on */
+			udelay(2);				/* power-good settle */
+			gpiod_set_value_cansleep(eth_reset, 0);	/* release reset */
+			dev_info(dev,
+				 "steelhead: LAN9500A power-on-reset sequenced (clk->enable->reset)\n");
+		}
+	}
+
 	/* get the PHY devices if needed */
 	for (i = 0 ; i < omap->nports ; i++) {
 		struct usb_phy *phy;
@@ -187,6 +473,16 @@
 	ehci_write(regs, EHCI_INSNREG04,
 				EHCI_INSNREG04_DISABLE_UNSUSPEND);
 
+	/*
+	 * Nexus Q (steelhead) EHCI host init -- the INSNREG01 burst thresholds and
+	 * the full USB3320 ULPI PHY programming are done in omap_ehci_reset() (the
+	 * EHCI .reset hook), which runs from inside usb_add_hcd() *after*
+	 * ehci_setup() has reset and set up the controller. That is where the
+	 * vendor does it, and it is the only point at which the INSNREG05 ULPI
+	 * viewport actually accepts the writes. The board-level LAN9500A
+	 * power-on-reset gpio sequence above has already run here, before
+	 * usb_add_hcd(), so the chip is powered and out of reset by then.
+	 */
 	ret = usb_add_hcd(hcd, irq, IRQF_SHARED);
 	if (ret) {
 		dev_err(dev, "failed to add hcd with err %d\n", ret);
@@ -195,6 +491,83 @@
 	device_wakeup_enable(hcd->self.controller);
 
 	/*
+	 * Nexus Q (steelhead): log the ULPI identity and state once now that the
+	 * controller is running (a healthy USB3320 answers VID 0x0424/PID 0x0007;
+	 * -ETIMEDOUT means the PHY is unclocked or held in reset), then keep the
+	 * root hub awake so the slow-to-connect soldered LAN9500A always gets a
+	 * powered, running port. The PHY soft reset itself is done earlier, before
+	 * usb_add_hcd() (see above).
+	 */
+	for (i = 0; i < omap->nports; i++) {
+		struct ehci_hcd *ehci = hcd_to_ehci(hcd);
+		int port = i + 1;	/* ULPI viewport PORTSEL is 1-based */
+		int vidl, vidh, pidl, pidh, func, otg, dbg;
+
+		if (pdata->port_mode[i] != OMAP_EHCI_PORT_MODE_PHY)
+			continue;
+
+		vidl = omap_ehci_ulpi_read(regs, port, ULPI_VENDOR_ID_LOW);
+		vidh = omap_ehci_ulpi_read(regs, port, ULPI_VENDOR_ID_HIGH);
+		pidl = omap_ehci_ulpi_read(regs, port, ULPI_PRODUCT_ID_LOW);
+		pidh = omap_ehci_ulpi_read(regs, port, ULPI_PRODUCT_ID_HIGH);
+		func = omap_ehci_ulpi_read(regs, port, ULPI_FUNC_CTRL);
+		otg  = omap_ehci_ulpi_read(regs, port, ULPI_OTG_CTRL);
+		dbg  = omap_ehci_ulpi_read(regs, port, ULPI_DEBUG);
+
+		dev_info(dev,
+			 "steelhead: port%d ULPI VID=%#x:%#x PID=%#x:%#x FUNC=%#x OTG=%#x DBG=%#x PORTSC=%08x\n",
+			 port, vidh, vidl, pidh, pidl, func, otg, dbg,
+			 ehci_readl(ehci, &ehci->regs->port_status[i]));
+	}
+
+	/*
+	 * Steelhead diag (temporary): sample the ULPI LineState (DEBUG reg, bits
+	 * 1:0; 00=SE0) and PORTSC over ~1s now that the controller is running, to
+	 * see whether the LAN9500A ever pulls up D+ (LineState leaves SE0 / PORTSC
+	 * CCS bit0 asserts) at all. Kernel-side ULPI-viewport reads only -- safe,
+	 * unlike userspace devmem on the gated module. Remove once root-caused.
+	 */
+	for (i = 0; i < omap->nports; i++) {
+		struct ehci_hcd *ehci = hcd_to_ehci(hcd);
+		int port = i + 1;
+		int j;
+
+		if (pdata->port_mode[i] != OMAP_EHCI_PORT_MODE_PHY)
+			continue;
+
+		for (j = 0; j < 10; j++) {
+			int dbg = omap_ehci_ulpi_read(regs, port, ULPI_DEBUG);
+			u32 portsc = ehci_readl(ehci,
+						&ehci->regs->port_status[i]);
+
+			dev_info(dev,
+				 "steelhead: diag t+%dms port%d ULPI DBG=%#x PORTSC=%08x\n",
+				 j * 100, port, dbg, portsc);
+			msleep(100);
+		}
+	}
+
+	if (hcd->self.root_hub) {
+		/*
+		 * Pin the root hub runtime-active. usb_disable_autosuspend()
+		 * (pm_runtime_forbid) alone is not enough: userspace udev
+		 * (60-autosuspend.rules, hwdb ID_AUTOSUSPEND) sets power/control
+		 * back to "auto" after boot, so the root hub autosuspends,
+		 * ehci_bus_suspend() halts the controller and the OMAP gates the
+		 * EHCI functional clock -> port power (VBUS) drops and the
