From 0000000000000000000000000000000000000006 Mon Sep 17 00:00:00 2001
From: Petr Parkan Janda <petr.parkan.janda@oh-so.com>
Date: Sat, 20 Jun 2026 11:55:00 +0200
Subject: [PATCH] usb: ehci-omap: steelhead LAN9500A bring-up (vendor host init)

The Google Nexus Q has a soldered SMSC LAN9500A USB-Ethernet chip on EHCI port 1
behind an external SMSC USB3320 ULPI PHY (modelled as usb-nop-xceiv). It did not
enumerate on mainline. Reverse-engineering the vendor board kernel
(android-omap-steelhead-3.0: drivers/usb/host/ehci-omap.c #ifdef
CONFIG_MACH_STEELHEAD, and board-steelhead-usbhost.c) shows the host-init steps
mainline lacks. Verified on hardware: under the stock kernel the LAN9500A
enumerates (idVendor=0424 idProduct=9e00 -> eth0), so the chip is healthy and the
gap is purely these software steps.

Replicate the vendor host init, all BEFORE usb_add_hcd() (the order matters):

 1) Power-on-reset the LAN9500A in board order -- with the 38.4 MHz PHY refclk
    (auxclk3) enabled: NENABLE(gpio_1) low, settle, NRESET(gpio_62) high. Owned
    via the steelhead DT (enable/reset gpios + clock on &usbhsehci); optional, so
    a no-op on other boards.
 2) Set INSNREG01 OUT/IN burst thresholds to 0x80 (vendor steelhead-only); the
    reset default does not work for this ULPI-PHY data path.
 3) Issue the ULPI Function-Control soft reset of the external transceiver
    BEFORE usb_add_hcd(). Without it the USB3320 answers register reads but never
    drives the downstream bus; doing it after the controller starts (an earlier
    version of this patch) does not bring the device up -- the vendor does it
    here, before the port is started.

Also log the ULPI identity once and pin the root hub runtime-active (userspace
udev re-enables autosuspend via hwdb, which would halt the controller, gate the
EHCI fclk and drop port power before the slow-to-connect LAN9500A is seen).

Signed-off-by: Petr Parkan Janda <petr.parkan.janda@oh-so.com>
---
--- a/drivers/usb/host/ehci-omap.c
+++ b/drivers/usb/host/ehci-omap.c
@@ -23,18 +23,24 @@
 #include <linux/platform_device.h>
 #include <linux/slab.h>
 #include <linux/usb/ulpi.h>
+#include <linux/ulpi/regs.h>
 #include <linux/pm_runtime.h>
 #include <linux/clk.h>
+#include <linux/gpio/consumer.h>
 #include <linux/usb.h>
 #include <linux/usb/hcd.h>
 #include <linux/of.h>
 #include <linux/dma-mapping.h>
+#include <linux/delay.h>
 
 #include "ehci.h"
 
 #include <linux/platform_data/usb-omap.h>
 
 /* EHCI Register Set */
+#define	EHCI_INSNREG01					(0x94)
+#define	EHCI_INSNREG01_OUT_THRESHOLD_SHIFT		16
+#define	EHCI_INSNREG01_IN_THRESHOLD_SHIFT		0
 #define EHCI_INSNREG04					(0xA0)
 #define EHCI_INSNREG04_DISABLE_UNSUSPEND		(1 << 5)
 #define	EHCI_INSNREG05_ULPI				(0xA4)
@@ -61,6 +67,76 @@
 	__raw_writel(val, base + reg);
 }
 
+static inline u32 ehci_read(void __iomem *base, u32 reg)
+{
+	return __raw_readl(base + reg);
+}
+
+/*
+ * Read one 8-bit ULPI PHY register through the OMAP EHCI INSNREG05 viewport.
+ * 'port' is the 1-based ULPI port select (port 1 == first EHCI port). Returns
+ * the register byte (0..0xff), or -ETIMEDOUT if the viewport never goes idle
+ * (which means the external ULPI PHY is unclocked or held in reset).
+ */
+static int omap_ehci_ulpi_read(void __iomem *regs, int port, u8 ulpi_reg)
+{
+	u32 val;
+	int timeout = 1000;
+
+	val = (1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT) |
+	      (port << EHCI_INSNREG05_ULPI_PORTSEL_SHIFT) |
+	      (3 << EHCI_INSNREG05_ULPI_OPSEL_SHIFT) |	/* 3 = read */
+	      ((u32)ulpi_reg << EHCI_INSNREG05_ULPI_REGADD_SHIFT);
+	ehci_write(regs, EHCI_INSNREG05_ULPI, val);
+
+	while ((ehci_read(regs, EHCI_INSNREG05_ULPI) &
+		(1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT)) && --timeout)
+		udelay(1);
+
+	if (!timeout)
+		return -ETIMEDOUT;
+
+	return ehci_read(regs, EHCI_INSNREG05_ULPI) & 0xff;
+}
+
+/*
+ * Issue a ULPI Function-Control soft reset to the external PHY on 'port'
+ * (1-based) through the INSNREG05 viewport. The mainline ehci-omap dropped
+ * this when PHY handling moved to the generic framework, but an external ULPI
+ * PHY modelled only as usb-nop-xceiv (e.g. the SMSC USB3320 on the Nexus Q)
+ * still needs the controller to soft-reset its transceiver once the link is
+ * up, otherwise a soldered-down downstream device never appears on the bus.
+ * Mirrors omap_ehci_soft_phy_reset() from the vendor/older OMAP EHCI driver.
+ */
+static void omap_ehci_soft_phy_reset(void __iomem *regs, int port)
+{
+	unsigned long timeout = jiffies + msecs_to_jiffies(1000);
+	u32 reg;
+
+	reg = ULPI_FUNC_CTRL_RESET
+		/* FUNCTION_CTRL_SET register */
+		| (ULPI_SET(ULPI_FUNC_CTRL) << EHCI_INSNREG05_ULPI_REGADD_SHIFT)
+		/* Write */
+		| (2 << EHCI_INSNREG05_ULPI_OPSEL_SHIFT)
+		/* PORTn */
+		| (port << EHCI_INSNREG05_ULPI_PORTSEL_SHIFT)
+		/* start ULPI access */
+		| (1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT);
+
+	ehci_write(regs, EHCI_INSNREG05_ULPI, reg);
+
+	/* Wait for ULPI access completion */
+	while ((ehci_read(regs, EHCI_INSNREG05_ULPI)
+			& (1 << EHCI_INSNREG05_ULPI_CONTROL_SHIFT))) {
+		cpu_relax();
+
+		if (time_after(jiffies, timeout)) {
+			pr_err("%s: ulpi write timeout\n", __func__);
+			break;
+		}
+	}
+}
+
 /* configure so an HC device and id are always provided */
 /* always called with process context; sleeping is OK */
 
@@ -144,6 +220,53 @@
 
 	platform_set_drvdata(pdev, hcd);
 
+	/*
+	 * Nexus Q (steelhead): stage the SMSC LAN9500A USB-Ethernet power-on
+	 * reset in the vendor board order BEFORE the PHY is initialised and the
+	 * controller is started. The chip hangs off port 1 behind the USB3320
+	 * ULPI PHY; the two share the 38.4 MHz reference clock (auxclk3) and the
+	 * reset line (gpio_62 NRESET), with the rail enabled by gpio_1 NENABLE.
+	 * The vendor board file (steelhead_usbhost_init), with the PHY refclk
+	 * already running, does:
+	 *	clk_enable(auxclk3) -> udelay(100) -> NENABLE low (power on)
+	 *	-> udelay(2) -> NRESET high (release reset)
+	 * Mainline otherwise lets nop-xceiv / regulator probe order release
+	 * NRESET before the refclk is stable. The resources are optional and only
+	 * present in the steelhead DT, so this is a no-op on other boards.
+	 *
+	 * The gpios are declared GPIO_ACTIVE_LOW in DT, so a logical 1 is the
+	 * asserted state (NENABLE on / NRESET held) and logical 0 is deasserted.
+	 */
+	{
+		struct gpio_desc *eth_en, *eth_reset;
+		struct clk *eth_phyclk;
+
+		/* NENABLE deasserted (off), NRESET asserted (held in reset) */
+		eth_en = devm_gpiod_get_optional(dev,
+				"steelhead-ethernet-enable", GPIOD_OUT_LOW);
+		eth_reset = devm_gpiod_get_optional(dev,
+				"steelhead-ethernet-reset", GPIOD_OUT_HIGH);
+		if (IS_ERR(eth_en))
+			eth_en = NULL;
+		if (IS_ERR(eth_reset))
+			eth_reset = NULL;
+
+		if (eth_en && eth_reset) {
+			eth_phyclk = devm_clk_get_optional(dev,
+					"steelhead-ethernet-phy");
+			if (!IS_ERR_OR_NULL(eth_phyclk)) {
+				clk_set_rate(eth_phyclk, 38400000);
+				clk_prepare_enable(eth_phyclk);
+			}
+			udelay(100);				/* refclk settle */
+			gpiod_set_value_cansleep(eth_en, 1);	/* power/enable on */
+			udelay(2);				/* power-good settle */
+			gpiod_set_value_cansleep(eth_reset, 0);	/* release reset */
+			dev_info(dev,
+				 "steelhead: LAN9500A power-on-reset sequenced (clk->enable->reset)\n");
+		}
+	}
+
 	/* get the PHY devices if needed */
 	for (i = 0 ; i < omap->nports ; i++) {
 		struct usb_phy *phy;
@@ -187,6 +310,35 @@
 	ehci_write(regs, EHCI_INSNREG04,
 				EHCI_INSNREG04_DISABLE_UNSUSPEND);
 
+	/*
+	 * Nexus Q (steelhead) EHCI host init, BEFORE usb_add_hcd() -- exactly
+	 * the order the vendor board kernel used (drivers/usb/host/ehci-omap.c,
+	 * android-omap-steelhead-3.0). Two steelhead-specific steps the mainline
+	 * driver lacks are required for the soldered SMSC LAN9500A behind the
+	 * external SMSC USB3320 ULPI PHY to enumerate:
+	 *
+	 *  1) INSNREG01 OUT/IN burst thresholds = 0x80 (vendor #ifdef
+	 *     CONFIG_MACH_STEELHEAD). The reset default does not work for this
+	 *     ULPI-PHY data path.
+	 *  2) The ULPI Function-Control soft reset of the external transceiver,
+	 *     issued *before* the controller is started -- the USB3320 otherwise
+	 *     answers register reads but never drives the downstream bus, so the
+	 *     LAN9500A never signals connect. Doing it after usb_add_hcd() (as an
+	 *     earlier version of this patch did) resets the PHY after the EHCI
+	 *     core has already configured/started the port, which does not bring
+	 *     the device up; the vendor does it here, before usb_add_hcd().
+	 */
+	ehci_write(regs, EHCI_INSNREG01,
+		   (0x80 << EHCI_INSNREG01_OUT_THRESHOLD_SHIFT) |
+		   (0x80 << EHCI_INSNREG01_IN_THRESHOLD_SHIFT));
+
+	for (i = 0; i < omap->nports; i++) {
+		int port = i + 1;	/* ULPI viewport PORTSEL is 1-based */
+
+		if (pdata->port_mode[i] == OMAP_EHCI_PORT_MODE_PHY)
+			omap_ehci_soft_phy_reset(regs, port);
+	}
+
 	ret = usb_add_hcd(hcd, irq, IRQF_SHARED);
 	if (ret) {
 		dev_err(dev, "failed to add hcd with err %d\n", ret);
@@ -195,6 +347,83 @@
 	device_wakeup_enable(hcd->self.controller);
 
 	/*
+	 * Nexus Q (steelhead): log the ULPI identity and state once now that the
+	 * controller is running (a healthy USB3320 answers VID 0x0424/PID 0x0007;
+	 * -ETIMEDOUT means the PHY is unclocked or held in reset), then keep the
+	 * root hub awake so the slow-to-connect soldered LAN9500A always gets a
+	 * powered, running port. The PHY soft reset itself is done earlier, before
+	 * usb_add_hcd() (see above).
+	 */
+	for (i = 0; i < omap->nports; i++) {
+		struct ehci_hcd *ehci = hcd_to_ehci(hcd);
+		int port = i + 1;	/* ULPI viewport PORTSEL is 1-based */
+		int vidl, vidh, pidl, pidh, func, otg, dbg;
+
+		if (pdata->port_mode[i] != OMAP_EHCI_PORT_MODE_PHY)
+			continue;
+
+		vidl = omap_ehci_ulpi_read(regs, port, ULPI_VENDOR_ID_LOW);
+		vidh = omap_ehci_ulpi_read(regs, port, ULPI_VENDOR_ID_HIGH);
+		pidl = omap_ehci_ulpi_read(regs, port, ULPI_PRODUCT_ID_LOW);
+		pidh = omap_ehci_ulpi_read(regs, port, ULPI_PRODUCT_ID_HIGH);
+		func = omap_ehci_ulpi_read(regs, port, ULPI_FUNC_CTRL);
+		otg  = omap_ehci_ulpi_read(regs, port, ULPI_OTG_CTRL);
+		dbg  = omap_ehci_ulpi_read(regs, port, ULPI_DEBUG);
+
+		dev_info(dev,
+			 "steelhead: port%d ULPI VID=%#x:%#x PID=%#x:%#x FUNC=%#x OTG=%#x DBG=%#x PORTSC=%08x\n",
+			 port, vidh, vidl, pidh, pidl, func, otg, dbg,
+			 ehci_readl(ehci, &ehci->regs->port_status[i]));
+	}
+
+	/*
+	 * Steelhead diag (temporary): sample the ULPI LineState (DEBUG reg, bits
+	 * 1:0; 00=SE0) and PORTSC over ~1s now that the controller is running, to
+	 * see whether the LAN9500A ever pulls up D+ (LineState leaves SE0 / PORTSC
+	 * CCS bit0 asserts) at all. Kernel-side ULPI-viewport reads only -- safe,
+	 * unlike userspace devmem on the gated module. Remove once root-caused.
+	 */
+	for (i = 0; i < omap->nports; i++) {
+		struct ehci_hcd *ehci = hcd_to_ehci(hcd);
+		int port = i + 1;
+		int j;
+
+		if (pdata->port_mode[i] != OMAP_EHCI_PORT_MODE_PHY)
+			continue;
+
+		for (j = 0; j < 10; j++) {
+			int dbg = omap_ehci_ulpi_read(regs, port, ULPI_DEBUG);
+			u32 portsc = ehci_readl(ehci,
+						&ehci->regs->port_status[i]);
+
+			dev_info(dev,
+				 "steelhead: diag t+%dms port%d ULPI DBG=%#x PORTSC=%08x\n",
+				 j * 100, port, dbg, portsc);
+			msleep(100);
+		}
+	}
+
+	if (hcd->self.root_hub) {
+		/*
+		 * Pin the root hub runtime-active. usb_disable_autosuspend()
+		 * (pm_runtime_forbid) alone is not enough: userspace udev
+		 * (60-autosuspend.rules, hwdb ID_AUTOSUSPEND) sets power/control
+		 * back to "auto" after boot, so the root hub autosuspends,
+		 * ehci_bus_suspend() halts the controller and the OMAP gates the
+		 * EHCI functional clock -> port power (VBUS) drops and the
+		 * soldered LAN9500A loses its session. Holding a runtime PM usage
+		 * reference keeps usage_count > 0, so the USB core never
+		 * autosuspends the root hub regardless of the control= policy;
+		 * the port stays powered and the hub keeps polling for the
+		 * slow-to-connect LAN9500A.
+		 */
+		pm_runtime_forbid(&hcd->self.root_hub->dev);
+		pm_runtime_get_noresume(&hcd->self.root_hub->dev);
+		dev_info(dev,
+			 "steelhead: root-hub pinned runtime-active, keeping ehci port powered\n");
+	}
+
+	/*
 	 * Bring PHYs out of reset for non PHY modes.
 	 * Even though HSIC mode is a PHY-less mode, the reset
 	 * line exists between the chips and can be modelled
