From 0000000000000000000000000000000000000009 Mon Sep 17 00:00:00 2001
From: Petr Parkan Janda <petr.parkan.janda@oh-so.com>
Date: Sun, 22 Jun 2026 17:00:00 +0200
Subject: [PATCH] ARM: OMAP4: steelhead: instrument SMP CPU1 bring-up (debug)

Temporary pr_emerg() milestones around the OMAP4 secondary-CPU bring-up
(omap4_smp_prepare_cpus / omap4_boot_secondary / omap4_secondary_init) to
locate exactly where CPU1 bring-up silently deadlocks on the OMAP4460 HS
Nexus Q. The messages print synchronously to the console, so the last one
before the hang pinpoints the failing step. Triggered at runtime via CPU1
hotplug (echo 1 > /sys/devices/system/cpu/cpu1/online) on a maxcpus=1 boot,
read off the HDMI text console.

NOT for release -- drop once CPU1 bring-up works.

Signed-off-by: Petr Parkan Janda <petr.parkan.janda@oh-so.com>
---
--- a/arch/arm/mach-omap2/omap-smp.c
+++ b/arch/arm/mach-omap2/omap-smp.c
@@ -145,6 +145,7 @@
 
 static void omap4_secondary_init(unsigned int cpu)
 {
+	pr_emerg("STEELHEAD-SMP: >>> CPU1 secondary_init REACHED, CPU1 is ALIVE (cpu=%u) <<<\n", cpu);
 	/*
 	 * Configure ACTRL and enable NS SMP bit access on CPU1 on HS device.
 	 * OMAP44XX EMU/HS devices - CPU0 SMP bit access is enabled in PPA
@@ -176,6 +177,8 @@
 	static bool booted;
 	static struct powerdomain *cpu1_pwrdm;
 
+	pr_emerg("STEELHEAD-SMP: boot_secondary cpu=%u ENTER (secure_apis=%d)\n", cpu, omap_secure_apis_support());
+
 	/*
 	 * Update the AuxCoreBoot0 with boot state for secondary core.
 	 * omap4_secondary_startup() routine will hold the secondary core till
@@ -189,6 +192,8 @@
 		writel_relaxed(AUX_CORE_BOOT0_GP_RELEASE,
 			       cfg.wakeupgen_base + OMAP_AUX_CORE_BOOT_0);
 
+	pr_emerg("STEELHEAD-SMP: AUX_CORE_BOOT0 release path returned (cpu=%u)\n", cpu);
+
 	if (!cpu1_clkdm && !cpu1_pwrdm) {
 		cpu1_clkdm = clkdm_lookup("mpu1_clkdm");
 		cpu1_pwrdm = pwrdm_lookup("cpu1_pwrdm");
@@ -243,10 +248,12 @@
 			local_irq_enable();
 		}
 	} else {
+		pr_emerg("STEELHEAD-SMP: first bringup, dsb_sev() to wake CPU1 from WFE\n");
 		dsb_sev();
 		booted = true;
 	}
 
+	pr_emerg("STEELHEAD-SMP: sending wakeup IPI to CPU1, now waiting for it...\n");
 	arch_send_wakeup_ipi_mask(cpumask_of(cpu));
 
 	return 0;
@@ -390,6 +397,7 @@
 	if (cfg.scu_base)
 		scu_enable(cfg.scu_base);
 
+	pr_emerg("STEELHEAD-SMP: prepare: SCU enabled, calling maybe_reset_cpu1\n");
 	omap4_smp_maybe_reset_cpu1(&cfg);
 
 	/*
@@ -403,6 +411,8 @@
 	else
 		writel_relaxed(__pa_symbol(cfg.startup_addr),
 			       cfg.wakeupgen_base + OMAP_AUX_CORE_BOOT_1);
+
+	pr_emerg("STEELHEAD-SMP: prepare: AUX_CORE_BOOT1 startup addr written (0x%lx), prepare DONE\n", (unsigned long)__pa_symbol(cfg.startup_addr));
 }
 
 const struct smp_operations omap4_smp_ops __initconst = {
