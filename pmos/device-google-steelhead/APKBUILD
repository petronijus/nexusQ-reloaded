# Reference: <https://postmarketos.org/devicepkg>
# Device: Google Nexus Q (steelhead)
pkgname=device-google-steelhead
pkgdesc="Google Nexus Q"
pkgver=1.0
pkgrel=15
url="https://postmarketos.org"
license="MIT"
arch="armv7"
options="!check !archcheck"
depends="
	linux-google-steelhead
	mesa-dri-gallium
	mkbootimg
	postmarketos-base
	lxqt-wayland-session
	labwc
	swaybg
	weston
	netsurf
	mpv
	nm-tray
	blueman
	breeze-icons
	nexusqd
	nexusq-control
	librespot
	openssh-server
	openssh-client
	gdb
	python3-dbg
"
makedepends="devicepkg-dev"
install="$pkgname.post-install"
subpackages="$pkgname-nonfree-firmware:nonfree_firmware"
source="
	deviceinfo
	modules-initfs
	weston.ini
	weston-nexusq.desktop
	lxqt-session.conf
	nexusq-wayland.sh
	wifi-powersave-off.conf
	brcmfmac-no-p2p.conf
	brcmfmac-mpc-off.conf
	nexusq-usb-acm-console.sh
	nexusq-usb-acm-console.service
	nexusq-usb-gadget.sh
	nexusq-usb-gadget.service
	nq-healthd
	nq-diag-snapshot
	nq-healthd.service
	librespot.service
	60_spotify.nft
	asound.conf
	snd-aloop.conf
	nexusq.preset
	$pkgname.post-install
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	# LXQt-Wayland is the UI (installed via the build's `ui = lxqt`); these
	# device files make it actually paint on this GPU-less, headless single-core
	# OMAP4 board:
	#  - force the wlroots Pixman SW renderer (else labwc aborts: no GPU)
	install -Dm644 "$srcdir"/nexusq-wayland.sh \
		"$pkgdir"/etc/profile.d/nexusq-wayland.sh
	#  - pin the LXQt compositor to labwc so the full session starts on boot 1
	install -Dm644 "$srcdir"/lxqt-session.conf \
		"$pkgdir"/etc/xdg/lxqt/session.conf

	# Fallback session: device-specific weston config (pixman, headless-tolerant)
	# kept selectable in case LXQt misbehaves. The default tinydm session
	# (LXQt-Wayland) is wired up by the post-install script.
	install -Dm644 "$srcdir"/weston.ini \
		"$pkgdir"/etc/xdg/weston/weston.ini
	install -Dm644 "$srcdir"/weston-nexusq.desktop \
		"$pkgdir"/usr/share/wayland-sessions/weston-nexusq.desktop

	# Disable WiFi power-save (BCM4330): fixes severe latency jitter (~175->~15 ms).
	install -Dm644 "$srcdir"/wifi-powersave-off.conf \
		"$pkgdir"/etc/NetworkManager/conf.d/wifi-powersave-off.conf

	# Disable brcmfmac P2P: the BCM4330 firmware advertises "p2p" but cannot create
	# the P2P_DEVICE interface (p2p_disc handshake times out), so wpa_supplicant/NM
	# spam failed p2p-dev creations + orphaned "event handler failed (72)". The
	# Nexus Q does not use Wi-Fi Direct. feature_disable=16 = BIT(BRCMF_FEAT_P2P).
	install -Dm644 "$srcdir"/brcmfmac-no-p2p.conf \
		"$pkgdir"/etc/modprobe.d/brcmfmac-no-p2p.conf

	# Keep the BCM4330 radio always on (mpc=0): fixes bulk stalls + ~30% packet
	# loss caused by the firmware's idle radio power-down. Needs kernel patch 0021
	# (the brcmfmac "mpc" module param). Matches stock bcmdhd, which sets mpc=0.
	install -Dm644 "$srcdir"/brcmfmac-mpc-off.conf \
		"$pkgdir"/etc/modprobe.d/brcmfmac-mpc-off.conf

	# USB gadget: own it deterministically as a COMPOSITE RNDIS net
	# (172.16.42.1 + ssh) + ACM console, every boot, from configfs. This replaces
	# the old pmOS-RNDIS + RNDIS->ACM-swap chain, which on the full-rootfs image
	# left the gadget *unbound* (host saw nothing — no net, no console, no way in).
	# Since the on-board ethernet regressed (v1.4.0), the USB net is the reliable
	# fallback path, so we expose RNDIS again (plus ACM for a serial login). The
	# script logs its result to /dev/tty1 so it is visible on HDMI with no channel.
	install -Dm755 "$srcdir"/nexusq-usb-gadget.sh \
		"$pkgdir"/usr/bin/nexusq-usb-gadget.sh
	install -Dm644 "$srcdir"/nexusq-usb-gadget.service \
		"$pkgdir"/etc/systemd/system/nexusq-usb-gadget.service
	install -dm755 "$pkgdir"/etc/systemd/system/multi-user.target.wants
	ln -sf ../nexusq-usb-gadget.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/nexusq-usb-gadget.service
	# Keep the old ACM-swap script/unit available but NOT enabled (superseded).
	install -Dm755 "$srcdir"/nexusq-usb-acm-console.sh \
		"$pkgdir"/usr/bin/nexusq-usb-acm-console.sh
	install -Dm644 "$srcdir"/nexusq-usb-acm-console.service \
		"$pkgdir"/etc/systemd/system/nexusq-usb-acm-console.service

	# Diagnostics: the comprehensive one-shot snapshot collector and the
	# continuous runtime health monitor. nq-healthd watches the things that
	# silently fail in the field (LED-ring/nexusqd hangs, VDD_MPU vs OPP drift,
	# thermal throttle, kernel errors) and logs to /var/log/nq-health. Enabled
	# by default so a fault is already recorded by the time we go looking.
	install -Dm755 "$srcdir"/nq-diag-snapshot \
		"$pkgdir"/usr/bin/nq-diag-snapshot
	install -Dm755 "$srcdir"/nq-healthd \
		"$pkgdir"/usr/bin/nq-healthd
	install -Dm644 "$srcdir"/nq-healthd.service \
		"$pkgdir"/etc/systemd/system/nq-healthd.service
	install -dm755 "$pkgdir"/etc/systemd/system/multi-user.target.wants
	ln -sf ../nq-healthd.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/nq-healthd.service

	# Spotify Connect (librespot) — the audio source. It outputs via the "nexusq"
	# ALSA PCM (asound.conf), which addresses the speaker by NAME (card numbers
	# race between TAS5713 and HDMI across boots) and resamples everything to
	# 48 kHz: the McBSP2->TAS5713 link only clocks the 48 kHz family cleanly, and
	# with kernel patch 0022 (the CLKGDV fix) that yields an exact 48 kHz FSYNC
	# (correct pitch/speed; before 0022 audio ran exactly 2x too fast). librespot
	# 0.8.0 ships only the libmdns zeroconf backend, which coexists with avahi.
	install -Dm644 "$srcdir"/asound.conf \
		"$pkgdir"/etc/asound.conf
	install -Dm644 "$srcdir"/librespot.service \
		"$pkgdir"/etc/systemd/system/librespot.service
	ln -sf ../librespot.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/librespot.service
	# Open mDNS (5353) + the librespot zeroconf HTTP port (37879) on WiFi so the
	# phone (Spotify controller) can discover "Nexus Q".
	install -Dm644 "$srcdir"/60_spotify.nft \
		"$pkgdir"/etc/nftables.d/60_spotify.nft
	# Load snd-aloop so the "nexusq" tee's loopback slave (hw:Loopback,0) exists.
	# librespot's audio is duplicated to the speaker AND the loopback; nexusqd's
	# tap (arecord on hw:Loopback,1, see userspace/nexusqd) reads it for the LED
	# music visualizer.
	install -Dm644 "$srcdir"/snd-aloop.conf \
		"$pkgdir"/etc/modules-load.d/snd-aloop.conf

	# Force-enable the companion control bridge. nexusq-control.service is a
	# VENDOR unit (the nexusq-control aport ships it in /usr/lib/systemd/system),
	# so unlike the device's own /etc units above it is subject to systemd-preset
	# management: the image build runs `systemctl preset-all`, postmarketOS ships
	# a `disable *` catch-all (99-default.preset), and there is no preset entry
	# enabling nexusq-control -> preset-all DISABLES it, stripping any hand-placed
	# /etc/.../multi-user.target.wants symlink (this is exactly why pkgrel 14's
	# bare symlink did not stick, AND why the aport's /usr/lib vendor wants did
	# not auto-start). The DURABLE fix is a preset that declares it enabled
	# (mirrors how postmarketos-base enables its services in 90-base.preset);
	# preset-all then (re)creates the enable symlink on every run. Priority 95
	# wins over 99-default's `disable *` and does not collide with the 90-* files.
	install -Dm644 "$srcdir"/nexusq.preset \
		"$pkgdir"/usr/lib/systemd/system-preset/95-nexusq.preset
	# Belt-and-suspenders: also drop the /etc enable symlink directly, so the
	# unit is enabled even on any path where preset-all is not (re)run. preset-all
	# is idempotent with an already-correct symlink; `systemctl enable` keeps it.
	ln -sf /usr/lib/systemd/system/nexusq-control.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/nexusq-control.service
}

nonfree_firmware() {
	pkgdesc="WiFi and Bluetooth firmware for BCM4330"
	depends="firmware-google-steelhead"
	mkdir -p "$subpkgdir"
}

sha512sums="
SKIP  deviceinfo
SKIP  modules-initfs
SKIP  weston.ini
SKIP  weston-nexusq.desktop
SKIP  lxqt-session.conf
SKIP  nexusq-wayland.sh
SKIP  wifi-powersave-off.conf
SKIP  brcmfmac-no-p2p.conf
SKIP  brcmfmac-mpc-off.conf
SKIP  nexusq-usb-acm-console.sh
SKIP  nexusq-usb-acm-console.service
SKIP  nexusq-usb-gadget.sh
SKIP  nexusq-usb-gadget.service
SKIP  nq-healthd
SKIP  nq-diag-snapshot
SKIP  nq-healthd.service
SKIP  librespot.service
SKIP  60_spotify.nft
SKIP  asound.conf
SKIP  snd-aloop.conf
SKIP  nexusq.preset
SKIP  device-google-steelhead.post-install
"
