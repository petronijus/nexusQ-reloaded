# Reference: <https://postmarketos.org/devicepkg>
# Device: Google Nexus Q (steelhead)
pkgname=device-google-steelhead
pkgdesc="Google Nexus Q"
pkgver=1.0
pkgrel=49
url="https://postmarketos.org"
license="MIT"
arch="armv7"
options="!check !archcheck"
depends="
	linux-google-steelhead
	mesa-dri-gallium
	mkbootimg
	postmarketos-base
	lxqt-wayland-session
	labwc
	swaybg
	weston
	netsurf
	mpv
	nm-tray
	blueman
	breeze-icons
	nexusqd
	nexusq-control
	nexusq-setupd
	nexusq-btagent
	librespot
	pulseaudio
	openssh-server
	openssh-client
	gdb
	python3-dbg
	i2c-tools
	gptfdisk
	iw
	ethtool
	iproute2-minimal
	tzdata
"
makedepends="devicepkg-dev"
install="$pkgname.post-install"
# apk trigger: patch pulseaudio's tas5713 mixer path AFTER pulseaudio is unpacked
# (.post-install runs too early — it fires before late-unpacked deps' files exist).
triggers="$pkgname.trigger=/usr/share/pulseaudio/alsa-mixer/paths:/etc/pulse:/etc/xdg/lxqt-tablet/autostart"
subpackages="$pkgname-nonfree-firmware:nonfree_firmware"
source="
	deviceinfo
	modules-initfs
	weston.ini
	weston-nexusq.desktop
	lxqt-session.conf
	nexusq-wayland.sh
	wifi-powersave-off.conf
	wifi-stable-mac.conf
	eth-lan.nmconnection
	eth-direct.nmconnection
	eth-no-auto-default.conf
	brcmfmac-no-p2p.conf
	brcmfmac-mpc-off.conf
	pipewire-autostart-off.desktop
	wireplumber-autostart-off.desktop
	blueman-autostart-off.desktop
	pulseaudio.service
	pam-base-auth
	pam-base-session
	91-pulseaudio-hdmi-ignore.rules
	92-steelhead-avr-keyboard.rules
	labwc-rc.xml
	nq-vol
	nexusq-nfc-send
	nexusq-nfc.service
	20-nexusq-nsresourced-off.preset
	bluetooth-confdir-mode.conf
	pulse-client-no-autospawn.conf
	50-nexusq-48k.conf
	nm-lo-unmanaged.conf
	ssh-authorized-keys
	wifi.nmconnection
	nexusq-usb-acm-console.sh
	nexusq-usb-acm-console.service
	nexusq-usb-gadget.sh
	nexusq-usb-gadget.service
	nq-healthd
	nq-diag-snapshot
	nq-healthd.service
	librespot.service
	librespot-nexusq
	60_spotify.nft
	55_nexusq-control.nft
	asound.conf
	snd-aloop.conf
	nexusq.preset
	$pkgname.post-install
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	# LXQt-Wayland is the UI (installed via the build's `ui = lxqt`); these
	# device files make it actually paint on this GPU-less, headless single-core
	# OMAP4 board:
	#  - force the wlroots Pixman SW renderer (else labwc aborts: no GPU)
	install -Dm644 "$srcdir"/nexusq-wayland.sh \
		"$pkgdir"/etc/profile.d/nexusq-wayland.sh
	#  - pin the LXQt compositor to labwc so the full session starts on boot 1
	install -Dm644 "$srcdir"/lxqt-session.conf \
		"$pkgdir"/etc/xdg/lxqt/session.conf

	# Fallback session: device-specific weston config (pixman, headless-tolerant)
	# kept selectable in case LXQt misbehaves. The default tinydm session
	# (LXQt-Wayland) is wired up by the post-install script.
	install -Dm644 "$srcdir"/weston.ini \
		"$pkgdir"/etc/xdg/weston/weston.ini
	install -Dm644 "$srcdir"/weston-nexusq.desktop \
		"$pkgdir"/usr/share/wayland-sessions/weston-nexusq.desktop

	# Disable WiFi power-save (BCM4330): fixes severe latency jitter (~175->~15 ms).
	install -Dm644 "$srcdir"/wifi-powersave-off.conf \
		"$pkgdir"/etc/NetworkManager/conf.d/wifi-powersave-off.conf

	# Pin WiFi to the hardware MAC: NM's randomized locally-administered MAC
	# pulled a fresh DHCP lease every boot, so the device's IP wandered and the
	# documented ssh path broke (2026-07-02).
	install -Dm644 "$srcdir"/wifi-stable-mac.conf \
		"$pkgdir"/etc/NetworkManager/conf.d/wifi-stable-mac.conf

	# Boot-log cleanup (cosmetic, no functional change):
	#  - pam-base-auth + pam-base-session shadow /usr/lib/pam.d/base-{auth,session}
	#    to drop the desktop-keyring PAM lines, silencing "gkr-pam: couldn't
	#    unlock the login keyring" on every key-based ssh login (the noisy one is
	#    the base-session auto_start). gnome-keyring stays installed (hard dep of
	#    nm-applet/gvfs/webkit); nothing here uses the user keyring. base-session
	#    preserves pam_systemd (XDG_RUNTIME_DIR); all its lines are -session
	#    optional so a stale copy can never block login.
	#  - PULSE_IGNORE the omap-hdmi-audio card (dummy-DAI, not a usable sink)
	#    so PulseAudio stops failing module-alsa-card on it every boot.
	install -Dm644 "$srcdir"/pam-base-auth \
		"$pkgdir"/etc/pam.d/base-auth
	install -Dm644 "$srcdir"/pam-base-session \
		"$pkgdir"/etc/pam.d/base-session
	install -Dm644 "$srcdir"/91-pulseaudio-hdmi-ignore.rules \
		"$pkgdir"/etc/udev/rules.d/91-pulseaudio-hdmi-ignore.rules
	# Front-panel volume ring -> real (PulseAudio) volume. Three pieces:
	# udev seat/keyboard tag (without it labwc never receives the device),
	# labwc keybinds in the skel rc.xml, and the nq-vol pactl helper (capped
	# at 100%). The tray volume applet then follows via the bridge's
	# panel.conf re-link on every output switch (nexusq-control r7+).
	install -Dm644 "$srcdir"/92-steelhead-avr-keyboard.rules \
		"$pkgdir"/etc/udev/rules.d/92-steelhead-avr-keyboard.rules
	install -Dm644 "$srcdir"/labwc-rc.xml \
		"$pkgdir"/etc/skel/.config/labwc/rc.xml
	install -Dm755 "$srcdir"/nq-vol \
		"$pkgdir"/usr/bin/nq-vol
	# NFC tap-to-send daemon (reverse-HCE reader): the Q reads a phone running
	# the companion app's HostApduService and pushes a text on each tap. Needs
	# the pn544 RATS kernel fix (linux patch 0037). neard is intentionally NOT
	# installed — this daemon owns the kernel NFC device directly.
	install -Dm755 "$srcdir"/nexusq-nfc-send \
		"$pkgdir"/usr/bin/nexusq-nfc-send
	install -Dm644 "$srcdir"/nexusq-nfc.service \
		"$pkgdir"/etc/systemd/system/nexusq-nfc.service
	install -dm755 "$pkgdir"/etc/systemd/system/multi-user.target.wants
	ln -sf ../nexusq-nfc.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/nexusq-nfc.service
	# Disable systemd-nsresourced via a low-priority preset (NOT a /dev/null mask,
	# which makes preset-all warn). See the .preset file header for the ordering.
	install -Dm644 "$srcdir"/20-nexusq-nsresourced-off.preset \
		"$pkgdir"/usr/lib/systemd/system-preset/20-nexusq-nsresourced-off.preset
	# Align bluetooth.service ConfigurationDirectoryMode with the shipped
	# /etc/bluetooth 0755 (silences the 755-vs-555 mode warning).
	install -Dm644 "$srcdir"/bluetooth-confdir-mode.conf \
		"$pkgdir"/etc/systemd/system/bluetooth.service.d/confdir-mode.conf
	# PA: start once (XDG autostart) — disable client autospawn (daemon-already-running race).
	install -Dm644 "$srcdir"/pulse-client-no-autospawn.conf \
		"$pkgdir"/etc/pulse/client.conf.d/50-nexusq-no-autospawn.conf
	# PA: pin all sinks to 48 kHz (McASP S/PDIF + McBSP2/TAS5713 clock only the
	# 48 kHz family cleanly; 44.1 kHz -> McASP "off by 88435 PPM"). Resample 44.1.
	install -Dm644 "$srcdir"/50-nexusq-48k.conf \
		"$pkgdir"/etc/pulse/daemon.conf.d/50-nexusq-48k.conf
	# NM: loopback unmanaged so the dns-filter dispatcher never runs (and fails) on lo.
	install -Dm644 "$srcdir"/nm-lo-unmanaged.conf \
		"$pkgdir"/etc/NetworkManager/conf.d/10-lo-unmanaged.conf

	# eth0 is OWNED by the baked profiles (see the file comments): eth-lan
	# (DHCP, one attempt per carrier event) + eth-direct (the static
	# PC<->Nexus cable workflow, manual activation) + no-auto-default so NM
	# never generates the "Wired connection 1" whose endless serverless-DHCP
	# retry loop bounced the carrier every ~47 s and failed
	# NetworkManager-wait-online (root-caused 2026-07-04; the LAN9500A
	# itself is fully healthy again since batch 2b — task #17 closed).
	install -Dm600 "$srcdir"/eth-lan.nmconnection \
		"$pkgdir"/etc/NetworkManager/system-connections/eth-lan.nmconnection
	install -Dm600 "$srcdir"/eth-direct.nmconnection \
		"$pkgdir"/etc/NetworkManager/system-connections/eth-direct.nmconnection
	install -Dm644 "$srcdir"/eth-no-auto-default.conf \
		"$pkgdir"/etc/NetworkManager/conf.d/eth-no-auto-default.conf

	# Audio: PulseAudio is the sound server (the pmOS audio backend). The
	# pipewire package is present only as a library dependency, but its XDG
	# autostart started a SECOND sound server next to PA in every LXQt session,
	# and the pipewire-systemd package enables a pipewire-pulse.socket whose
	# service/binary (the pipewire-pulse package) is not installed at all ->
	# "Socket service pipewire-pulse.service not loaded, refusing." every boot.
	# Suppress the autostarts via the device XDG config dir (see the
	# XDG_CONFIG_DIRS prepend in nexusq-wayland.sh) and mask the orphaned user
	# socket. If the image ever switches its backend to PipeWire, drop all three.
	install -Dm644 "$srcdir"/pipewire-autostart-off.desktop \
		"$pkgdir"/etc/xdg/nexusq/autostart/pipewire.desktop
	install -Dm644 "$srcdir"/wireplumber-autostart-off.desktop \
		"$pkgdir"/etc/xdg/nexusq/autostart/wireplumber.desktop

	# Bluetooth: keep blueman-applet out of the session. Its DisplayYesNo agent
	# forces SSP into Numeric Comparison, which raises a Confirm/Deny dialog on
	# the HDMI desktop that NOTHING attached to this appliance can click -> every
	# bond timed out (mgmt 0x0e), and it also stole the default agent from
	# nexusq-btagent (RequestDefaultAgent is last-writer-wins). Root-caused live
	# 2026-07-15; pairing + A2DP verified working the moment the applet was gone.
	# Same XDG_CONFIG_DIRS shadowing trick as the pipewire/wireplumber overrides
	# above. The blueman package itself stays (blueman-manager on demand).
	install -Dm644 "$srcdir"/blueman-autostart-off.desktop \
		"$pkgdir"/etc/xdg/nexusq/autostart/blueman.desktop
	install -dm755 "$pkgdir"/etc/systemd/user
	ln -sf /dev/null "$pkgdir"/etc/systemd/user/pipewire-pulse.socket

	# ...but suppressing PipeWire is only half of it: PulseAudio was never
	# actually STARTED. Alpine's PA ships no systemd user unit and relies on the
	# XDG autostart pulseaudio.desktop (start-pulseaudio-x11), which does not
	# fire in this systemd + LXQt/labwc Wayland session (xdg-desktop-autostart
	# .target stays dead; the .desktop is X-GNOME-HiddenUnderSystemd; autospawn
	# is off) → no daemon → PA clients get "Connection refused" → red-cross tray
	# icon (diagnosed 2026-07-07). Ship a native PA user service and enable it
	# for every user session via the default.target.wants symlink (a plain user
	# daemon — NOT socket-activated, which double-binds the native socket PA's
	# own default.pa creates). autospawn stays off (50-nexusq-no-autospawn.conf).
	install -Dm644 "$srcdir"/pulseaudio.service \
		"$pkgdir"/usr/lib/systemd/user/pulseaudio.service
	install -dm755 "$pkgdir"/usr/lib/systemd/user/default.target.wants
	ln -sf ../pulseaudio.service \
		"$pkgdir"/usr/lib/systemd/user/default.target.wants/pulseaudio.service

	# Baked-in device access. Both files are staged into this aport by
	# docker-build.sh (Phase 6) from the PRIVATE overlay (private/access/) —
	# the WiFi PSK is a secret and the ssh pubkeys are personal, so neither
	# lives in the public tree. On a public build the staged files are EMPTY
	# placeholders and the [ -s ] guards skip them (no access baked; configure
	# by hand after flashing). This is what makes a clean reflash come up
	# reachable: root+user ssh keys and the WiFi profile live in the rootfs,
	# which a flash wipes (bitten 2026-06-28 and again 2026-07-02).
	if [ -s "$srcdir"/ssh-authorized-keys ]; then
		install -dm700 "$pkgdir"/root/.ssh
		install -Dm600 "$srcdir"/ssh-authorized-keys \
			"$pkgdir"/root/.ssh/authorized_keys
		install -dm700 "$pkgdir"/etc/skel/.ssh
		install -Dm600 "$srcdir"/ssh-authorized-keys \
			"$pkgdir"/etc/skel/.ssh/authorized_keys
	fi
	if [ -s "$srcdir"/wifi.nmconnection ]; then
		install -Dm600 "$srcdir"/wifi.nmconnection \
			"$pkgdir"/etc/NetworkManager/system-connections/wifi.nmconnection
	fi

	# Disable brcmfmac P2P: the BCM4330 firmware advertises "p2p" but cannot create
	# the P2P_DEVICE interface (p2p_disc handshake times out), so wpa_supplicant/NM
	# spam failed p2p-dev creations + orphaned "event handler failed (72)". The
	# Nexus Q does not use Wi-Fi Direct. feature_disable=16 = BIT(BRCMF_FEAT_P2P).
	install -Dm644 "$srcdir"/brcmfmac-no-p2p.conf \
		"$pkgdir"/etc/modprobe.d/brcmfmac-no-p2p.conf

	# Keep the BCM4330 radio always on (mpc=0): fixes bulk stalls + ~30% packet
	# loss caused by the firmware's idle radio power-down. Needs kernel patch 0021
	# (the brcmfmac "mpc" module param). Matches stock bcmdhd, which sets mpc=0.
	install -Dm644 "$srcdir"/brcmfmac-mpc-off.conf \
		"$pkgdir"/etc/modprobe.d/brcmfmac-mpc-off.conf

	# USB gadget: own it deterministically as a COMPOSITE RNDIS net
	# (172.16.42.1 + ssh) + ACM console, every boot, from configfs. This replaces
	# the old pmOS-RNDIS + RNDIS->ACM-swap chain, which on the full-rootfs image
	# left the gadget *unbound* (host saw nothing — no net, no console, no way in).
	# Since the on-board ethernet regressed (v1.4.0), the USB net is the reliable
	# fallback path, so we expose RNDIS again (plus ACM for a serial login). The
	# script logs its result to /dev/tty1 so it is visible on HDMI with no channel.
	install -Dm755 "$srcdir"/nexusq-usb-gadget.sh \
		"$pkgdir"/usr/bin/nexusq-usb-gadget.sh
	install -Dm644 "$srcdir"/nexusq-usb-gadget.service \
		"$pkgdir"/etc/systemd/system/nexusq-usb-gadget.service
	install -dm755 "$pkgdir"/etc/systemd/system/multi-user.target.wants
	ln -sf ../nexusq-usb-gadget.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/nexusq-usb-gadget.service
	# Keep the old ACM-swap script/unit available but NOT enabled (superseded).
	install -Dm755 "$srcdir"/nexusq-usb-acm-console.sh \
		"$pkgdir"/usr/bin/nexusq-usb-acm-console.sh
	install -Dm644 "$srcdir"/nexusq-usb-acm-console.service \
		"$pkgdir"/etc/systemd/system/nexusq-usb-acm-console.service

	# Diagnostics: the comprehensive one-shot snapshot collector and the
	# continuous runtime health monitor. nq-healthd watches the things that
	# silently fail in the field (LED-ring/nexusqd hangs, VDD_MPU vs OPP drift,
	# thermal throttle, kernel errors) and logs to /var/log/nq-health. Enabled
	# by default so a fault is already recorded by the time we go looking.
	install -Dm755 "$srcdir"/nq-diag-snapshot \
		"$pkgdir"/usr/bin/nq-diag-snapshot
	install -Dm755 "$srcdir"/nq-healthd \
		"$pkgdir"/usr/bin/nq-healthd
	install -Dm644 "$srcdir"/nq-healthd.service \
		"$pkgdir"/etc/systemd/system/nq-healthd.service
	install -dm755 "$pkgdir"/etc/systemd/system/multi-user.target.wants
	ln -sf ../nq-healthd.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/nq-healthd.service

	# Keep root's user manager resident (logind linger). Without it every ssh
	# login builds and tears down the whole user@0 session — ~7.5 s CPU per
	# login/logout cycle plus the cgroup/bpf destroy churn in pid 1 (measured
	# 2026-07-12, idle-temperature study). Linger turns that into a one-time
	# boot cost. logind reads this dir; an empty file named after the user is
	# the whole mechanism (`loginctl enable-linger root` creates exactly this).
	install -Dm644 /dev/null "$pkgdir"/var/lib/systemd/linger/root

	# Same for `user` (uid 10000) — but for a DIFFERENT and load-bearing reason:
	# it decouples AUDIO from the HDMI desktop. PulseAudio and librespot are user
	# units under user@10000.service, while the desktop is tinydm -> labwc in
	# session-c1.scope — different cgroups, but without linger the user manager
	# exists only BECAUSE of that graphical session, so stopping the desktop tears
	# down the manager and kills the music with it.
	# With linger, verified live 2026-07-15: `systemctl stop tinydm` leaves
	# user@10000 active, pulseaudio active, librespot active, both sinks present.
	# This is the prerequisite for the app's desktop toggle (PLAN.md "Open work").
	install -Dm644 /dev/null "$pkgdir"/var/lib/systemd/linger/user

	# Spotify Connect (librespot) — one INPUT into the PulseAudio hub (PA-centric
	# audio design). It runs as a systemd USER unit (uid-10000 `user` session, so
	# it shares that session's PA) via the wrapper /usr/bin/librespot-nexusq
	# (--backend alsa --device pulse; the ALSA `pulse` plugin routes into PA). The
	# OUTPUT (TAS5713 / SPDIF / HDMI) is the PA default sink, selectable by the
	# companion app — NOT a hardwired asound.conf `type multi` fan-out. Enabled
	# for the autologin session by the default.target.wants symlink (same pattern
	# as pulseaudio.service above; no linger needed).
	#   librespot 0.8.0 ships ONLY the libmdns zeroconf backend, which advertises
	# on every interface; the wrapper pins it to the live wlan0 IPv4
	# (--zeroconf-interface) so it never announces the usb0 gadget IP, and avahi is
	# constrained to wlan0 in the post-install.
	# NB asound.conf is still installed: the "nexusq"/snd-aloop loopback it defines
	# feeds nexusqd's LED music-visualizer tap (arecord hw:Loopback,1). That tap
	# will move to a PA monitor source when the companion bridge is reworked; until
	# then librespot no longer writes the loopback, so the visualizer is dormant.
	install -Dm644 "$srcdir"/asound.conf \
		"$pkgdir"/etc/asound.conf
	install -Dm755 "$srcdir"/librespot-nexusq \
		"$pkgdir"/usr/bin/librespot-nexusq
	install -Dm644 "$srcdir"/librespot.service \
		"$pkgdir"/usr/lib/systemd/user/librespot.service
	ln -sf ../librespot.service \
		"$pkgdir"/usr/lib/systemd/user/default.target.wants/librespot.service
	# Open mDNS (5353) + the librespot zeroconf HTTP port (37879) on WiFi so the
	# phone (Spotify controller) can discover "Nexus Q".
	install -Dm644 "$srcdir"/60_spotify.nft \
		"$pkgdir"/etc/nftables.d/60_spotify.nft
	# Open TCP 45015 on WiFi so the companion app can reach the nexusq-control
	# bridge (mDNS _nexusq._tcp discovery reuses the 5353 rule above). Without
	# this the phone app connects on the USB-gadget net but is firewalled off
	# over WiFi (the normal path).
	install -Dm644 "$srcdir"/55_nexusq-control.nft \
		"$pkgdir"/etc/nftables.d/55_nexusq-control.nft
	# Load snd-aloop so the "nexusq" tee's loopback slave (hw:Loopback,0) exists.
	# librespot's audio is duplicated to the speaker AND the loopback; nexusqd's
	# tap (arecord on hw:Loopback,1, see userspace/nexusqd) reads it for the LED
	# music visualizer.
	install -Dm644 "$srcdir"/snd-aloop.conf \
		"$pkgdir"/etc/modules-load.d/snd-aloop.conf

	# Force-enable the companion control bridge. nexusq-control.service is a
	# VENDOR unit (the nexusq-control aport ships it in /usr/lib/systemd/system),
	# so unlike the device's own /etc units above it is subject to systemd-preset
	# management: the image build runs `systemctl preset-all`, postmarketOS ships
	# a `disable *` catch-all (99-default.preset), and there is no preset entry
	# enabling nexusq-control -> preset-all DISABLES it, stripping any hand-placed
	# /etc/.../multi-user.target.wants symlink (this is exactly why pkgrel 14's
	# bare symlink did not stick, AND why the aport's /usr/lib vendor wants did
	# not auto-start). The DURABLE fix is a preset that declares it enabled
	# (mirrors how postmarketos-base enables its services in 90-base.preset);
	# preset-all then (re)creates the enable symlink on every run. Priority 95
	# wins over 99-default's `disable *` and does not collide with the 90-* files.
	install -Dm644 "$srcdir"/nexusq.preset \
		"$pkgdir"/usr/lib/systemd/system-preset/95-nexusq.preset
	# Belt-and-suspenders: also drop the /etc enable symlink directly, so the
	# unit is enabled even on any path where preset-all is not (re)run. preset-all
	# is idempotent with an already-correct symlink; `systemctl enable` keeps it.
	ln -sf /usr/lib/systemd/system/nexusq-control.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/nexusq-control.service
}

nonfree_firmware() {
	pkgdesc="WiFi and Bluetooth firmware for BCM4330"
	depends="firmware-google-steelhead"
	mkdir -p "$subpkgdir"
}

sha512sums="
SKIP  deviceinfo
SKIP  modules-initfs
SKIP  weston.ini
SKIP  weston-nexusq.desktop
SKIP  lxqt-session.conf
SKIP  nexusq-wayland.sh
