# Reference: <https://postmarketos.org/deviceinfo>
# Please use double quotes only. Google Nexus Q (steelhead).

deviceinfo_format_version="0"
deviceinfo_name="Google Nexus Q"
deviceinfo_manufacturer="Google"
deviceinfo_codename="google-steelhead"
deviceinfo_year="2012"
deviceinfo_dtb="omap4-steelhead"
deviceinfo_append_dtb="true"
deviceinfo_arch="armv7"

# Device
deviceinfo_chassis="embedded"
deviceinfo_keyboard="false"
deviceinfo_external_storage="false"
deviceinfo_screen_width="1920"
deviceinfo_screen_height="1080"

# Bootloader (offsets validated against samsung-maguro / OMAP4460)
deviceinfo_flash_method="fastboot"
deviceinfo_generate_bootimg="true"
deviceinfo_flash_offset_base="0x80000000"
deviceinfo_flash_offset_kernel="0x00008000"
deviceinfo_flash_offset_ramdisk="0x01000000"
deviceinfo_flash_offset_second="0x00f00000"
deviceinfo_flash_offset_tags="0x00000100"
deviceinfo_flash_pagesize="2048"
deviceinfo_kernel_cmdline="console=tty0 console=ttyS2,115200n8 mem=1G earlyprintk loglevel=7 ignore_loglevel panic=30"

# Rootfs goes to userdata (13 GB) since system partition is only 1 GB and the
# rootfs image exceeds fastboot's download buffer. Boot is loaded via RAM
# (fastboot boot) since boot.img exceeds the 8 MB boot partition.
deviceinfo_flash_fastboot_partition_system="userdata"

# USB gadget on the micro-USB port. pmOS brings it up as an RNDIS network device;
# nexusq-usb-acm-console.service then swaps it to an ACM serial debug console once
# the usb0 net device appears (networking lives on the on-board ethernet since
# v1.3.0). Keep "rndis" here — the service triggers off usb0 appearing, so the
# RNDIS gadget must be created first, then it is reshaped to ACM. fastboot is
# unaffected (bootloader-level, not this booted gadget).
deviceinfo_usb_idVendor="0x18D1"
deviceinfo_usb_idProduct="0x4EE2"
deviceinfo_usb_network_function_default="rndis"
