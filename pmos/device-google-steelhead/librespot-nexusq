#!/bin/sh
# librespot as a PulseAudio INPUT (Spotify Connect) for the Nexus Q.
#
# Runs as the `user` (uid 10000) systemd USER unit so it shares that session's
# PulseAudio: --backend alsa --device pulse -> the ALSA `pulse` plugin -> PA.
# This makes Spotify just one INPUT into the PA hub; the OUTPUT (TAS5713 / SPDIF
# / HDMI) is selected via PA's default sink (companion app). No `type multi`
# fan-out — a single, movable PA sink-input. (The multi-input design also lets
# Tidal / Bluetooth-A2DP / casting join later as further PA clients.)
#
# librespot 0.8.0 here is built with ONLY the libmdns zeroconf backend
# (`--zeroconf-backend avahi` errors: "Valid values: libmdns"). libmdns
# advertises on EVERY interface, so it announced the usb0 gadget IP
# (172.16.42.1) — unreachable from a WiFi phone. Pin libmdns to the live wlan0
# IPv4 with --zeroconf-interface, resolved at start (DHCP, not hardcoded); wait
# for wlan0 to get an address first. (avahi is additionally constrained to
# wlan0 via allow-interfaces= in the post-install.)
set -e

for i in $(seq 1 30); do
	WIP=$(ip -4 -o addr show wlan0 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)
	[ -n "$WIP" ] && break
	sleep 1
done
[ -n "$WIP" ] || { echo "librespot-nexusq: wlan0 has no IPv4 after 30s" >&2; exit 1; }

# Device name: read from the same identity file the nexusq-control bridge uses
# (/etc/nexusq/device.json, written by nexusq-setupd's setName), so Spotify
# Connect shows whatever name the user set. Falls back to "Nexus Q" when the
# file is absent/corrupt/unset (fresh install, before first setup) — never let
# a missing identity file block librespot from starting.
NQ_NAME="$(python3 - <<'EOF' 2>/dev/null || echo "Nexus Q"
import json
print(json.load(open("/etc/nexusq/device.json"))["name"])
EOF
)"
[ -n "$NQ_NAME" ] || NQ_NAME="Nexus Q"

# --ap-port 443: VLAN20 blocks Spotify's default access-point port 4070; without
#   this, discovery succeeds but playback stalls right after the credential handoff.
# --zeroconf-port 37879: matches the 60_spotify.nft firewall drop-in.
# --disable-credential-cache: stay in discovery mode (device always advertises for
#   Spotify Connect) rather than auto-logging into one cached account.
# --cache $CACHE_DIRECTORY: audio-file cache in the user-owned systemd CacheDirectory
#   (falls back to /var/cache/librespot when run by hand outside systemd).
# --onevent nexusq-onevent: now-playing + volume hook for the companion bridge.
exec /usr/bin/librespot \
	--name "$NQ_NAME" \
	--backend alsa --device pulse \
	--bitrate 320 --format S16 --initial-volume 60 \
	--ap-port 443 \
	--zeroconf-port 37879 --zeroconf-interface "$WIP" \
	--cache "${CACHE_DIRECTORY:-/var/cache/librespot}" --disable-credential-cache \
	--onevent /usr/bin/nexusq-onevent
