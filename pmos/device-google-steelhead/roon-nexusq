#!/bin/sh
# Roon Bridge launcher for the Nexus Q.
#
# Roon ships as glibc/.NET (Mono) armv7 binaries that do NOT run on musl (even
# gcompat segfaults on its Mono). So the Bridge runs inside a bubblewrap sandbox
# over a baked minimal Debian bookworm armhf glibc rootfs at /opt/glibc-rt (see
# docs/2026-07-17-roon-tidal-feasibility.md — proven on-device). Roon is just one
# more PulseAudio INPUT, like librespot/shairport: OUTPUT + volume live in PA and
# follow the app's default-sink choice.
#
# Started ON DEMAND by the roon.service USER unit (uid 10000). It is NEVER
# auto-enabled — the resource policy is that only the services the user turns on
# actually run (Mono is not free). Default: off.
#
# THE APP LAYER SELF-UPDATES. Only the glibc BASE is baked; RoonBridge itself is
# fetched here on first run and thereafter keeps itself current via Roon's own
# updater. Its directory therefore lives under a uid-10000-owned path so both this
# first fetch and every later self-update can write to it.
#
# HOME must be /home/roon (uid-10000-owned, created at package time): this unit
# runs as uid 10000 and Roon persists its state ($HOME/.RoonBridge) — /root inside
# the chroot is root-owned 0700 and NOT writable (measured 2026-07-17).
set -e

ROOT=/opt/glibc-rt
APPDIR="$ROOT/opt/RoonBridge"
RB_URL="https://download.roonlabs.com/builds/RoonBridge_linuxarmv7hf.tar.bz2"

[ -x "$ROOT/bin/bash" ] || { echo "roon-nexusq: glibc base missing at $ROOT" >&2; exit 1; }

# Lazy provisioning: fetch RoonBridge the first time Roon is turned on (needs the
# network — if it is not up yet the unit's Restart=on-failure retries).
if [ ! -x "$APPDIR/start.sh" ]; then
	echo "roon-nexusq: RoonBridge not present — fetching (first run)..." >&2
	mkdir -p "$ROOT/opt"
	tmp=$(mktemp -d)
	trap 'rm -rf "$tmp"' EXIT
	wget -q -O "$tmp/rb.tar.bz2" "$RB_URL"
	tar -xjf "$tmp/rb.tar.bz2" -C "$ROOT/opt"
	[ -x "$APPDIR/start.sh" ] || { echo "roon-nexusq: fetch/extract failed" >&2; exit 1; }
	echo "roon-nexusq: RoonBridge staged at $APPDIR" >&2
fi

XRT="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
PA_SOCK="$XRT/pulse/native"

# Roon shows the BRIDGE under the sandbox hostname. Take the onboarding name
# (/etc/nexusq/device.json, same source as AirPlay), sanitized to hostname-safe
# (alnum + '-'; spaces become '-', so "Nexus Q" -> "Nexus-Q"), and set it via
# --unshare-uts --hostname so the Core lists the user's device name instead of
# the OS hostname "steelhead".
NQ_NAME="$(python3 - <<'EOF' 2>/dev/null || echo "Nexus Q"
import json
print(json.load(open("/etc/nexusq/device.json"))["name"])
EOF
)"
[ -n "$NQ_NAME" ] || NQ_NAME="Nexus Q"
NQ_HOST="$(printf '%s' "$NQ_NAME" | tr -c 'A-Za-z0-9-' '-' | sed 's/^-*//; s/-*$//; s/--*/-/g')"
[ -n "$NQ_HOST" ] || NQ_HOST="Nexus-Q"

# The base tarball ships an empty /etc/resolv.conf placeholder so this bind (the
# host's live DNS, for Roon's cloud + self-update) has a target to land on.
# --tmpfs /run BEFORE the XRT bind: the baked /run is root-owned, so unprivileged
# bwrap could not mkdir the /run/user/10000 mountpoint inside it ("Can't mkdir
# /run/user/10000", hit live 2026-07-17). A fresh tmpfs /run belongs to the userns
# user, so bwrap creates the bind target itself.
# --ro-bind /sys: Mono's NetworkInterface reads interface state from
# /sys/class/net; without it EVERY iface enumerates as "not up", RoonBridge skips
# them all and never SOOD-announces on the LAN — invisible to the Core (hit live
# 2026-07-17, "[ipaddresses] SKIPPED wlan0: not up").
#
# AUDIO: Roon does not speak PulseAudio, and with no audio devices RAATServer
# answers enumerate_devices with [] and the Core shows nothing. So the sandbox
# gets EXACTLY ONE ALSA card: the dedicated RoonLoop snd-aloop card (index 7, see
# the modprobe.d file). Only its control + playback nodes (+ /dev/snd/timer) are
# dev-bound — the real cards (TAS5713/SPDIF/HDMI) have no nodes inside, so Roon
# can never grab hw and fight PulseAudio. PA reads the capture side
# (hw:RoonLoop,1,0 -> roon_in source -> module-loopback -> default sink), loaded
# below, so Roon audio follows the app's output choice like every other input.
# The PA source holds the loopback at s16le/48k FIRST, which constrains Roon's
# playback side to 48 kHz (RAAT reads the capability and converts itself).
# latency_msec=250: the loopback cushion proven smooth in the live bring-up
# (2026-07-17). Together with RAAT's own RT scheduling (user@10000 LimitRTPRIO)
# and the Core-side Device Setup "Buffer Size", this is the anti-choppiness set.
pactl list short sources 2>/dev/null | grep -q "^[0-9]*[[:space:]]*roon_in" || {
	pactl load-module module-alsa-source device=hw:RoonLoop,1,0 \
		source_name=roon_in source_properties=device.description=RoonBridge \
		rate=48000 channels=2 format=s16le >/dev/null
	pactl load-module module-loopback source=roon_in latency_msec=250 >/dev/null
}

exec bwrap \
	--bind "$ROOT" / \
	--unshare-uts \
	--hostname "$NQ_HOST" \
	--dev /dev \
	--proc /proc \
	--ro-bind /sys /sys \
	--dev-bind /dev/snd/controlC7 /dev/snd/controlC7 \
	--dev-bind /dev/snd/pcmC7D0p /dev/snd/pcmC7D0p \
	--dev-bind /dev/snd/timer /dev/snd/timer \
	--tmpfs /tmp \
	--tmpfs /run \
	--bind "$XRT" "$XRT" \
	--ro-bind /etc/resolv.conf /etc/resolv.conf \
	--setenv XDG_RUNTIME_DIR "$XRT" \
	--setenv PULSE_SERVER "$PA_SOCK" \
	--setenv HOME /home/roon \
	/bin/bash -c 'cd /opt/RoonBridge && exec ./start.sh'
