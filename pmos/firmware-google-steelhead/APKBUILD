# Reference: <https://postmarketos.org/devicepkg>
# Firmware: Google Nexus Q (steelhead) -- BCM4330 WiFi/BT
# Modeled on firmware-samsung-maguro (identical BCM4330 chip)
pkgname=firmware-google-steelhead
pkgver=1
pkgrel=1
pkgdesc="Google Nexus Q BCM4330 WiFi (brcmfmac) + BT firmware"
url="https://postmarketos.org"
arch="armv7"
license="proprietary"
depends="firmware-aosp-broadcom-wlan"
options="!strip !check !archcheck !spdx !tracedeps"
# The three blobs below are staged into this aport by docker-build.sh Phase 6
# (from ./firmware/), because the proprietary ones must not live in the public
# tree. The mainline kernel drives this chip with brcmfmac (WiFi) + hci_uart_bcm
# (BT), which look for these exact names under /lib/firmware/brcm:
#   - brcmfmac4330-sdio.bin : brcmfmac base firmware (redistributable, upstream
#                             linux-firmware) -- else "brcmfmac ... failed ... -2".
#   - brcmfmac4330-sdio.txt : brcmfmac NVRAM/calibration (the device's bcmdhd.cal,
#                             which is already key=value NVRAM) -- RF calibration.
#   - BCM4330B1.hcd         : BT patchram for the BCM4330B1 -- else
#                             "BCM: firmware Patch file not found" and no Bluetooth.
# NOTE: firmware-aosp-broadcom-wlan ships the *bcmdhd* (Android driver) fw_bcm4330
# images, which brcmfmac CANNOT use; it is kept as a dependency only for parity.
# If the blobs are absent (public clone without the firmware overlay), docker-build.sh
# replaces this with an empty package -- WiFi/BT then simply have no firmware.
source="
	brcmfmac4330-sdio.bin
	brcmfmac4330-sdio.txt
	BCM4330B1.hcd
"

build() {
	true
}

package() {
	install -Dm644 "$srcdir/brcmfmac4330-sdio.bin" \
		"$pkgdir"/lib/firmware/brcm/brcmfmac4330-sdio.bin
	install -Dm644 "$srcdir/brcmfmac4330-sdio.txt" \
		"$pkgdir"/lib/firmware/brcm/brcmfmac4330-sdio.txt
	install -Dm644 "$srcdir/BCM4330B1.hcd" \
		"$pkgdir"/lib/firmware/brcm/BCM4330B1.hcd
}

sha512sums=""
