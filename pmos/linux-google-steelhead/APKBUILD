# Reference: <https://postmarketos.org/linux-postmarketos>
# Kernel: mainline for Google Nexus Q (steelhead)
# Modeled after linux-postmarketos-omap
pkgname=linux-google-steelhead
pkgver=6.12.12
pkgrel=37
pkgdesc="Mainline kernel for Google Nexus Q"
url="https://kernel.org"
arch="armv7"
license="GPL-2.0-only"
options="!strip !check !tracedeps
	pmb:cross-native
	pmb:kconfigcheck-community
"
makedepends="
	bash
	bc
	bison
	findutils
	flex
	openssl-dev
	perl
	postmarketos-installkernel
	xz
"

_flavor="${pkgname#linux-}"
_config="config-$_flavor.$arch"
_carch="arm"

source="
	https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-$pkgver.tar.xz
	$_config
	0001-ASoC-tas571x-add-TAS5713-support.patch
	0002-dt-bindings-add-ti-tas5713.patch
	0003-ARM-dts-omap4-add-steelhead.patch
	0004-mfd-twl-core-register-clk-cell-for-twl6030.patch
	0005-leds-add-steelhead-avr.patch
	0006-usb-ehci-omap-steelhead-keep-ethernet-port-alive-ulp.patch
	0007-clk-ti-composite-implement-divider-round-set-rate.patch
	0008-mfd-omap-usb-host-steelhead-UHH-HOSTCONFIG-connect.patch
	0009-ARM-OMAP4-steelhead-SEV-in-prepare-wake-cpu1.patch
	0010-drm-omapdrm-hdmi4-cap-pixel-clock-steelhead.patch
	0011-leds-steelhead-avr-drain-key-fifo-at-probe.patch
	0012-mfd-omap-usb-host-steelhead-enable-utmi-clk-phy-mode.patch
	0013-ARM-OMAP4460-steelhead-tps62361-vdd-mpu-pmic.patch
	0014-ARM-OMAP4460-steelhead-tps62361-vdd-mpu-retask.patch
	0015-ARM-OMAP4460-steelhead-vc-mpu-bridge-regulator.patch
	0016-ARM-OMAP4460-steelhead-mpu-opp-stock-voltages.patch
	0017-ARM-OMAP4460-steelhead-vc-mpu-abb-fbb-nitro.patch
	0018-regulator-ti-abb-ENOTRECOVERABLE-when-unset.patch
	0019-bus-ti-sysc-silence-active-timer-ebusy.patch
	0020-nfc-pn544-i2c-longer-ven-settle-steelhead.patch
	0021-brcmfmac-mpc-module-param.patch
	0022-ASoC-omap-mcbsp-derive-CLKGDV-from-fclk-simple-card.patch
	0023-ARM-OMAP4-twl-smps-offset-no-latch-on-fail-steelhead-seed.patch
	0024-ARM-OMAP4-cpuidle-steelhead-C1-only.patch
	0025-bus-ti-sysc-child-named-clock-clkdev-add.patch
	0026-usb-phy-generic-vbus-optional-getter.patch
	0027-ARM-OMAP4-stock-parity-vc-on-voltages-4460-core-vcore1.patch
	0028-mmc-pwrseq-simple-clk-settle-delay.patch
	0029-leds-steelhead-avr-readable-frame.patch
	0030-twl-gate-pre-probe-access-twl-is-ready.patch
	0031-mfd-twl-core-clocks-init-twl4030-only.patch
	0032-mfd-omap-usb-host-depopulate-children-on-remove.patch
	0033-brcmfmac-nowarn-optional-firmware-clm-blob.patch
	0034-ARM-steelhead-no-hw-breakpoint-hs-debug-locked.patch
	0035-ARM-l2c-downgrade-omap4-aux-modify-notice.patch
	0036-Bluetooth-btbcm-recognize-bcm4330-4330a0-placeholder.patch
	0037-nfc-pn544-rats-activate-iso-dep-targets-steelhead.patch
"

builddir="$srcdir/linux-$pkgver"

prepare() {
	default_prepare
	cp "$srcdir/$_config" .config
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1))-postmarketOS" \
		KCFLAGS="-Wno-array-bounds" \
		olddefconfig
	make ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1))-postmarketOS" \
		KCFLAGS="-Wno-array-bounds"
}

package() {
	mkdir -p "$pkgdir"/boot

	make zinstall modules_install dtbs_install \
		ARCH="$_carch" \
		INSTALL_MOD_STRIP=1 \
		INSTALL_PATH="$pkgdir"/boot \
		INSTALL_MOD_PATH="$pkgdir" \
		INSTALL_DTBS_PATH="$pkgdir/boot/dtbs"

	install -D "$builddir"/include/config/kernel.release \
		"$pkgdir/usr/share/kernel/$_flavor/kernel.release"
}

