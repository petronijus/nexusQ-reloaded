# Nexus Q (steelhead) LED ring daemon — C11/musl, drives the leds-steelhead-avr
# kernel frame channel. Built for the target by pmbootstrap (armv7/musl).
pkgname=nexusqd
pkgver=0.1.0
pkgrel=9
pkgdesc="Nexus Q LED ring daemon (steelhead-avr)"
url="https://github.com/petronijus/nexusQ-reloaded"
arch="armv7"
license="GPL-2.0-only"
# arecord (alsa-utils) is the audio-visualizer tap; it now uses the ALSA→PulseAudio
# plugin (`arecord -D pulse`) to capture PA's default SOURCE (kept pointed at the
# active sink's .monitor by nexusq-control), so it follows the selected output and
# reacts to any input. The old snd-aloop loopback tap is vestigial (see audio.h).
# pulseaudio-utils: `pactl list short sink-inputs` gates the tap on a live playback
# stream so PA can suspend the sink at idle (idle-CPU fix, see src/audio.c).
depends="alsa-utils pulseaudio-utils"
options="!check"   # unit tests run on the host CI, not in the cross build
# Source files are staged flat next to this APKBUILD by docker-build.sh
# (from userspace/nexusqd/{src,include,Makefile,...}); prepare() restores the tree.
source="
	frame.c frame.h themes.c themes.h avr.c avr.h compositor.c compositor.h
	keys.c keys.h control.c control.h reaction.c reaction.h screensaver.c screensaver.h
	audio.c audio.h audiocap.c audiocap.h themecolor.c themecolor.h jrandom.c jrandom.h
	ledcfg.c ledcfg.h fx_waveform.c fx_waveform.h fx_waveformsolid.c fx_waveformsolid.h
	fx_circles.c fx_circles.h fx_pointmorph.c fx_pointmorph.h fx_starfield.c fx_starfield.h
	music.c music.h nexusqd.c nexusled.c
	sdnotify.c sdnotify.h
	Makefile nexusqd.service default.json
"
builddir="$srcdir"

prepare() {
	default_prepare
	mkdir -p include src
	cp "$srcdir"/*.h include/ 2>/dev/null || true
	cp "$srcdir"/*.c src/ 2>/dev/null || true
}

build() {
	make CC="${CC:-cc}" CFLAGS="-std=c11 -O2 -Wall -Iinclude"
}

package() {
	install -Dm755 nexusqd  "$pkgdir"/usr/bin/nexusqd
	install -Dm755 nexusled "$pkgdir"/usr/bin/nexusled
	install -Dm644 nexusqd.service "$pkgdir"/usr/lib/systemd/system/nexusqd.service
	install -Dm644 default.json "$pkgdir"/etc/nexusqd/themes/default.json

	# Enable autostart declaratively (no post-install / no manual systemctl enable):
	# the WantedBy=multi-user.target symlink is what `systemctl enable` would create.
	install -d "$pkgdir"/usr/lib/systemd/system/multi-user.target.wants
	ln -sf ../nexusqd.service \
		"$pkgdir"/usr/lib/systemd/system/multi-user.target.wants/nexusqd.service
}

sha512sums="SKIP"
