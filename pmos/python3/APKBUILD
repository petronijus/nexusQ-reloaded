# was briefly present, and is in 3.16
provides="pythonispython3=$pkgver-r$pkgrel"

prepare() {
	default_prepare

	# force system libs
	rm -r Modules/expat
}

build() {
	# set thread stack size to 2MB so we don't segfault before we hit
	# sys.getrecursionlimit()
	# note: raised from 1 as we ran into some stack limit on x86_64 too
	# sometimes, but not recursion
	local stacksize=0x200000

	# steelhead r4 experiment: build the interpreter core at -O0 instead of -O2.
	# The build SIGSEGVs on the real armv7 Cortex-A9 during Py_Initialize -- a GARBAGE
	# type-index (0xf0012b00) read in _PyStaticType_InitBuiltin -> wild (UNMAPPED)
	# deref. This is NOT optimization-level-dependent: two -O0 builds with
	# byte-identical .text (3,528,976 bytes, cmp-equal) differing only in data behave
	# oppositely on the SAME device -> a CPython SOURCE-level use-before-init bug, not
	# codegen (header has the full disproof list). -O0 is kept as the current
	# experiment state; it is NOT expected to be the fix. OPEN.
	export CFLAGS_NODIST="$CFLAGS -O0 -DTHREAD_STACK_SIZE=$stacksize"
	export CXXFLAGS_NODIST="$CXXFLAGS -O2"
	export LDFLAGS_NODIST="$LDFLAGS -Wl,-z,stack-size=$stacksize"

	case "$CARCH" in
	ppc64le)
		# FIXME: on ppc64le, the stack-clash-protection from gcc seems to segfault
		# python.. sometimes. not sure if python or gcc bug (probably former)
		# for an easy reproduction, run the testsuite of community/py3-lmdb
		export CFLAGS_NODIST="${CFLAGS_NODIST/-fstack-clash-protection}"
		export CXXFLAGS_NODIST="${CXXFLAGS_NODIST/-fstack-clash-protection}"
		# because test_time fails in docker on ppc64le (see check()),
		# we need to exclude that from the tests that run for PGO
		# purposes during the build, as well
		export PROFILE_TASK='-m test --pgo --timeout=$(TESTTIMEOUT) --exclude test_time'
		;;
	esac


	# we set them via NODIST to not propagate them and duplicate them to modules
	unset LDFLAGS CFLAGS CXXFLAGS CPPFLAGS

	# steelhead: deliberately NO --enable-optimizations (PGO) and NO --with-lto.
	# (PGO cannot run under our qemu armv7 build; LTO/PGO were the original -- now
	# DISPROVEN -- suspects, along with LDREXD alignment, TLSDESC, and optimization
	# level itself: two -O0 r4 builds with byte-identical .text behave oppositely on
	# the same device, so this is a CPython SOURCE-level use-before-init bug, not
	# codegen. See the header + docs/2026-06-28-session-findings.md. OPEN.)
	# Keep --with-computed-gotos for dispatch speed.
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--enable-ipv6 \
		--enable-loadable-sqlite-extensions \
		--enable-shared \
		--with-computed-gotos \
		--with-system-expat \
		--with-system-libmpdec \
		--without-ensurepip

	make
}

check() {
	# test that we reach recursionlimit before we segfault
	cat > test-stacksize.py <<-EOF
	import threading
	import sys

	def fun(i):
	  try:
	    fun(i+1)
	  except:
	    sys.exit(0)

	t = threading.Thread(target=fun, args=[1])
	t.start()
EOF
	LD_LIBRARY_PATH=$PWD ./python test-stacksize.py

	local fail
	local ignore

	# musl related
	fail="test__locale"					# various musl locale deficiencies
	fail="$fail test_locale"
	fail="$fail test_re"
	fail="$fail test_c_locale_coercion"
	fail="$fail test_datetime"				# hangs if 'tzdata' installed
	fail="$fail test_os"					# fpathconf, ttyname errno values
	ignore="test.test_strptime.StrptimeTests.test_date_locale2"

	# FIXME: failures needing investigation
	fail="$fail test_ctypes"				# fail on aarch64 (ctypes.test.test_win32.Structures)

	# kernel related
	fail="$fail test_fcntl"					# wants DNOTIFY, we don't have it

	# test_clock_settime returns Function not implemented instead of the
	# expected permission error in docker (CI). Disable for now.
	case "$CARCH" in
		ppc64le) fail="$fail test_time";;
	esac

	make quicktest TESTOPTS="-j${JOBS:-$(nproc)} --exclude $fail --ignore $ignore"
}

package() {
	make -j1 DESTDIR="$pkgdir" EXTRA_CFLAGS="$CFLAGS" install maninstall
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE

	install -Dm644 "$srcdir"/externally-managed \
		"$pkgdir"/usr/lib/python$_basever/EXTERNALLY-MANAGED

	ln -s python3 "$pkgdir"/usr/bin/python
	ln -s python3-config "$pkgdir"/usr/bin/python-config

	local size
	for size in 16 32 48 256; do
		local dir="$pkgdir"/usr/share/icons/hicolor/"$size"x"$size"/apps
		install -dm755 "$dir"
		ln -s ../../../../../lib/python3.14/idlelib/Icons/idle_$size.png "$dir"/idle.png
	done
	install -Dm0644 "$srcdir"/idle.desktop "$pkgdir"/usr/share/applications/idle.desktop
}

dev() {
	default_dev

	# pyconfig.h is needed runtime so we move it back
	mkdir -p "$pkgdir"/usr/include/python$_basever
	mv "$subpkgdir"/usr/include/python$_basever/pyconfig.h \
		"$pkgdir"/usr/include/python$_basever/
}

idle() {
	pkgdesc="IDE for Python3 using Tkinter"
	depends="$depends python3-tkinter~$pkgver"

	amove usr/bin/idle* usr/lib/python$_basever/idlelib usr/share/icons usr/share/applications
}

tests() {
	pkgdesc="The test modules from the main python package"
	provides="python3-tkinter-tests=$pkgver-r$pkgrel"

	amove usr/lib/python$_basever/test
}

_pyc_meta() {
	pkgdesc="Meta package for pulling in all -pyc packages"
	depends=""
	mkdir -p "$subpkgdir"
}

# python3-pyc, to install pyc by default
_default_pyc() {
	pkgdesc="$pkgdesc (install .pyc cache files)"
	install_if="$pkgname=$pkgver-r$pkgrel"
	provides="python3-tkinter-pyc=$pkgver-r$pkgrel"
	depends="
		$pkgname-pycache-pyc0=$pkgver-r$pkgrel
		pyc
		"

	mkdir -p "$subpkgdir"
}

pyc0() {
	pkgdesc="$pkgdesc (.pyc pycache files)"

	cd "$pkgdir"
	amove $(find usr/lib/python3* -name "*.pyc")
}

pyc1() {
	pkgdesc="$pkgdesc (.opt-1.pyc pycache files)"

	cd "$pkgdir"
	amove $(find usr/lib/python3* -name "*.opt-1.pyc")
}

pyc2() {
	pkgdesc="$pkgdesc (.opt-2.pyc pycache files)"

	cd "$pkgdir"
	amove $(find usr/lib/python3* -name "*.opt-2.pyc")
}

