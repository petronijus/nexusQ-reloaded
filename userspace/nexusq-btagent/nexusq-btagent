#!/usr/bin/env python3
"""Nexus Q Bluetooth pairing agent + pairing-exposure indicator.

The Q is an appliance: there is no keyboard, mouse or touchscreen attached to
it, so NOTHING on the device can ever answer a pairing prompt. That single fact
drives this daemon's whole design.

WHY THIS EXISTS (root-caused live 2026-07-15)
---------------------------------------------
SSP picks its pairing model from BOTH sides' IO capabilities:

    phone DisplayYesNo + Q NoInputNoOutput -> Just Works        (no prompt)
    phone DisplayYesNo + Q DisplayYesNo    -> Numeric Comparison (prompt BOTH ends)

`blueman-applet` registers a DisplayYesNo agent, which forces the second row —
so bluetoothd raised a Confirm/Deny dialog on the HDMI desktop that no attached
input device could ever click, and every bond died on timeout (mgmt status 0x0e).
This was NOT a BCM4330 limitation: pairing + A2DP were user-confirmed working
2026-07-09 (docs/2026-07-09-bluetooth-uart-max-speed-and-crackle-isolation.md)
and re-verified live 2026-07-15 the moment the applet was out of the way.

So the Q must present NoInputNoOutput and auto-accept — the ONLY model that can
complete here. This daemon owns that agent permanently (not just during setup),
because a bond is needed for BT AUDIO (A2DP) too, not only WiFi provisioning:
`nexusq-setupd` runs for minutes and exits, which would leave the appliance with
no agent and no way to pair a phone for music.

THE INVARIANT: ring <=> Pairable
--------------------------------
An auto-accept Just-Works agent bonds ANY device that asks, with no confirmation
anywhere. That is the correct trade for an input-less appliance, but it makes
"pairable" a real exposure window, so it must be VISIBLE and must not outlive its
purpose. bluez leaves Pairable=true permanently by default. The property we hold:

    ring spinning blue  ==  someone can pair with this Q
    ring not spinning   ==  nobody can

`Pairable` is the ONLY thing that gates pairing — `Discoverable` merely governs
inquiry (anyone who already knows the address can pair a non-discoverable but
pairable adapter). So the ring keys off `Pairable`, and `Pairable` is off at rest,
turned on only for as long as someone asked for a pairing window.

Pairable is forced OFF outside a window, and a window is open exactly while the
adapter is discoverable — that is how setup asks for one. bluez's own default is
Pairable=true FOREVER, so without this the Q sits permanently bondable by anyone
in range.

PAIRABLE ALSO DECIDES WHETHER A BOND LASTS — the trap
-----------------------------------------------------
`Pairable` is not only "may someone pair with us". It is also what makes a bond
DURABLE, in both directions. Measured 2026-07-15 (A/B on a real MX Master 4, same
agent, one variable):

    Pairable: no   -> pair "succeeds", Bonded: no,  NO keys stored, gone on restart
    Pairable: yes  -> pair succeeds,   Bonded: yes, [PeripheralLongTermKey] +
                      [IdentityResolvingKey] on disk, survives restart

The chain, from `bluetoothd -d` rather than from reading source: the key DOES
arrive (`new_long_term_key_callback() … new LTK … enc_size 16`), but bluez only
PERSISTS a key the kernel marked `store_hint`; the kernel only marks it so when
both sides set the SMP *bonding* bit; and our side only sets that bit under
`HCI_BONDABLE` — which is exactly `Adapter1.Pairable`.

So an OUTBOUND pair (we pair a mouse/keyboard) attempted at rest reports
"Pairing successful", connects, genuinely works — and evaporates on the next
restart, because no key was ever stored. INBOUND never had this problem: setup
opens a window first, so Pairable was on.

**Therefore: an outbound pair MUST open a window too.** Do not "fix" this by
leaving Pairable on at rest — that trades a real exposure for a convenience, and
the ring would sit lit forever, which is the same as no indicator at all.

LED OWNERSHIP
-------------
`nexusq-setupd` drives the ring itself while setup runs (blue spin, and its
connecting/success/error states), and deliberately leaves the chosen theme up on
a successful finish. This daemon therefore only touches the ring when IT took
it — i.e. the adapter became discoverable while setupd was NOT running (a manual
/ anomalous exposure, exactly the case worth showing). It never releases a ring
it did not take.

NB dbus/gi are imported inside _run() (same pattern as nexusq-setupd) so the
pure logic below stays importable — and unit-testable — on a host with no BlueZ.
"""

import json
import os
import socket
import subprocess
import sys

BLUEZ = "org.bluez"
ADAPTER_PATH = "/org/bluez/hci0"
ADAPTER_IFACE = "org.bluez.Adapter1"
DEVICE_IFACE = "org.bluez.Device1"
PROPS_IFACE = "org.freedesktop.DBus.Properties"
AGENT_PATH = "/org/nexusq/btagent"
AGENT_CAPABILITY = "NoInputNoOutput"

NEXUSQD_SOCK = os.environ.get("NEXUSQD_SOCK", "/run/nexusqd.sock")
SETUPD_UNIT = "nexusq-setupd.service"

# Our own control socket. `nexusq-control` (the LAN bridge the app talks to) is
# stdlib-only by standing rule and so cannot speak D-Bus; BlueZ knowledge lives
# here, in the one component that owns it. Newline-JSON, same envelope style as
# nexusqd's socket:
#     {"m":"openWindow","secs":120}  ->  {"ok":true,"secs":120}
# Root-only (0600): opening a pairing window is a privileged act.
CONTROL_SOCK = os.environ.get("NEXUSQ_BTAGENT_SOCK", "/run/nexusq-btagent.sock")

# A discovery scan must self-stop: a permanently scanning radio hurts BT/WiFi
# coexistence on this shared BCM4330 antenna, and WiFi is the app's own transport.
SCAN_SECS = 25

# How long `pair` waits for the target to show up before giving a clean
# "is it in pairing mode?" rather than BlueZ's raw UnknownObject.
PAIR_DISCOVER_SECS = 25

# Same stock #0099CC blue + default rate as setupd's idle spin: "open for
# pairing" must look identical whether setupd is driving it or we are.
DISCOVERABLE_CMD = "spin 0 153 204"
RELEASE_CMD = "auto"

RECONCILE_SECS = 10

# How long a pairing window may stay open, in seconds. 120 = stock steelhead's
# own DiscoverableTimeout (verified in its /system/etc/bluetooth/main.conf).
# Enforced by BLUEZ's timer, not ours, so the window still closes if this daemon
# is killed mid-window.
WINDOW_TIMEOUT = 120


def log(*a):
    print(*a, file=sys.stderr, flush=True)


def led_send(line, sock_path=NEXUSQD_SOCK):
    """Fire-and-forget to nexusqd. The ring is an indicator, never a hard dep:
    nexusqd being down must not take the BT agent down with it."""
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(2)
            s.connect(sock_path)
            s.sendall((line + "\n").encode())
        return True
    except OSError as e:
        log("nexusqd send failed:", e)
        return False


def setupd_active(run=None):
    """True while nexusq-setupd owns the ring.

    "activating" counts as active. `systemctl is-active --quiet` exits non-zero
    for a unit that is still starting, and setupd takes a moment to come up —
    during which it has ALREADY flipped the adapter to discoverable. That gap let
    us grab a ring setupd was about to drive (seen live 2026-07-15).

    Fails to FALSE — i.e. "the ring is ours" — when systemctl cannot be consulted
    (it has timed out live under load). This direction is deliberate: the ring is
    a SAFETY indicator, and the invariant that must never break is "dark ==
    nobody can pair". Assuming setupd owns the ring would make us skip it, which
    on a pairable adapter is exactly the lie this daemon exists to prevent.
    Assuming it is ours costs almost nothing: DISCOVERABLE_CMD is byte-identical
    to setupd's idle spin, so the worst case is re-sending the blue it is already
    showing, and at most a wiped theme in a rare error path. A silent dark ring
    on a bondable appliance is the worse failure.
    """
    run = run or subprocess.run
    try:
        r = run(["systemctl", "is-active", SETUPD_UNIT],
                timeout=5, capture_output=True, text=True)
        return (r.stdout or "").strip() in ("active", "activating", "reloading")
    except (OSError, subprocess.SubprocessError) as e:
        log("systemctl is-active failed; taking the ring so it cannot lie:", e)
        return False


def device_kind(icon, appearance, cls):
    """Human-facing device type for the app's list.

    Deliberately NOT derived from Class of Device alone: **BLE peripherals have
    no CoD**. Petr's MX Keys and MX Master report `Class: <none>` and would have
    been invisible in an app that filtered on it — measured 2026-07-15, twice,
    because my own scan filter hid them from me first.

    BlueZ has already done this work: `Icon` is derived from CoD *or* from the
    BLE Appearance, so it is the right primary source. Fall back to Appearance
    (0x03c1 keyboard / 0x03c2 mouse), then to the CoD major class.
    """
    icon = (icon or "").lower()
    for needle, kind in (("keyboard", "keyboard"), ("mouse", "mouse"),
                         ("headset", "headphones"), ("headphones", "headphones"),
                         ("audio", "audio"), ("phone", "phone"),
                         ("computer", "computer")):
        if needle in icon:
            return kind

    if appearance:
        # BLE Appearance: the top 10 bits are the category.
        cat = (int(appearance) >> 6) & 0x3FF
        if cat == 15:  # HID
            sub = int(appearance) & 0x3F
            return {1: "keyboard", 2: "mouse"}.get(sub, "input")
        if cat in (2, 3):
            return "phone"

    if cls:
        major = (int(cls) >> 8) & 0x1F
        return {1: "computer", 2: "phone", 4: "audio", 5: "input"}.get(major, "other")

    return "other"


def led_plan(pairable, owns_led, setup_running):
    """Pure decision: what to do with the ring. Returns (command, owns_after).

    Keyed on PAIRABLE, not Discoverable: pairable is the only thing that gates
    pairing, so it is the only honest thing to show. Split out from the D-Bus
    plumbing so these rules — the part that is easy to get subtly wrong — are
    unit-testable without a Bluetooth stack.
    """
    if setup_running:
        # setupd owns the ring OUTRIGHT while it runs: it spins its own blue and
        # then drives connecting/success/error, and on success it deliberately
        # leaves the chosen theme up. We yield unconditionally — including
        # dropping a ring we already held, WITHOUT releasing it (sending "auto"
        # here would wipe what setupd is showing). Yielding silently is also what
        # keeps us from "releasing" at the end of setup and erasing that theme.
        return None, False
    if pairable and not owns_led:
        return DISCOVERABLE_CMD, True
    if not pairable and owns_led:
        return RELEASE_CMD, False
    return None, owns_led        # nothing to do; keep current ownership


def _run():
    import dbus
    import dbus.mainloop.glib
    import dbus.service
    from gi.repository import GLib

    dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)

    class Agent(dbus.service.Object):
        """NoInputNoOutput Just-Works agent.

        With NoInputNoOutput most of these are never called (Just Works needs no
        interaction at all — the live 2026-07-15 bond completed without a single
        callback). They are all implemented anyway: an agent missing a method a
        peer's model asks for makes bluetoothd fail the bond, which is precisely
        the dead-end we are fixing. Legacy (pre-SSP) peers still ask for a PIN.
        """

        @dbus.service.method("org.bluez.Agent1", in_signature="", out_signature="")
        def Release(self):
            pass

        @dbus.service.method("org.bluez.Agent1", in_signature="ou", out_signature="")
        def RequestConfirmation(self, device, passkey):
            log("pairing: auto-confirming", device)

        @dbus.service.method("org.bluez.Agent1", in_signature="o", out_signature="")
        def RequestAuthorization(self, device):
            log("pairing: auto-authorizing", device)

        @dbus.service.method("org.bluez.Agent1", in_signature="os", out_signature="")
        def AuthorizeService(self, device, uuid):
            log("service: auto-authorizing", device, uuid)

        @dbus.service.method("org.bluez.Agent1", in_signature="o", out_signature="s")
        def RequestPinCode(self, device):
            log("pairing: legacy PIN requested by", device)
            return "0000"

        @dbus.service.method("org.bluez.Agent1", in_signature="o", out_signature="u")
        def RequestPasskey(self, device):
            log("pairing: passkey requested by", device)
            return dbus.UInt32(0)

        @dbus.service.method("org.bluez.Agent1", in_signature="ouq", out_signature="")
        def DisplayPasskey(self, device, passkey, entered):
            pass

        @dbus.service.method("org.bluez.Agent1", in_signature="os", out_signature="")
        def DisplayPinCode(self, device, pincode):
            pass

        @dbus.service.method("org.bluez.Agent1", in_signature="", out_signature="")
        def Cancel(self):
            log("pairing: cancelled by remote")

    class Daemon:
        def __init__(self, bus):
            self.bus = bus
            self.agent = None
            self.owns_led = False
            self.registered = False

        def _props(self, path=ADAPTER_PATH):
            return dbus.Interface(self.bus.get_object(BLUEZ, path), PROPS_IFACE)

        def _get(self, name, path=ADAPTER_PATH, iface=ADAPTER_IFACE):
            return self._props(path).Get(iface, name)

        def _set(self, name, value, path=ADAPTER_PATH, iface=ADAPTER_IFACE):
            self._props(path).Set(iface, name, value)

        def arm_window_timeout(self):
            """Make the pairing window close ITSELF, in bluez, not in us.

            bluez expires Pairable/Discoverable on its own timers. Setting them
            once means a window shuts even if this daemon is killed mid-window —
            the fail-safe direction. A timer of ours would die with us and leave
            the Q pairable forever, which is the whole failure this ring exists
            to make impossible.

            setupd deliberately sets both timeouts to 0 (never expire) for the
            duration of onboarding, because a wizard that goes non-pairable
            halfway through is worse than a longer window; it closes them on the
            way out. So only arm defaults when setup is NOT running.
            """
            if setupd_active():
                return
            try:
                # NEVER touch the timeouts while a window is OPEN. Writing
                # DiscoverableTimeout restarts bluez's countdown, so this tick
                # (every 10 s) used to both overwrite a caller's requested
                # duration — openWindow(30) silently became 120 — and keep
                # kicking the timer, so `startPairing` lied about its own window.
                # Only arm the default while the adapter is at rest.
                if bool(self._get("Discoverable")):
                    return
                for prop in ("PairableTimeout", "DiscoverableTimeout"):
                    if int(self._get(prop)) != WINDOW_TIMEOUT:
                        self._set(prop, dbus.UInt32(WINDOW_TIMEOUT))
                        log(f"{prop} -> {WINDOW_TIMEOUT}s (default for the next window)")
            except dbus.DBusException as e:
                log("could not arm window timeouts:", e)

        def register(self):
            """(Re)register with bluetoothd. Idempotent and safe to retry:
            bluetoothd drops every agent when it restarts, and it may well start
            after us."""
            try:
                if self.agent is None:
                    self.agent = Agent(self.bus, AGENT_PATH)
                am = dbus.Interface(self.bus.get_object(BLUEZ, "/org/bluez"),
                                    "org.bluez.AgentManager1")
                try:
                    am.UnregisterAgent(AGENT_PATH)
                except dbus.DBusException:
                    pass  # not registered yet — the normal path
                am.RegisterAgent(AGENT_PATH, AGENT_CAPABILITY)
                # Last RequestDefaultAgent caller wins. blueman-applet's
                # DisplayYesNo agent is kept out of autostart by the device
                # package for exactly this reason; if it is ever started by hand
                # it steals the default and pairing breaks again (see header).
                am.RequestDefaultAgent(AGENT_PATH)
                self.registered = True
                log(f"agent registered as default ({AGENT_CAPABILITY})")
            except dbus.DBusException as e:
                self.registered = False
                log("agent registration failed (will retry):", e)
                return False
            return True

        def reconcile(self):
            try:
                pairable = bool(self._get("Pairable"))
                discoverable = bool(self._get("Discoverable"))
            except dbus.DBusException:
                return True  # no adapter (yet); the tick / signals retry

            # A pairing window is OPEN exactly while the adapter is discoverable:
            # that is how setup asks for one, and (until the bridge gains an
            # explicit request) how anything else must ask too — including an
            # outbound pair, which needs Pairable to produce a DURABLE bond.
            #
            # Outside a window we force Pairable OFF. bluez's default is
            # Pairable=true forever, so without this the Q would sit permanently
            # bondable by anyone in range, with the ring honestly but uselessly
            # lit the whole time. Closing it is the point.
            if pairable != discoverable:
                log(f"enforcing Pairable={discoverable} (was {pairable})")
                try:
                    self._set("Pairable", dbus.Boolean(discoverable))
                    pairable = discoverable
                except dbus.DBusException as e:
                    log("could not set Pairable:", e)

            # The ring keys off PAIRABLE, not Discoverable — Pairable is the only
            # property that gates pairing, so it is the only honest thing to
            # show. (They track each other today; keying off the real gate means
            # the ring stays correct when the bridge learns to open a window
            # without announcing us.)
            cmd, owns = led_plan(pairable, self.owns_led, setupd_active())
            if cmd is not None:
                log("ring ON: adapter is PAIRABLE — anyone can pair" if owns
                    else "ring released: adapter no longer pairable")
                if led_send(cmd) or not owns:
                    # Only claim ownership if nexusqd actually took the command;
                    # releasing is unconditional (we are giving the ring up).
                    self.owns_led = owns
            return True

        def _on_device_props(self, iface, changed, invalidated, path=None):
            if iface != DEVICE_IFACE or not changed.get("Paired"):
                return
            # Trust the bond so its profiles (A2DP above all) reconnect on their
            # own later without re-asking for service authorization.
            try:
                self._set("Trusted", dbus.Boolean(True), path=path,
                          iface=DEVICE_IFACE)
                log(f"bonded {self._get('Address', path=path, iface=DEVICE_IFACE)}"
                    " -> Trusted")
            except dbus.DBusException as e:
                log("could not trust newly bonded device:", e)

        def _on_adapter_props(self, iface, changed, invalidated, path=None):
            if iface == ADAPTER_IFACE and ("Discoverable" in changed
                                           or "Pairable" in changed):
                self.reconcile()

        def _on_bluez_owner(self, name, old, new):
            if not new:
                log("bluetoothd went away; agent dropped")
                self.registered = False
                self.owns_led = False  # ring state is meaningless with no adapter
                return
            log("bluetoothd appeared; re-registering")
            self.register()
            self.reconcile()

        def _tick(self):
            if not self.registered:
                self.register()
            self.arm_window_timeout()
            self.reconcile()
            self.start_control()
            return True

        # --- control socket (the LAN bridge's only way into BlueZ) ----------
        def _devices(self, paired_only=False):
            """Snapshot of known devices, already typed for the app."""
            out = []
            try:
                om = dbus.Interface(self.bus.get_object(BLUEZ, "/"),
                                    "org.freedesktop.DBus.ObjectManager")
                objs = om.GetManagedObjects()
            except dbus.DBusException:
                return out
            for path, ifaces in objs.items():
                d = ifaces.get(DEVICE_IFACE)
                if not d:
                    continue
                if paired_only and not d.get("Paired"):
                    continue
                addr = str(d.get("Address", ""))
                # NB: BlueZ synthesises `Alias` from the ADDRESS ("6B-64-CB-F3-81-98")
                # when a device has no name, so `Alias` is never empty and cannot
                # be used to test "does this have an identity". Only a real `Name`
                # counts; anything else is anonymous.
                name = str(d.get("Name", "") or "")
                if not name:
                    alias = str(d.get("Alias", "") or "")
                    if alias.replace("-", ":").upper() != addr.upper():
                        name = alias  # a user-set alias IS an identity
                icon = str(d.get("Icon", "") or "")
                appearance = d.get("Appearance")
                cls = d.get("Class")
                # Anonymous BLE beacons are noise — a 25 s scan sees ~38 of them
                # (measured), most of them the neighbours'. A wall of bare MACs is
                # unusable on a screenless appliance, so only surface things with
                # a real identity.
                if not paired_only and not (name or icon or appearance):
                    continue
                out.append({
                    "mac": addr,
                    "name": name,
                    "kind": device_kind(icon, appearance, cls),
                    "rssi": int(d.get("RSSI", 0)) if d.get("RSSI") is not None else None,
                    "paired": bool(d.get("Paired", False)),
                    "bonded": bool(d.get("Bonded", False)),
                    "connected": bool(d.get("Connected", False)),
                })
            out.sort(key=lambda x: (not x["paired"], x["kind"] == "other",
                                    -(x["rssi"] or -200)))
            return out

        def _dev_path(self, mac):
            return f"{ADAPTER_PATH}/dev_" + mac.upper().replace(":", "_")

        def _open_window(self, secs):
            """Open a pairing window: discoverable + (via reconcile) pairable.

            This is the ONE mechanism for both directions. An OUTBOUND pair needs
            it too — not to be allowed (Pairable: no does not block an outgoing
            Pair()), but to be DURABLE: Pairable -> HCI_BONDABLE -> the SMP
            bonding bit -> the kernel marks the key persistent -> bluez stores it.
            Without it a mouse pairs, works, and is gone after a reboot.
            """
            secs = max(1, min(int(secs or WINDOW_TIMEOUT), 600))
            self._set("DiscoverableTimeout", dbus.UInt32(secs))
            self._set("PairableTimeout", dbus.UInt32(secs))
            self._set("Discoverable", dbus.Boolean(True))
            self.reconcile()
            return secs

        def _close_window(self):
            self._set("Discoverable", dbus.Boolean(False))
            self.reconcile()

        def _ctl(self, req, reply):
            """Handle one control request. `reply` may be called later (async)."""
            m = req.get("m")
            mac = req.get("mac")

            if m == "openWindow":
                secs = self._open_window(req.get("secs", WINDOW_TIMEOUT))
                return reply({"ok": True, "secs": secs})
            if m == "closeWindow":
                self._close_window()
                return reply({"ok": True})
            if m == "windowState":
                return reply({"open": bool(self._get("Pairable")),
                              "discoverable": bool(self._get("Discoverable"))})
            if m == "startScan":
                secs = max(5, min(int(req.get("secs", SCAN_SECS)), 60))
                try:
                    dbus.Interface(self.bus.get_object(BLUEZ, ADAPTER_PATH),
                                   ADAPTER_IFACE).StartDiscovery()
                except dbus.DBusException as e:
                    if "InProgress" not in str(e):
                        return reply({"error": "unavailable", "message": str(e)})
                # Self-stopping: a scan that outlives the request would keep the
                # radio busy behind the user's back.
                GLib.timeout_add_seconds(secs, self._stop_scan_once)
                return reply({"ok": True, "secs": secs})
            if m == "stopScan":
                self._stop_scan_once()
                return reply({"ok": True})
            if m == "scanResults":
                return reply({"devices": self._devices()})
            if m == "listPaired":
                return reply({"devices": self._devices(paired_only=True)})
            if m == "remove":
                try:
                    dbus.Interface(self.bus.get_object(BLUEZ, ADAPTER_PATH),
                                   ADAPTER_IFACE).RemoveDevice(self._dev_path(mac))
                    return reply({"removed": True})
                except dbus.DBusException as e:
                    return reply({"error": "not_found", "message": str(e)})
            if m in ("connect", "disconnect"):
                try:
                    dev = dbus.Interface(self.bus.get_object(BLUEZ, self._dev_path(mac)),
                                         DEVICE_IFACE)
                    (dev.Connect if m == "connect" else dev.Disconnect)(timeout=30)
                    return reply({"ok": True})
                except dbus.DBusException as e:
                    return reply({"error": "unavailable", "message": str(e)})
            if m == "pair":
                return self._pair_async(mac, reply)
            return reply({"error": "unknown_method", "message": str(m)})

        def _stop_scan_once(self):
            try:
                dbus.Interface(self.bus.get_object(BLUEZ, ADAPTER_PATH),
                               ADAPTER_IFACE).StopDiscovery()
            except dbus.DBusException:
                pass  # already stopped
            return False  # one-shot timer

        def _pair_async(self, mac, reply):
            """Pair -> Trust -> Connect, without blocking the main loop.

            Pair() takes seconds and our Agent1 must answer DURING it — a
            synchronous call would deadlock the very agent that completes the
            pairing. Hence reply_handler/error_handler.

            The window is opened first and left to bluez's timer: that is what
            makes the bond durable (see _open_window).
            """
            self._open_window(WINDOW_TIMEOUT)

            # BlueZ forgets an unpaired device object shortly after discovery
            # stops, so by the time the user taps "Pair" in the app the object
            # from their scan is usually GONE (measured: Pair -> UnknownObject).
            # Own the discovery here instead of trusting a previous scan.
            try:
                dbus.Interface(self.bus.get_object(BLUEZ, ADAPTER_PATH),
                               ADAPTER_IFACE).StartDiscovery()
            except dbus.DBusException as e:
                if "InProgress" not in str(e):
                    log("pair: could not start discovery:", e)

            deadline = [PAIR_DISCOVER_SECS]

            def attempt():
                try:
                    # Probe by READING A PROPERTY. (Introspect() is not a Device1
                    # method — using it here made this test throw every time and
                    # report "not advertising" for a device that was right there.)
                    self._get("Address", path=self._dev_path(mac), iface=DEVICE_IFACE)
                    dev = dbus.Interface(
                        self.bus.get_object(BLUEZ, self._dev_path(mac)), DEVICE_IFACE)
                except dbus.DBusException:
                    deadline[0] -= 1
                    if deadline[0] > 0:
                        return True  # keep waiting for it to advertise
                    self._stop_scan_once()
                    reply({"error": "not_found",
                           "message": "device not advertising — is it in pairing mode?"})
                    return False
                _pair_now(dev)
                return False

            def _pair_now(dev):

                def done():
                    self._stop_scan_once()
                    # Close the window we opened FOR this pair. Leaving it up for
                    # the rest of its 120 s leaves the Q pairable by anyone with
                    # nothing left to pair — the ring would be honest and the
                    # exposure pointless. (Petr caught this: "after a successful
                    # pairing the search should close and pairing should stop".)
                    self._close_window()
                    try:
                        self._set("Trusted", dbus.Boolean(True),
                                  path=self._dev_path(mac), iface=DEVICE_IFACE)
                    except dbus.DBusException:
                        pass
                    try:
                        dev.Connect(timeout=30)
                    except dbus.DBusException as e:
                        log("paired but connect failed:", e)
                    info = next((d for d in self._devices()
                                 if d["mac"].upper() == mac.upper()), {})
                    # `bonded` is the honest answer to "will this survive a
                    # reboot?" — `paired` alone LIES: it is true for a
                    # session-only pairing that evaporates on restart.
                    log(f"paired {mac} bonded={info.get('bonded')}")
                    reply({"paired": True, "bonded": bool(info.get("bonded")),
                           "connected": bool(info.get("connected"))})

                def failed(e):
                    self._stop_scan_once()
                    # "AlreadyExists" means it is already paired — that is the
                    # outcome the caller wanted, not an error. Reporting it as a
                    # failure made the app cry "something went wrong" over a
                    # device that had just paired perfectly.
                    if "AlreadyExists" in str(e):
                        self._close_window()
                        info = next((d for d in self._devices()
                                     if d["mac"].upper() == mac.upper()), {})
                        return reply({"paired": True,
                                      "bonded": bool(info.get("bonded")),
                                      "connected": bool(info.get("connected"))})
                    self._close_window()
                    log("pair failed:", e)
                    reply({"error": "pair_failed", "message": str(e)})

                dev.Pair(reply_handler=done, error_handler=failed, timeout=90)

            GLib.timeout_add_seconds(1, attempt)

        def _serve(self, sock, _cond):
            try:
                conn, _ = sock.accept()
            except OSError:
                return True
            conn.settimeout(5)
            try:
                data = conn.recv(4096).decode(errors="replace").strip()
                req = json.loads(data) if data else {}
            except (OSError, ValueError):
                conn.close()
                return True

            replied = [False]

            def reply(obj):
                if replied[0]:
                    return
                replied[0] = True
                try:
                    conn.sendall((json.dumps(obj) + "\n").encode())
                finally:
                    conn.close()

            try:
                self._ctl(req, reply)
            except dbus.DBusException as e:
                reply({"error": "unavailable", "message": str(e)})
            except Exception as e:  # noqa: BLE001 — a bad request must not kill the agent
                log("control error:", e)
                reply({"error": "internal", "message": str(e)})
            return True

        def start_control(self):
            try:
                os.unlink(CONTROL_SOCK)
            except OSError:
                pass
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.bind(CONTROL_SOCK)
            os.chmod(CONTROL_SOCK, 0o600)  # opening a pairing window is privileged
            s.listen(4)
            s.setblocking(False)
            GLib.io_add_watch(s, GLib.IO_IN, self._serve)
            log("control socket:", CONTROL_SOCK)

        def run(self):
            self.bus.add_signal_receiver(
                self._on_device_props, dbus_interface=PROPS_IFACE,
                signal_name="PropertiesChanged", arg0=DEVICE_IFACE,
                path_keyword="path")
            self.bus.add_signal_receiver(
                self._on_adapter_props, dbus_interface=PROPS_IFACE,
                signal_name="PropertiesChanged", arg0=ADAPTER_IFACE,
                path_keyword="path")
            self.bus.add_signal_receiver(
                self._on_bluez_owner, dbus_interface="org.freedesktop.DBus",
                signal_name="NameOwnerChanged", arg0=BLUEZ)

            self.register()
            self.arm_window_timeout()
            self.reconcile()
            self.start_control()
            # Backstop only: the signals above do the work; this covers a missed
            # signal, a late adapter, or a bluetoothd that outlives our agent.
            GLib.timeout_add_seconds(RECONCILE_SECS, self._tick)
            GLib.MainLoop().run()

    Daemon(dbus.SystemBus()).run()


def main():
    _run()
    return 0


if __name__ == "__main__":
    sys.exit(main())
