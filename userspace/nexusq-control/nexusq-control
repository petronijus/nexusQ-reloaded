#!/usr/bin/env python3
"""nexusq-control — LAN control bridge for the postmarketOS Nexus Q.

Implements the v1 companion protocol (companion/PROTOCOL.md): newline-delimited
JSON over TCP. It is the single LAN endpoint the Flutter companion talks to, and
it fans the work out to the device subsystems that already exist:

  - output selection     -> PulseAudio default sink  (pactl; PA is the audio hub
                            and every INPUT is a PA client, every OUTPUT a sink —
                            switching = set-default-sink + move all sink-inputs)
  - volume / mute        -> the active output's PA sink  (pactl set-sink-volume/
                            set-sink-mute; input-agnostic, follows the output)
  - LED theme / brightness -> nexusqd control socket  (/run/nexusqd.sock)
  - now-playing            -> librespot --onevent hook pushes metadata + volume
                            in over a local unix socket (read-only metadata,
                            faithful to the original app)

Stdlib only (the device ships python3 via pmos/python3). Threaded: a TCP accept
loop, a unix accept loop for the librespot hook, and one handler thread per
client. State is shared under a lock; device events are broadcast to all clients.

Config via env:
  NEXUSQ_BIND_HOST     (default 0.0.0.0)
  NEXUSQ_BIND_PORT     (default 45015)
  NEXUSQ_MIXER_CARD    (default NexusQSpeaker)  # ALSA card for the amp safety toggle
  NEXUSQ_AMP_CTRL      (default Speaker)        # class-D amp on/off control on that card
  NEXUSQ_PULSE_SERVER  (default unix:/run/user/10000/pulse/native)  # user-session PA
  NEXUSQ_PULSE_COOKIE  (default /home/user/.config/pulse/cookie)    # lets root reach it
  NEXUSQD_SOCK         (default /run/nexusqd.sock)
  NEXUSQ_HOOK_SOCK     (default /run/nexusq-control.sock)
  NEXUSQ_NAME          (default "Nexus Q")     # fallback when device.json is absent
  NEXUSQ_IDENTITY      (default /etc/nexusq/device.json)  # {"name","room"} written
                                                            # by nexusq-setupd's setName
"""
import json
import os
import re
import socket
import subprocess
import threading
import time

HOST = os.environ.get("NEXUSQ_BIND_HOST", "0.0.0.0")
PORT = int(os.environ.get("NEXUSQ_BIND_PORT", "45015"))
MIXER_CARD = os.environ.get("NEXUSQ_MIXER_CARD", "NexusQSpeaker")
AMP_CTRL = os.environ.get("NEXUSQ_AMP_CTRL", "Speaker")
# PulseAudio runs in the uid-10000 `user` session; root reaches it with the user's
# cookie (verified). Both overridable, like MIXER_CARD.
PULSE_SERVER = os.environ.get("NEXUSQ_PULSE_SERVER", "unix:/run/user/10000/pulse/native")
PULSE_COOKIE = os.environ.get("NEXUSQ_PULSE_COOKIE", "/home/user/.config/pulse/cookie")
NEXUSQD_SOCK = os.environ.get("NEXUSQD_SOCK", "/run/nexusqd.sock")
HOOK_SOCK = os.environ.get("NEXUSQ_HOOK_SOCK", "/run/nexusq-control.sock")
IDENTITY_PATH = os.environ.get("NEXUSQ_IDENTITY", "/etc/nexusq/device.json")
SETUP_FORCE_FLAG = "/run/nexusq-setup.force"


def load_identity(path=None):
    """Device identity {name, room}: /etc/nexusq/device.json (written by
    nexusq-setupd's setName) > NEXUSQ_NAME env > defaults. Resilient: a
    missing/corrupt file can never take the bridge down."""
    ident = {"name": os.environ.get("NEXUSQ_NAME", "Nexus Q"), "room": ""}
    try:
        with open(path or IDENTITY_PATH) as f:
            data = json.load(f)
        if isinstance(data.get("name"), str) and data["name"].strip():
            ident["name"] = data["name"].strip()
        if isinstance(data.get("room"), str):
            ident["room"] = data["room"].strip()
    except (OSError, ValueError):
        pass
    return ident


_IDENT = load_identity()
DEVICE_NAME = _IDENT["name"]
DEVICE_ROOM = _IDENT["room"]
# The LXQt panel volume applet pins to a device INDEX ([volume] device=N in
# panel.conf), it does not follow PA's default sink — we re-link it on every
# output switch (see _sync_panel_applet). The appliance's canonical output after
# boot is the speaker (PA itself would pick sink #0, probe-order dependent).
PANEL_CONF = os.environ.get("NEXUSQ_PANEL_CONF", "/home/user/.config/lxqt/panel.conf")
BOOT_OUTPUT = os.environ.get("NEXUSQ_BOOT_OUTPUT", "speaker")

# Known PulseAudio sinks → a stable id + Czech-friendly label. Matched by substring
# against the PA sink name (e.g. alsa_output.platform-sound-tas5713.stereo-fallback)
# so we tolerate profile-suffix drift. Order = the app's display order. This mapping
# is INPUT-AGNOSTIC: any input (librespot now; BT-A2DP / Tidal / casting later) is a
# PA client whose stream we move onto whichever of these sinks is the active output.
OUTPUTS = [
    {"id": "speaker", "label": "Reproduktor",    "match": "tas5713"},
    {"id": "spdif",   "label": "Optický výstup", "match": "spdif"},
    {"id": "hdmi",    "label": "HDMI",           "match": "hdmi"},
]
OUTPUT_BY_ID = {o["id"]: o for o in OUTPUTS}

THEMES = [
    {"name": "blue", "label": "Blue"},
    {"name": "warm", "label": "Warm"},
    {"name": "cool", "label": "Cool"},
    {"name": "rose", "label": "Rose"},
    {"name": "smoke", "label": "Smoke"},
    {"name": "off", "label": "Off"},
]

# A color theme is a *breathing* override: nexusqd's `breathe R G B` pulses the ring
# gently in the theme's hue (same throb as the idle screensaver breathe) at
# compositor priority 8, so it is ALWAYS visible — even while music plays or after
# the idle screensaver has blanked. Picking a visualisation (SCENES) sends `auto`,
# which clears this override so the audio-reactive scene shows. "off" blanks the ring.
THEME_CMDS = {
    "blue":  ["breathe 0 153 204"],   # the original #0099CC breathe hue
    "warm":  ["breathe 255 90 10"],
    "cool":  ["breathe 0 200 140"],
    "rose":  ["breathe 255 40 90"],
    "smoke": ["breathe 110 115 135"],
    "off":   ["off"],
}

# The 5 audio-reactive music visualisations, in nexusqd's RenderEngine order
# (userspace/nexusqd music.c: scene 0..4). setScene selects which effect the ring
# shows while audio plays. It also sends `auto` first so any solid color-theme
# override (a `set R G B` from setTheme, compositor priority 8) is cleared and the
# visualiser (priority 7) is actually visible.
SCENES = [
    {"name": "waveform",      "label": "Waveform",   "index": 0},
    {"name": "waveformsolid", "label": "Solid Wave", "index": 1},
    {"name": "circles",       "label": "Circles",    "index": 2},
    {"name": "pointmorph",    "label": "Morph",      "index": 3},
    {"name": "starfield",     "label": "Starfield",  "index": 4},
]
SCENE_INDEX = {s["name"]: s["index"] for s in SCENES}


def log(*a):
    print("[nexusq-control]", *a, flush=True)


def _pactl(*args, timeout=4):
    """Run pactl against the uid-10000 user PulseAudio (root uses the user cookie)."""
    return subprocess.run(
        ["pactl", *args],
        env={**os.environ, "PULSE_SERVER": PULSE_SERVER, "PULSE_COOKIE": PULSE_COOKIE},
        capture_output=True, text=True, timeout=timeout,
    )


def _amixer(*args, timeout=4):
    """Run amixer on the speaker card (used only for the class-D amp safety toggle)."""
    return subprocess.run(
        ["amixer", "-c", MIXER_CARD, *args],
        capture_output=True, text=True, timeout=timeout,
    )


def _sync_panel_applet(sink):
    """Re-link the LXQt panel volume applet to the active output's sink.

    The applet does NOT follow PA's default sink — it pins to a device index
    ([volume] device=N in panel.conf, N = the sink's position in PA's sink
    list, which is probe-order dependent, so we compute it at switch time).
    lxqt-panel watches panel.conf and applies the change live (verified
    2026-07-07), so the tray icon always shows/controls the selected output.
    Best-effort: silently skip when the panel config does not exist yet
    (fresh home before first login) or PA is unreachable; never let this
    break output switching.
    """
    try:
        if not PANEL_CONF or not os.path.isfile(PANEL_CONF):
            return
        r = _pactl("list", "short", "sinks")
        if r.returncode != 0:
            return
        idx = None
        rows = [l for l in r.stdout.splitlines() if l.strip()]
        for i, ln in enumerate(rows):
            if sink in ln.split():
                idx = i
                break
        if idx is None:
            return
        with open(PANEL_CONF) as f:
            lines = f.read().splitlines()
        out, in_vol, done = [], False, False
        for ln in lines:
            s = ln.strip()
            if s.startswith("["):
                if in_vol and not done:
                    out.append(f"device={idx}")
                    done = True
                in_vol = (s == "[volume]")
                out.append(ln)
                continue
            if in_vol and re.match(r"\s*device\s*=", ln):
                if not done:
                    out.append(f"device={idx}")
                    done = True
                continue
            out.append(ln)
        if in_vol and not done:
            out.append(f"device={idx}")
            done = True
        if not done:
            out += ["", "[volume]", f"device={idx}"]
        with open(PANEL_CONF, "w") as f:  # in-place: keeps the user's owner/mode
            f.write("\n".join(out) + "\n")
    except Exception as e:  # noqa: BLE001
        log("panel applet sync failed:", e)


class Pulse:
    """pactl access to the user-session PulseAudio: enumerate sinks, read/set the
    default sink, and move sink-inputs. Resilient — a pactl hiccup never throws,
    it degrades to empty/None so it can't take down the bridge."""

    def sinks(self):
        """Return the list of PA sink names (`pactl list short sinks`), or []."""
        try:
            r = _pactl("list", "short", "sinks")
            if r.returncode != 0:
                return []
            names = []
            for ln in r.stdout.splitlines():
                cols = ln.split("\t")
                if len(cols) >= 2 and cols[1].strip():
                    names.append(cols[1].strip())
            return names
        except Exception as e:  # noqa: BLE001 - never let pactl kill the bridge
            log("pactl list sinks failed:", e)
            return []

    def default_sink(self):
        try:
            r = _pactl("get-default-sink")
            if r.returncode == 0:
                return r.stdout.strip() or None
        except Exception as e:  # noqa: BLE001
            log("pactl get-default-sink failed:", e)
        return None

    def set_default_sink(self, sink):
        try:
            _pactl("set-default-sink", sink)
        except Exception as e:  # noqa: BLE001
            log("pactl set-default-sink failed:", e)

    def set_default_source(self, source):
        """Point PA's default SOURCE at `source` (we use `<sink>.monitor` of the
        active output). This is what makes the nexusqd visualizer tap — `arecord -D
        pulse`, which captures the PA DEFAULT SOURCE — follow the selected output:
        the default source does NOT auto-track the default sink, so we steer it
        here on every output change / at startup. Resilient: a failure here must
        never break output selection (worst case the ring taps the previous
        output's monitor until the next switch)."""
        try:
            _pactl("set-default-source", source)
        except Exception as e:  # noqa: BLE001
            log("pactl set-default-source failed:", e)

    def sink_input_ids(self):
        """Return the ids of every current sink-input (`pactl list short sink-inputs`)."""
        try:
            r = _pactl("list", "short", "sink-inputs")
            if r.returncode != 0:
                return []
            ids = []
            for ln in r.stdout.splitlines():
                cols = ln.split("\t")
                if cols and cols[0].strip():
                    ids.append(cols[0].strip())
            return ids
        except Exception as e:  # noqa: BLE001
            log("pactl list sink-inputs failed:", e)
            return []

    def move_all_inputs(self, sink):
        """Move every existing sink-input onto `sink` so a live stream follows the
        output switch. Input-agnostic: works for any PA client."""
        for sid in self.sink_input_ids():
            try:
                _pactl("move-sink-input", sid, sink)
            except Exception as e:  # noqa: BLE001
                log("pactl move-sink-input failed:", sid, e)


class Mixer:
    """Volume/mute on a *given PA sink* via pactl (0..100 + mute). The active
    output's sink is passed in, so volume is input-agnostic and follows the output.

    NOTE: the TAS5713 class-D amp has a very hot/steep gain (app ~8% is already
    deafening); a usable-range gain cap on the TAS5713 Master/Speaker control is a
    known follow-up tuning — we apply a plain linear pactl percentage for now."""

    _pct = re.compile(r"(\d{1,3})%")

    def get(self, sink):
        """Return (volume 0..100, muted) for `sink`, or (None, None) on failure."""
        if not sink:
            return None, None
        try:
            rv = _pactl("get-sink-volume", sink)
            rm = _pactl("get-sink-mute", sink)
            vol = None
            if rv.returncode == 0:
                m = self._pct.search(rv.stdout)  # first %: the volume (dB has no %)
                vol = int(m.group(1)) if m else None
            muted = "yes" in rm.stdout.lower() if rm.returncode == 0 else False
            return vol, muted
        except Exception as e:  # noqa: BLE001 - never let a mixer hiccup kill the bridge
            log("pactl get volume failed:", e)
            return None, None

    def set_volume(self, sink, pct):
        if not sink:
            return
        pct = max(0, min(100, int(pct)))
        try:
            _pactl("set-sink-volume", sink, f"{pct}%")
            _pactl("set-sink-mute", sink, "0")  # setting a level implies unmute
        except Exception as e:  # noqa: BLE001
            log("pactl set volume failed:", e)

    def set_muted(self, sink, muted):
        if not sink:
            return
        try:
            _pactl("set-sink-mute", sink, "1" if muted else "0")
        except Exception as e:  # noqa: BLE001
            log("pactl set mute failed:", e)


def nexusqd_send(line):
    """Send one command line to nexusqd's control socket; return True on 'ok'."""
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(2)
            s.connect(NEXUSQD_SOCK)
            s.sendall((line + "\n").encode())
            return s.recv(64).startswith(b"ok")
    except OSError as e:
        log("nexusqd send failed:", e)
        return False


class Bridge:
    def __init__(self):
        self.pulse = Pulse()
        self.mixer = Mixer()
        self.lock = threading.Lock()
        self.clients = {}          # id -> socket
        self._next_id = 0
        # Seed the active output from PA's current default sink (fall back to speaker),
        # then read volume/mute off that sink.
        output = self._output_for_sink(self.pulse.default_sink()) or "speaker"
        init_sink = self._sink_for_output(output) or self.pulse.default_sink()
        vol, muted = self.mixer.get(init_sink)
        # Seed PA's default SOURCE to the active output's monitor so the nexusqd LED
        # visualizer taps the active mix from the very first boot, before any
        # setOutput. `arecord -D pulse` captures the default source, which does not
        # auto-track the default sink — we keep it steered here and on every switch.
        if init_sink:
            self.pulse.set_default_source(init_sink + ".monitor")
        self.state = {
            "volume": vol if vol is not None else 50,
            "muted": bool(muted),
            "brightness": 255,
            "theme": "blue",
            "scene": "waveform",
            "output": output,
            "nowPlaying": {"playing": False, "artist": "", "track": "",
                           "album": "", "artUrl": "", "source": ""},
            "name": DEVICE_NAME,
        }
        # Boot default OUTPUT: on a fresh boot PA's default is just its first
        # sink (probe-order dependent — often the SPDIF), but this appliance's
        # canonical output is the speaker. Steer to BOOT_OUTPUT once PA is up:
        # the bridge is a system service that starts well before the user
        # session's PulseAudio, so retry in the background (~90 s), then give
        # up quietly (setOutput from the app still works). Applying via
        # _set_output keeps everything consistent (streams moved, amp toggle,
        # LED-tap monitor source, tray-icon link, state + no clients yet).
        def _boot_output():
            if BOOT_OUTPUT not in OUTPUT_BY_ID:
                return
            for _ in range(45):
                try:
                    if self._sink_for_output(BOOT_OUTPUT):
                        self._set_output({"output": BOOT_OUTPUT})
                        log("boot output ->", BOOT_OUTPUT)
                        return
                except Exception:  # noqa: BLE001 - PA not up yet; retry
                    pass
                time.sleep(2)
            log("boot output: PA never became ready, leaving PA's default")
        threading.Thread(target=_boot_output, daemon=True).start()

    # --- output/sink resolution -----------------------------------------
    def _sink_for_output(self, oid):
        """Resolve an output id (speaker/spdif/hdmi) to a present PA sink name, or None."""
        o = OUTPUT_BY_ID.get(oid)
        if o is None:
            return None
        return next((n for n in self.pulse.sinks() if o["match"] in n), None)

    def _output_for_sink(self, sink):
        """Reverse-map a PA sink name to a known output id, or None if unrecognised."""
        if not sink:
            return None
        return next((o["id"] for o in OUTPUTS if o["match"] in sink), None)

    def _active_sink(self):
        """The PA sink of the currently-selected output (fall back to PA's default)."""
        with self.lock:
            oid = self.state.get("output")
        return (self._sink_for_output(oid) if oid else None) or self.pulse.default_sink()

    # --- client registry / broadcast ------------------------------------
    def add_client(self, sock):
        with self.lock:
            cid = self._next_id
            self._next_id += 1
            self.clients[cid] = sock
        return cid

    def remove_client(self, cid):
        with self.lock:
            self.clients.pop(cid, None)

    def broadcast(self, event, data):
        msg = (json.dumps({"event": event, "data": data}) + "\n").encode()
        with self.lock:
            dead = []
            for cid, sock in self.clients.items():
                try:
                    sock.sendall(msg)
                except OSError:
                    dead.append(cid)
            for cid in dead:
                self.clients.pop(cid, None)

    # --- request dispatch ------------------------------------------------
    def handle(self, method, params):
        """Return (result, events) where events is a list of (name, data) to
        broadcast *after* the response is sent (ack precedes async events)."""
        p = params or {}
        if method == "subscribe":
            return {"subscribed": ["*"]}, []
        if method == "getState":
            with self.lock:
                return dict(self.state), []
        if method == "getDeviceInfo":
            return {"name": DEVICE_NAME, "model": "steelhead", "room": DEVICE_ROOM,
                    "serial": _serial(), "swVersion": _sw_version()}, []
        if method in ("setVolume", "adjustVolume", "setMuted", "toggleMute"):
            return self._volume_cmd(method, p)
        if method == "listOutputs":
            return self._list_outputs(), []
        if method == "setOutput":
            return self._set_output(p)
        if method == "setTheme":
            name = str(p.get("theme", ""))
            cmds = THEME_CMDS.get(name)
            if cmds is None:
                raise Err("bad_request", f"unknown theme {name}")
            for c in cmds:
                if not nexusqd_send(c):
                    raise Err("unavailable", "nexusqd rejected theme")
            with self.lock:
                self.state["theme"] = name
            return {"theme": name}, [("themeChanged", {"theme": name})]
        if method == "listThemes":
            return {"themes": THEMES}, []
        if method == "listScenes":
            return {"scenes": SCENES}, []
        if method == "setScene":
            name = str(p.get("scene", ""))
            idx = SCENE_INDEX.get(name)
            if idx is None:
                raise Err("bad_request", f"unknown scene {name}")
            # drop any solid override so the audio visualiser is visible, then select it
            if not nexusqd_send("auto") or not nexusqd_send(f"scene {idx}"):
                raise Err("unavailable", "nexusqd rejected scene")
            with self.lock:
                self.state["scene"] = name
            return {"scene": name}, [("sceneChanged", {"scene": name})]
        if method == "setBrightness":
            b = max(0, min(255, int(p.get("brightness", 255))))
            if not nexusqd_send(f"brightness {b}"):
                raise Err("unavailable", "nexusqd rejected brightness")
            with self.lock:
                self.state["brightness"] = b
            return {"brightness": b}, [("brightnessChanged", {"brightness": b})]
        if method == "getPlayState":
            with self.lock:
                return dict(self.state["nowPlaying"]), []
        if method in ("playPause", "next", "previous"):
            # v1: librespot is a Spotify-Connect receiver with no local transport
            # API — control happens from the Spotify app. Reserved for a future
            # backend (e.g. go-librespot's HTTP API). See PROTOCOL.md §5.
            raise Err("unavailable", "transport control not available in v1")
        if method == "startSetupMode":
            # Re-provisioning entry point: arm the force flag (the unit's
            # ExecCondition honors it even when a WiFi profile exists) and
            # start nexusq-setupd. The setup daemon owns everything after this.
            try:
                open(SETUP_FORCE_FLAG, "w").close()
                r = subprocess.run(["systemctl", "start", "nexusq-setupd.service"],
                                   capture_output=True, text=True, timeout=15)
                if r.returncode != 0:
                    raise Err("unavailable", "nexusq-setupd failed to start: " + r.stderr.strip())
            except OSError as e:
                raise Err("unavailable", f"cannot start setup mode: {e}")
            return {"started": True}, []
        raise Err("unknown_method", method)

    def _volume_cmd(self, method, p):
        # Volume/mute always act on the *active output's* PA sink, so the knob is
        # input-agnostic and follows the current output.
        sink = self._active_sink()
        with self.lock:
            vol = self.state["volume"]
            muted = self.state["muted"]
        if method == "setVolume":
            vol = max(0, min(100, int(p.get("volume", vol))))
            muted = False
            self.mixer.set_volume(sink, vol)  # implies unmute
        elif method == "adjustVolume":
            vol = max(0, min(100, vol + int(p.get("steps", 0))))
            self.mixer.set_volume(sink, vol)
        elif method == "setMuted":
            muted = bool(p.get("muted", False))
            self.mixer.set_muted(sink, muted)
        elif method == "toggleMute":
            muted = not muted
            self.mixer.set_muted(sink, muted)
        with self.lock:
            self.state["volume"] = vol
            self.state["muted"] = muted
        # drive nexusqd's dedicated mute LED so app mute has a device-side indicator
        # (idempotent set, same LED the hardware mute key lights)
        nexusqd_send(f"muted {1 if muted else 0}")
        return {"volume": vol, "muted": muted}, [("volumeChanged", {"volume": vol, "muted": muted})]

    def _list_outputs(self):
        """Enumerate the known outputs, marking which have a present PA sink and which
        is active (the current default sink). HDMI is omitted when its sink is absent
        (usually PULSE_IGNORE'd); speaker/spdif are always listed."""
        sinks = self.pulse.sinks()
        active = self._output_for_sink(self.pulse.default_sink())
        outs = []
        for o in OUTPUTS:
            sink = next((n for n in sinks if o["match"] in n), None)
            if sink is None and o["id"] == "hdmi":
                continue  # no real HDMI sink present → don't advertise it
            outs.append({
                "id": o["id"],
                "label": o["label"],
                "sink": sink or "",
                "available": sink is not None,
            })
        if active is None:
            with self.lock:
                active = self.state.get("output", "speaker")
        return {"outputs": outs, "active": active}

    def _set_output(self, p):
        oid = str(p.get("output", ""))
        if oid not in OUTPUT_BY_ID:
            raise Err("bad_request", f"unknown output {oid}")
        sink = self._sink_for_output(oid)
        if sink is None:
            raise Err("bad_request", f"output {oid} unavailable")
        # 1) new streams go here, 2) move every current stream so a live one follows.
        self.pulse.set_default_sink(sink)
        self.pulse.move_all_inputs(sink)
        # 3) point PA's default SOURCE at this output's monitor so the nexusqd LED
        # visualizer (`arecord -D pulse`, captures the default source) taps the mix
        # actually going to the selected output. Resilient (see set_default_source).
        self.pulse.set_default_source(sink + ".monitor")
        # 4) re-link the desktop tray volume icon to this output (best-effort).
        _sync_panel_applet(sink)
        # Hardware amp safety: power the class-D amp ONLY when the speaker is active,
        # so the banana-terminal amp is silent for the optical / HDMI outputs.
        if oid == "speaker":
            _amixer("sset", AMP_CTRL, "on")
            self.mixer.set_muted(sink, False)  # unmute the speaker sink
        else:
            _amixer("sset", AMP_CTRL, "off")
        # reconcile volume/mute from the now-active sink so the UI reflects reality
        vol, muted = self.mixer.get(sink)
        with self.lock:
            self.state["output"] = oid
            if vol is not None:
                self.state["volume"] = vol
                self.state["muted"] = bool(muted)
            vol_out = self.state["volume"]
            muted_out = self.state["muted"]
        events = [("outputChanged", {"output": oid}),
                  ("volumeChanged", {"volume": vol_out, "muted": muted_out})]
        return {"output": oid}, events

    # --- librespot hook (internal, over the unix socket) ----------------
    def on_hook(self, obj):
        kind = obj.get("kind", "")
        np = None
        with self.lock:
            cur = dict(self.state["nowPlaying"])
        if kind == "track_changed":
            cur.update({
                "track": obj.get("name", ""),
                "artist": obj.get("artists", ""),
                "album": obj.get("album", ""),
                "artUrl": obj.get("cover", ""),
                "source": "spotify",
                "playing": True,
            })
            np = cur
        elif kind in ("playing", "paused", "stopped"):
            cur["playing"] = (kind == "playing")
            np = cur
        elif kind == "volume":
            # librespot volume is 0..65535; convert to 0..100
            raw = int(obj.get("volume", 0))
            vol = round(raw * 100 / 65535)
            with self.lock:
                self.state["volume"] = vol
            self.broadcast("volumeChanged",
                           {"volume": vol, "muted": self.state["muted"]})
            return
        if np is not None:
            with self.lock:
                self.state["nowPlaying"] = np
            self.broadcast("nowPlayingChanged", np)


class Err(Exception):
    def __init__(self, code, message):
        super().__init__(message)
        self.code = code
        self.message = message


def _serial():
    for path in ("/sys/firmware/devicetree/base/serial-number",
                 "/proc/device-tree/serial-number"):
        try:
            with open(path, "rb") as f:
                return f.read().rstrip(b"\x00").decode(errors="replace")
        except OSError:
            pass
    return "unknown"


def _sw_version():
    try:
        with open("/etc/os-release") as f:
            for ln in f:
                if ln.startswith("VERSION="):
                    return ln.split("=", 1)[1].strip().strip('"')
    except OSError:
        pass
    return "unknown"


def read_json_lines(sock, on_obj):
    """Block reading newline-JSON objects from sock, calling on_obj(dict) for
    each, until the peer closes the connection."""
    buf = b""
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            return
        buf += chunk
        while b"\n" in buf:
            line, buf = buf.split(b"\n", 1)
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line.decode())
            except (ValueError, UnicodeDecodeError):
                continue
            on_obj(obj)


def client_thread(bridge, sock, addr):
    cid = bridge.add_client(sock)
    log("client connected:", addr)

    def handle_obj(obj):
        method = obj.get("method")
        rid = obj.get("id")
        if not isinstance(method, str):
            return
        events = []
        try:
            result, events = bridge.handle(method, obj.get("params"))
            if rid is not None:
                sock.sendall((json.dumps({"id": rid, "ok": True, "result": result}) + "\n").encode())
        except Err as e:
            if rid is not None:
                sock.sendall((json.dumps({"id": rid, "ok": False,
                                          "error": {"code": e.code, "message": e.message}}) + "\n").encode())
        except Exception as e:  # noqa: BLE001
            log("handler error:", method, e)
            if rid is not None:
                sock.sendall((json.dumps({"id": rid, "ok": False,
                                          "error": {"code": "internal", "message": str(e)}}) + "\n").encode())
        # broadcast side-effect events only after the ack has been written
        for name, data in events:
            bridge.broadcast(name, data)

    try:
        read_json_lines(sock, handle_obj)
    except OSError:
        pass
    finally:
        bridge.remove_client(cid)
        sock.close()
        log("client disconnected:", addr)


def hook_thread(bridge, sock):
    """Short-lived: a librespot onevent invocation pushes one event line."""
    try:
        read_json_lines(sock, bridge.on_hook)
    except OSError:
        pass
    finally:
        sock.close()


def serve_unix(bridge):
    try:
        os.unlink(HOOK_SOCK)
    except OSError:
        pass
    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(HOOK_SOCK)
    os.chmod(HOOK_SOCK, 0o660)
    srv.listen(8)
    log("hook socket:", HOOK_SOCK)
    while True:
        conn, _ = srv.accept()
        threading.Thread(target=hook_thread, args=(bridge, conn), daemon=True).start()


def publish_mdns():
    """Best-effort _nexusq._tcp advertisement via avahi (if present)."""
    try:
        return subprocess.Popen(
            ["avahi-publish-service", DEVICE_NAME, "_nexusq._tcp", str(PORT),
             "proto=1", f"name={DEVICE_NAME}", "model=steelhead", f"room={DEVICE_ROOM}"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    except FileNotFoundError:
        log("avahi-publish-service not found; mDNS disabled (connect by host:port)")
        return None


def pa_watch_thread(bridge):
    """Watch PulseAudio for sink volume/mute changes made OUTSIDE the bridge — the
    physical dome dial (nq-vol runs `pactl set-sink-volume`) and the LXQt panel
    applet both poke PA directly — and push them to app clients so the app slider
    tracks the knob. `pactl subscribe` fires 'change on sink' for volume, mute and
    run-state alike, so we re-read the active sink and broadcast only when the
    level or mute actually moved (state transitions from the LED tap gating would
    otherwise spam)."""
    env = {**os.environ, "PULSE_SERVER": PULSE_SERVER, "PULSE_COOKIE": PULSE_COOKIE}
    while True:
        proc = None
        try:
            proc = subprocess.Popen(
                ["pactl", "subscribe"], stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL, env=env, text=True, bufsize=1)
            for line in proc.stdout:
                if "on sink #" not in line:
                    continue
                sink = bridge._active_sink()
                if not sink:
                    continue
                vol, muted = bridge.mixer.get(sink)
                if vol is None:
                    continue
                with bridge.lock:
                    moved = (vol != bridge.state["volume"]
                             or bool(muted) != bridge.state["muted"])
                    if moved:
                        bridge.state["volume"] = vol
                        bridge.state["muted"] = bool(muted)
                if moved:
                    bridge.broadcast("volumeChanged",
                                     {"volume": vol, "muted": bool(muted)})
        except FileNotFoundError:
            log("pactl not found; dome-dial -> app volume sync disabled")
            return
        except OSError:
            pass
        finally:
            if proc:
                try:
                    proc.kill()
                except OSError:
                    pass
        time.sleep(1)  # subscribe ended (e.g. PA restart) — re-subscribe


def main():
    bridge = Bridge()
    threading.Thread(target=serve_unix, args=(bridge,), daemon=True).start()
    threading.Thread(target=pa_watch_thread, args=(bridge,), daemon=True).start()
    mdns = publish_mdns()

    srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    srv.bind((HOST, PORT))
    srv.listen(8)
    log(f"listening on {HOST}:{PORT}  (PA {PULSE_SERVER}, amp {MIXER_CARD}:{AMP_CTRL}, nexusqd {NEXUSQD_SOCK})")
    try:
        while True:
            conn, addr = srv.accept()
            conn.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
            threading.Thread(target=client_thread, args=(bridge, conn, addr), daemon=True).start()
    except KeyboardInterrupt:
        pass
    finally:
        if mdns:
            mdns.terminate()
        srv.close()


if __name__ == "__main__":
    main()
