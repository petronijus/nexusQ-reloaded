#!/usr/bin/env python3
"""librespot --onevent hook → nexusq-control.

librespot invokes this once per player event with the event in the environment.
We translate the relevant ones into a single JSON line and push it to the
bridge's local hook socket, which updates now-playing / volume and fans the
change out to connected companions. Best-effort: never fail librespot if the
bridge is down.
"""
import json
import os
import socket
import sys

HOOK_SOCK = os.environ.get("NEXUSQ_HOOK_SOCK", "/run/nexusq-control.sock")

# librespot exposes the event as PLAYER_EVENT (newer) or as argv[1] (older).
event = os.environ.get("PLAYER_EVENT") or (sys.argv[1] if len(sys.argv) > 1 else "")


def first_line(v):
    return (v or "").splitlines()[0] if v else ""


def env_csv(*names):
    """Join a possibly newline-separated env var (e.g. ARTISTS) as ', '."""
    for n in names:
        v = os.environ.get(n)
        if v:
            return ", ".join(x for x in v.splitlines() if x)
    return ""


obj = None
if event in ("track_changed", "changed", "started", "preloading", "loading"):
    name = os.environ.get("NAME", "")
    if name or os.environ.get("ARTISTS"):
        obj = {
            "kind": "track_changed",
            "name": name,
            "artists": env_csv("ARTISTS", "ALBUM_ARTISTS"),
            "album": os.environ.get("ALBUM", ""),
            "cover": first_line(os.environ.get("COVERS") or os.environ.get("COVER")),
        }
elif event in ("playing", "resumed"):
    obj = {"kind": "playing"}
elif event in ("paused",):
    obj = {"kind": "paused"}
elif event in ("stopped", "end_of_track", "session_disconnected"):
    obj = {"kind": "stopped"}
elif event in ("volume_changed", "volume_set"):
    obj = {"kind": "volume", "volume": int(os.environ.get("VOLUME", "0") or 0)}

if obj is None:
    sys.exit(0)

try:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
        s.settimeout(2)
        s.connect(HOOK_SOCK)
        s.sendall((json.dumps(obj) + "\n").encode())
except OSError:
    pass  # bridge not running — ignore
